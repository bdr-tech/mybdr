{
  "buildCommand": "prisma generate && next build",
  "outputDirectory": ".next",
  "framework": "nextjs",
  "installCommand": "npm install",
  "nodeVersion": "22.x",
  "crons": [
    {
      "path": "/api/cron/tournament-reminders",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/web/youtube/recommend",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/weekly-report",
      "schedule": "0 0 * * 1"
    }
  ]
}
