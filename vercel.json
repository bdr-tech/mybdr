{
  "buildCommand": "prisma generate && next build",
  "outputDirectory": ".next",
  "framework": "nextjs",
  "installCommand": "npm install",
  "regions": ["icn1"],
  "crons": [
    {
      "path": "/api/cron/tournament-reminders",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/notification-cleanup",
      "schedule": "0 18 * * *"
    }
  ]
}
