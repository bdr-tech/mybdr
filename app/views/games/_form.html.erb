<%# locals: (game:) %>
<%= form_with model: game, local: true, class: "space-y-6" do |f| %>
  <% if game.errors.any? %>
    <div class="alert alert-error">
      <ul class="list-disc list-inside">
        <% game.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <!-- 기본 정보 -->
  <div class="space-y-4">
    <h2 class="text-lg font-semibold text-gray-900 pb-2 border-b border-gray-200">기본 정보</h2>

    <div class="form-group">
      <%= f.label :game_type, "경기 타입", class: "form-label required" %>
      <%= f.select :game_type,
          options_for_select([
            ["픽업게임", "pickup"],
            ["게스트 모집", "guest_recruit"],
            ["팀 대 팀", "team_vs_team"]
          ], game.game_type),
          {}, class: "form-select", required: true %>
    </div>

    <div class="form-group">
      <%= f.label :title, "경기 제목", class: "form-label" %>
      <%= f.text_field :title, class: "form-input", placeholder: "예: 매주 화요일 픽업게임" %>
      <p class="form-hint">비워두면 자동으로 생성됩니다</p>
    </div>

    <div class="form-group">
      <%= f.label :description, "경기 설명", class: "form-label" %>
      <%= f.text_area :description, rows: 3, class: "form-input", placeholder: "경기에 대한 상세 설명을 입력해주세요" %>
    </div>
  </div>

  <!-- 일정 -->
  <div class="space-y-4">
    <h2 class="text-lg font-semibold text-gray-900 pb-2 border-b border-gray-200">일정</h2>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div class="form-group">
        <%= f.label :scheduled_at, "경기 일시", class: "form-label required" %>
        <%= f.datetime_local_field :scheduled_at, class: "form-input", required: true %>
      </div>

      <div class="form-group">
        <%= f.label :duration_hours, "경기 시간 (시간)", class: "form-label required" %>
        <%= f.select :duration_hours,
            options_for_select((1..5).map { |h| ["#{h}시간", h] }, game.duration_hours || 2),
            {}, class: "form-select" %>
      </div>
    </div>

    <!-- 반복 경기 -->
    <div class="form-group">
      <div class="flex items-center gap-3">
        <%= f.check_box :is_recurring, class: "form-checkbox", id: "is_recurring" %>
        <%= f.label :is_recurring, "반복 경기로 설정", class: "form-label mb-0" %>
      </div>
    </div>

    <div id="recurrence_options" class="<%= 'hidden' unless game.is_recurring? %>">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="form-group">
          <%= f.label :recurrence_rule, "반복 주기", class: "form-label" %>
          <%= f.select :recurrence_rule,
              options_for_select([
                ["매주", "weekly"],
                ["격주", "biweekly"],
                ["매월", "monthly"]
              ], game.recurrence_rule),
              { include_blank: "선택하세요" }, class: "form-select" %>
        </div>

        <% if game.new_record? %>
          <div class="form-group">
            <label class="form-label">자동 생성 횟수</label>
            <select name="recurring_count" class="form-select">
              <% (1..12).each do |n| %>
                <option value="<%= n %>" <%= 'selected' if n == 4 %>><%= n %>회</option>
              <% end %>
            </select>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <!-- 장소 -->
  <div class="space-y-4">
    <h2 class="text-lg font-semibold text-gray-900 pb-2 border-b border-gray-200">장소</h2>

    <%# 자주 가는 경기장 또는 추천 경기장 %>
    <% courts_data = @frequent_courts.presence || @recommended_courts || [] %>
    <% if courts_data.any? %>
      <div class="form-group">
        <label class="form-label flex items-center gap-2">
          <%= @court_section_title %>
          <% if @court_section_subtitle.present? %>
            <span class="text-xs text-gray-500 font-normal">(<%= @court_section_subtitle %>)</span>
          <% end %>
        </label>
        
        <div class="grid grid-cols-1 gap-2 mt-2">
          <% courts_data.each do |item| %>
            <% court = item.is_a?(Hash) ? item[:court] : item %>
            <% count = item.is_a?(Hash) ? item[:count] : nil %>
            <% next unless court %>
            <label class="relative flex items-center p-3 bg-white border rounded-xl cursor-pointer hover:bg-gray-50 transition court-option
                          <%= 'border-indigo-500 bg-indigo-50' if game.court_id == court.id %>">
              <%= f.radio_button :court_id, court.id, 
                  class: "sr-only peer",
                  data: { 
                    court_city: court.city,
                    court_district: court.district,
                    court_name: court.name,
                    court_address: court.address
                  } %>
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2">
                  <span class="text-sm font-medium text-gray-900"><%= court.name %></span>
                  <% if court.indoor? %>
                    <span class="inline-flex items-center px-1.5 py-0.5 rounded text-xs font-medium bg-blue-100 text-blue-700">실내</span>
                  <% else %>
                    <span class="inline-flex items-center px-1.5 py-0.5 rounded text-xs font-medium bg-green-100 text-green-700">실외</span>
                  <% end %>
                </div>
                <% if court.full_address.present? %>
                  <p class="text-xs text-gray-500 mt-0.5 truncate"><%= court.full_address %></p>
                <% end %>
              </div>
              <% if count.present? %>
                <div class="flex-shrink-0 ml-3 text-right">
                  <span class="text-sm font-semibold text-indigo-600"><%= count %>회</span>
                  <span class="text-xs text-gray-500 block">이용</span>
                </div>
              <% end %>
              <div class="flex-shrink-0 ml-3 w-5 h-5 rounded-full border-2 flex items-center justify-center
                          <%= game.court_id == court.id ? 'border-indigo-500 bg-indigo-500' : 'border-gray-300' %>">
                <% if game.court_id == court.id %>
                  <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                  </svg>
                <% end %>
              </div>
            </label>
          <% end %>
          
          <%# 직접 입력 옵션 %>
          <label class="relative flex items-center p-3 bg-white border rounded-xl cursor-pointer hover:bg-gray-50 transition
                        <%= 'border-indigo-500 bg-indigo-50' if game.court_id.blank? %>">
            <%= f.radio_button :court_id, "", 
                class: "sr-only peer",
                checked: game.court_id.blank?,
                data: { action: "change->games-form#selectCourt" } %>
            <div class="flex-1">
              <div class="flex items-center gap-2">
                <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
                </svg>
                <span class="text-sm font-medium text-gray-700">직접 입력</span>
              </div>
            </div>
            <div class="flex-shrink-0 ml-3 w-5 h-5 rounded-full border-2 flex items-center justify-center
                        <%= game.court_id.blank? ? 'border-indigo-500 bg-indigo-500' : 'border-gray-300' %>">
              <% if game.court_id.blank? %>
                <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
              <% end %>
            </div>
          </label>
        </div>
      </div>
    <% end %>

    <div id="manual_venue" class="<%= 'hidden' if game.court_id.present? && courts_data.any? %>">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="form-group">
          <%= f.label :city, "시/도", class: "form-label" %>
          <%= f.select :city,
              options_for_select(["서울특별시", "부산광역시", "대구광역시", "인천광역시", "광주광역시", "대전광역시", "울산광역시", "세종특별자치시", "경기도", "강원도", "충청북도", "충청남도", "전라북도", "전라남도", "경상북도", "경상남도", "제주특별자치도"], game.city),
              { include_blank: "선택하세요" }, class: "form-select" %>
        </div>

        <div class="form-group">
          <%= f.label :district, "구/군", class: "form-label" %>
          <%= f.text_field :district, class: "form-input", placeholder: "예: 강남구" %>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="form-group">
          <%= f.label :venue_name, "장소명", class: "form-label" %>
          <%= f.text_field :venue_name, class: "form-input", placeholder: "예: 올림픽공원 농구장" %>
        </div>

        <div class="form-group">
          <%= f.label :venue_address, "상세 주소", class: "form-label" %>
          <%= f.text_field :venue_address, class: "form-input", placeholder: "예: A코트" %>
        </div>
      </div>
    </div>
  </div>

  <!-- 참가 설정 -->
  <div class="space-y-4">
    <h2 class="text-lg font-semibold text-gray-900 pb-2 border-b border-gray-200">참가 설정</h2>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      <div class="form-group">
        <%= f.label :max_participants, "최대 인원", class: "form-label required" %>
        <%= f.number_field :max_participants, min: 2, max: 50, class: "form-input", required: true %>
      </div>

      <div class="form-group">
        <%= f.label :min_participants, "최소 인원", class: "form-label required" %>
        <%= f.number_field :min_participants, min: 1, max: 50, class: "form-input", required: true %>
      </div>

      <div class="form-group">
        <%= f.label :fee_per_person, "참가비 (원)", class: "form-label" %>
        <%= f.number_field :fee_per_person, min: 0, step: 1000, class: "form-input", placeholder: "0 = 무료" %>
      </div>
    </div>

    <div class="form-group">
      <%= f.label :skill_level, "난이도", class: "form-label" %>
      <%= f.select :skill_level,
          options_for_select([
            ["모든 레벨", "all"],
            ["초급", "beginner"],
            ["중급", "intermediate"],
            ["상급", "advanced"]
          ], game.skill_level),
          {}, class: "form-select" %>
    </div>

    <div class="form-group">
      <%= f.label :requirements, "참가 조건", class: "form-label" %>
      <%= f.text_area :requirements, rows: 2, class: "form-input", placeholder: "예: 농구화 필수, 초급자 환영" %>
    </div>
  </div>

  <!-- 유니폼 설정 -->
  <div class="space-y-4">
    <h2 class="text-lg font-semibold text-gray-900 pb-2 border-b border-gray-200">유니폼 색상</h2>

    <div class="grid grid-cols-2 gap-4">
      <div class="form-group">
        <%= f.label :uniform_home_color, "홈팀 색상", class: "form-label" %>
        <div class="flex items-center gap-3">
          <%= f.color_field :uniform_home_color, class: "w-12 h-12 rounded-lg border border-gray-300 cursor-pointer" %>
          <span class="text-sm text-gray-500"><%= game.uniform_home_color %></span>
        </div>
      </div>

      <div class="form-group">
        <%= f.label :uniform_away_color, "원정팀 색상", class: "form-label" %>
        <div class="flex items-center gap-3">
          <%= f.color_field :uniform_away_color, class: "w-12 h-12 rounded-lg border border-gray-300 cursor-pointer" %>
          <span class="text-sm text-gray-500"><%= game.uniform_away_color %></span>
        </div>
      </div>
    </div>
  </div>

  <!-- 제출 버튼 -->
  <div class="flex items-center justify-end gap-4 pt-6 border-t border-gray-200">
    <%= link_to "취소", game.persisted? ? game_path(game) : games_path, class: "btn btn-secondary" %>

    <% if game.new_record? && game.is_recurring? %>
      <input type="hidden" name="create_recurring" value="1">
    <% end %>

    <%= f.submit game.persisted? ? "저장하기" : "경기 만들기", class: "btn btn-primary" %>
  </div>
<% end %>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    // 반복 경기 토글
    const recurringCheckbox = document.getElementById('is_recurring');
    const recurrenceOptions = document.getElementById('recurrence_options');

    if (recurringCheckbox && recurrenceOptions) {
      recurringCheckbox.addEventListener('change', function() {
        recurrenceOptions.classList.toggle('hidden', !this.checked);
      });
    }

    // 경기장 선택 토글 (라디오 버튼)
    const courtRadios = document.querySelectorAll('input[name="game[court_id]"]');
    const manualVenue = document.getElementById('manual_venue');

    function updateManualVenueVisibility() {
      const selectedRadio = document.querySelector('input[name="game[court_id]"]:checked');
      if (manualVenue && selectedRadio) {
        // 값이 비어있으면 (직접 입력 선택) 보여주기
        manualVenue.classList.toggle('hidden', selectedRadio.value !== '');
      }
    }

    courtRadios.forEach(function(radio) {
      radio.addEventListener('change', updateManualVenueVisibility);
    });

    // 경기장 정보 자동 채우기
    function fillCourtInfo(radio) {
      const citySelect = document.querySelector('select[name="game[city]"]');
      const districtInput = document.querySelector('input[name="game[district]"]');
      const venueNameInput = document.querySelector('input[name="game[venue_name]"]');
      const venueAddressInput = document.querySelector('input[name="game[venue_address]"]');

      if (radio.value && radio.dataset.courtCity) {
        // 경기장 선택 시 정보 자동 채우기
        if (citySelect) citySelect.value = radio.dataset.courtCity || '';
        if (districtInput) districtInput.value = radio.dataset.courtDistrict || '';
        if (venueNameInput) venueNameInput.value = radio.dataset.courtName || '';
        if (venueAddressInput) venueAddressInput.value = radio.dataset.courtAddress || '';
      }
    }

    // 라디오 버튼 선택 시 스타일 업데이트 + 정보 채우기
    courtRadios.forEach(function(radio) {
      radio.addEventListener('change', function() {
        // 모든 라벨 스타일 리셋
        courtRadios.forEach(function(r) {
          const label = r.closest('label');
          if (label) {
            label.classList.remove('border-indigo-500', 'bg-indigo-50');
            const indicator = label.querySelector('.rounded-full');
            if (indicator) {
              indicator.classList.remove('border-indigo-500', 'bg-indigo-500');
              indicator.classList.add('border-gray-300');
              indicator.innerHTML = '';
            }
          }
        });
        
        // 선택된 라벨 스타일 적용
        const selectedLabel = this.closest('label');
        if (selectedLabel) {
          selectedLabel.classList.add('border-indigo-500', 'bg-indigo-50');
          const indicator = selectedLabel.querySelector('.rounded-full');
          if (indicator) {
            indicator.classList.remove('border-gray-300');
            indicator.classList.add('border-indigo-500', 'bg-indigo-500');
            indicator.innerHTML = '<svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>';
          }
        }

        // 경기장 정보 자동 채우기
        fillCourtInfo(this);
      });
    });

    // 초기 상태 설정
    updateManualVenueVisibility();
  });
</script>
