<%# locals: (game:) %>
<%= link_to game_path(game.uuid), class: "card hover:shadow-lg transition-shadow group" do %>
  <div class="p-5">
    <!-- 상단: 타입 & 상태 -->
    <div class="flex items-center justify-between mb-3">
      <span class="badge badge-<%= game.game_type %>">
        <%= game.game_type_name %>
      </span>
      <span class="badge badge-<%= game.status %>">
        <%= game.status_name %>
      </span>
    </div>

    <!-- 제목 -->
    <h3 class="font-semibold text-lg text-gray-900 group-hover:text-primary-600 transition-colors mb-2 line-clamp-1">
      <%= game.title.presence || "#{game.game_type_name} - #{game.location_display}" %>
    </h3>

    <!-- 일정 -->
    <div class="flex items-center text-gray-600 text-sm mb-2">
      <svg class="w-4 h-4 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
      </svg>
      <span><%= l(game.scheduled_at, format: :long) %></span>
    </div>

    <!-- 장소 -->
    <div class="flex items-center text-gray-600 text-sm mb-4">
      <svg class="w-4 h-4 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
      </svg>
      <span class="line-clamp-1"><%= game.location_display %></span>
    </div>

    <!-- 하단 정보 -->
    <div class="flex items-center justify-between pt-3 border-t border-gray-100">
      <!-- 참가 인원 -->
      <div class="flex items-center text-sm">
        <svg class="w-4 h-4 mr-1 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197m13.5-9a2.5 2.5 0 11-5 0 2.5 2.5 0 015 0z"/>
        </svg>
        <span class="<%= game.full? ? 'text-red-600 font-medium' : 'text-gray-600' %>">
          <%= game.current_participants %>/<%= game.max_participants %>명
        </span>
      </div>

      <!-- 참가비 -->
      <% if game.has_fee? %>
        <span class="font-semibold text-primary-600">
          <%= number_to_currency(game.fee_per_person, unit: "₩", precision: 0) %>
        </span>
      <% else %>
        <span class="text-green-600 font-medium">무료</span>
      <% end %>
    </div>
  </div>
<% end %>
