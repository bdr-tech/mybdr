<div class="p-4 hover:bg-gray-50 transition-colors group"
     data-section-id="<%= section.id %>"
     data-visible="<%= section.is_visible %>">
  <div class="flex items-center gap-4">
    <%# Drag Handle %>
    <div class="section-drag-handle cursor-move text-gray-400 hover:text-gray-600">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8h16M4 16h16"/>
      </svg>
    </div>

    <%# Section Icon & Info %>
    <div class="flex items-center gap-3 flex-1 min-w-0">
      <span class="text-2xl flex-shrink-0"><%= section_icon(section.section_type) %></span>
      <div class="min-w-0">
        <p class="font-medium text-gray-900 truncate">
          <%= section.title.presence || section_type_name(section.section_type) %>
        </p>
        <p class="text-sm text-gray-500">
          <%= section_type_name(section.section_type) %>
          <% unless section.is_visible %>
            <span class="text-orange-500">• 숨김</span>
          <% end %>
        </p>
      </div>
    </div>

    <%# Actions %>
    <div class="flex items-center gap-2 opacity-0 group-hover:opacity-100 transition-opacity">
      <%# Visibility Toggle %>
      <button type="button"
              class="p-2 text-gray-400 hover:text-gray-600 rounded-lg hover:bg-gray-100 transition-colors"
              data-action="click->page-editor#toggleVisibility"
              title="<%= section.is_visible ? '숨기기' : '표시하기' %>">
        <span data-visibility-icon><%= section.is_visible ? '👁️' : '👁️‍🗨️' %></span>
      </button>

      <%# Edit %>
      <button type="button"
              class="p-2 text-gray-400 hover:text-blue-600 rounded-lg hover:bg-blue-50 transition-colors"
              data-action="click->page-editor#editSection"
              title="편집">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
        </svg>
      </button>

      <%# Duplicate %>
      <button type="button"
              class="p-2 text-gray-400 hover:text-green-600 rounded-lg hover:bg-green-50 transition-colors"
              data-action="click->page-editor#duplicateSection"
              title="복제">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/>
        </svg>
      </button>

      <%# Delete %>
      <button type="button"
              class="p-2 text-gray-400 hover:text-red-600 rounded-lg hover:bg-red-50 transition-colors"
              data-action="click->page-editor#deleteSection"
              title="삭제">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
        </svg>
      </button>
    </div>
  </div>

  <%# Section Preview (collapsed by default) %>
  <% if section.content.present? %>
    <div class="mt-3 pl-9 text-sm text-gray-500 truncate">
      <%= truncate(section.content.to_s, length: 100) %>
    </div>
  <% end %>
</div>
