<% content_for :title do %>대시보드 - 대회관리자 콘솔<% end %>

<div class="space-y-8">
  <%# Welcome Section %>
  <div class="bg-white rounded-2xl shadow-sm p-6 md:p-8">
    <h1 class="text-2xl font-bold text-gray-900 mb-2">
      👋 안녕하세요, <%= current_user.nickname || current_user.name %>님!
    </h1>
    <p class="text-gray-600">대회관리자 콘솔에서 대회를 만들고 관리하세요.</p>
  </div>

  <%# Quick Stats %>
  <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
    <div class="bg-white rounded-xl shadow-sm p-6 text-center">
      <p class="text-3xl font-bold text-primary-600"><%= @stats[:total_tournaments] %></p>
      <p class="text-gray-500 text-sm mt-1">내 대회</p>
    </div>
    <div class="bg-white rounded-xl shadow-sm p-6 text-center">
      <p class="text-3xl font-bold text-green-600"><%= @stats[:active_tournaments] %></p>
      <p class="text-gray-500 text-sm mt-1">진행중</p>
    </div>
    <div class="bg-white rounded-xl shadow-sm p-6 text-center">
      <p class="text-3xl font-bold text-blue-600"><%= number_with_delimiter(@stats[:total_visitors]) %></p>
      <p class="text-gray-500 text-sm mt-1">총 방문자</p>
    </div>
    <div class="bg-white rounded-xl shadow-sm p-6 text-center">
      <p class="text-3xl font-bold text-orange-600"><%= @stats[:total_teams] %></p>
      <p class="text-gray-500 text-sm mt-1">참가팀</p>
    </div>
  </div>

  <%# Quick Actions %>
  <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
    <%= link_to new_tournament_admin_tournament_path, class: "bg-primary-600 hover:bg-primary-700 text-white rounded-xl p-6 flex items-center gap-4 transition-colors" do %>
      <div class="w-12 h-12 bg-white/20 rounded-full flex items-center justify-center text-2xl">+</div>
      <div>
        <p class="font-bold">새 대회 만들기</p>
        <p class="text-sm opacity-80">3분 안에 대회 사이트 완성</p>
      </div>
    <% end %>

    <%= link_to tournament_admin_tournaments_path, class: "bg-white hover:bg-gray-50 text-gray-900 rounded-xl p-6 flex items-center gap-4 shadow-sm transition-colors" do %>
      <div class="w-12 h-12 bg-gray-100 rounded-full flex items-center justify-center text-2xl">🏆</div>
      <div>
        <p class="font-bold">내 대회 관리</p>
        <p class="text-sm text-gray-500"><%= @tournaments.count %>개 대회</p>
      </div>
    <% end %>

    <%= link_to tournament_admin_templates_path, class: "bg-white hover:bg-gray-50 text-gray-900 rounded-xl p-6 flex items-center gap-4 shadow-sm transition-colors" do %>
      <div class="w-12 h-12 bg-gray-100 rounded-full flex items-center justify-center text-2xl">🎨</div>
      <div>
        <p class="font-bold">템플릿 둘러보기</p>
        <p class="text-sm text-gray-500">다양한 디자인 선택</p>
      </div>
    <% end %>
  </div>

  <%# Tournament List %>
  <div class="bg-white rounded-2xl shadow-sm overflow-hidden">
    <div class="p-6 border-b flex items-center justify-between">
      <h2 class="text-lg font-bold text-gray-900">📋 내 대회 목록</h2>
      <%= link_to "전체 보기", tournament_admin_tournaments_path, class: "text-primary-600 hover:text-primary-700 text-sm font-medium" %>
    </div>

    <% if @tournaments.any? %>
      <div class="divide-y">
        <% @tournaments.limit(5).each do |tournament| %>
          <div class="p-6 hover:bg-gray-50 transition-colors">
            <div class="flex items-start justify-between gap-4">
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2 mb-1">
                  <h3 class="font-semibold text-gray-900 truncate">
                    <%= tournament.name %>
                  </h3>
                  <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium
                               <%= tournament.status_in_progress? ? 'bg-green-100 text-green-800' :
                                   tournament.status_draft? ? 'bg-gray-100 text-gray-800' :
                                   tournament.status_completed? ? 'bg-blue-100 text-blue-800' :
                                   'bg-yellow-100 text-yellow-800' %>">
                    <%= tournament.status_name %>
                  </span>
                </div>

                <% if tournament.tournament_site %>
                  <p class="text-sm text-gray-500 mb-2">
                    🔗 <%= tournament.tournament_site.subdomain %>.mybdr.kr
                    <% if tournament.tournament_site.is_published %>
                      <span class="text-green-600">• 발행됨</span>
                    <% else %>
                      <span class="text-gray-400">• 미발행</span>
                    <% end %>
                  </p>
                <% end %>

                <div class="flex items-center gap-4 text-sm text-gray-500">
                  <span>📅 <%= tournament.date_range %></span>
                  <span>👥 <%= tournament.teams_count %>팀</span>
                  <% if tournament.tournament_site %>
                    <span>👀 <%= number_with_delimiter(tournament.tournament_site.views_count) %> 조회</span>
                  <% end %>
                </div>
              </div>

              <div class="flex items-center gap-2">
                <% if tournament.tournament_site %>
                  <%= link_to tournament_admin_tournament_site_path(tournament),
                              class: "px-3 py-1.5 text-sm font-medium text-gray-700 bg-gray-100 hover:bg-gray-200 rounded-lg transition-colors" do %>
                    사이트 편집
                  <% end %>
                <% end %>
                <%= link_to tournament_admin_tournament_path(tournament),
                            class: "px-3 py-1.5 text-sm font-medium text-white bg-primary-600 hover:bg-primary-700 rounded-lg transition-colors" do %>
                  관리
                <% end %>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="p-12 text-center">
        <div class="w-16 h-16 bg-gray-100 rounded-full flex items-center justify-center mx-auto mb-4 text-3xl">
          🏆
        </div>
        <h3 class="font-semibold text-gray-900 mb-1">아직 대회가 없습니다</h3>
        <p class="text-gray-500 text-sm mb-4">첫 번째 대회를 만들어보세요!</p>
        <%= link_to "새 대회 만들기", new_tournament_admin_tournament_path,
                    class: "inline-flex items-center px-4 py-2 bg-primary-600 text-white rounded-lg font-medium hover:bg-primary-700 transition-colors" %>
      </div>
    <% end %>
  </div>

  <%# Series Section %>
  <% if @series.any? %>
    <div class="bg-white rounded-2xl shadow-sm overflow-hidden">
      <div class="p-6 border-b flex items-center justify-between">
        <h2 class="text-lg font-bold text-gray-900">📁 내 시리즈</h2>
        <%= link_to "전체 보기", tournament_admin_series_index_path, class: "text-primary-600 hover:text-primary-700 text-sm font-medium" %>
      </div>

      <div class="divide-y">
        <% @series.limit(3).each do |series| %>
          <div class="p-6 hover:bg-gray-50 transition-colors">
            <div class="flex items-start justify-between gap-4">
              <div>
                <h3 class="font-semibold text-gray-900"><%= series.name %></h3>
                <p class="text-sm text-gray-500 mt-1">
                  총 <%= series.tournaments_count %>회 개최
                  <% if series.tournaments.any? %>
                    • 최근: <%= series.tournaments.order(edition_number: :desc).first&.name %>
                  <% end %>
                </p>
              </div>
              <%= link_to tournament_admin_series_path(series),
                          class: "px-3 py-1.5 text-sm font-medium text-gray-700 bg-gray-100 hover:bg-gray-200 rounded-lg transition-colors" do %>
                관리
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>
</div>
