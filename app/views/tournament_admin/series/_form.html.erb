<%= form_with model: @series,
              url: @series.persisted? ? tournament_admin_series_path(@series) : tournament_admin_series_index_path,
              local: true, class: "space-y-6" do |f| %>
  <% if @series.errors.any? %>
    <div class="bg-red-50 border border-red-200 rounded-lg p-4">
      <h3 class="text-sm font-medium text-red-800 mb-2">오류가 발생했습니다:</h3>
      <ul class="list-disc list-inside text-sm text-red-700">
        <% @series.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :name, "시리즈 이름", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_field :name, required: true, placeholder: "BDR 챔피언십",
                     class: "w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-600/20 focus:border-primary-600 transition-colors" %>
  </div>

  <div>
    <%= f.label :description, "설명", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_area :description, rows: 3, placeholder: "시리즈에 대한 간략한 설명을 입력하세요",
                    class: "w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-600/20 focus:border-primary-600 transition-colors" %>
  </div>

  <div>
    <%= f.label :logo_url, "로고 URL", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.url_field :logo_url, placeholder: "https://example.com/logo.png",
                    class: "w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-600/20 focus:border-primary-600 transition-colors" %>
    <p class="mt-1 text-sm text-gray-500">시리즈를 대표하는 로고 이미지 URL을 입력하세요</p>
  </div>

  <div class="flex items-center gap-2">
    <%= f.check_box :is_public, class: "rounded border-gray-300 text-primary-600 focus:ring-primary-500" %>
    <%= f.label :is_public, "공개", class: "text-sm text-gray-700" %>
    <span class="text-sm text-gray-500">(체크하면 일반 사용자에게 시리즈가 공개됩니다)</span>
  </div>

  <div class="pt-6 border-t flex justify-between">
    <%= link_to "취소", (@series.persisted? ? tournament_admin_series_path(@series) : tournament_admin_series_index_path),
                class: "px-6 py-2.5 text-gray-700 font-medium rounded-lg hover:bg-gray-100 transition-colors" %>
    <%= f.submit (@series.persisted? ? "저장" : "시리즈 생성"),
                 class: "px-6 py-2.5 bg-primary-600 text-white font-medium rounded-lg hover:bg-primary-700 transition-colors cursor-pointer" %>
  </div>
<% end %>
