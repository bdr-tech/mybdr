<% if @match.errors.any? %>
  <div class="alert-error mb-6">
    <ul class="list-disc list-inside">
      <% @match.errors.full_messages.each do |msg| %>
        <li><%= msg %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<div class="space-y-6">
  <!-- 대진 -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    <div>
      <label class="form-label">홈팀</label>
      <%= f.select :home_team_id,
                   options_for_select(
                     [["TBD (미정)", nil]] + teams.map { |t| [t.team.name, t.id] },
                     f.object.home_team_id
                   ),
                   {},
                   class: "form-select w-full" %>
    </div>
    <div>
      <label class="form-label">원정팀</label>
      <%= f.select :away_team_id,
                   options_for_select(
                     [["TBD (미정)", nil]] + teams.map { |t| [t.team.name, t.id] },
                     f.object.away_team_id
                   ),
                   {},
                   class: "form-select w-full" %>
    </div>
  </div>

  <!-- 라운드 정보 -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
    <div>
      <label class="form-label">라운드 번호</label>
      <%= f.number_field :round_number, class: "form-input w-full", min: 1 %>
    </div>
    <div>
      <label class="form-label">라운드명</label>
      <%= f.text_field :round_name, class: "form-input w-full", placeholder: "예: 8강, A조 1라운드" %>
    </div>
    <div>
      <label class="form-label">경기 번호</label>
      <%= f.number_field :match_number, class: "form-input w-full", min: 1 %>
    </div>
  </div>

  <!-- 조/브라켓 정보 -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
    <div>
      <label class="form-label">조 (그룹)</label>
      <%= f.text_field :group_name, class: "form-input w-full", placeholder: "예: A, B, W, L" %>
      <p class="text-xs text-gray-500 mt-1">그룹 스테이지 또는 더블 엘리미네이션용</p>
    </div>
    <div>
      <label class="form-label">브라켓 위치</label>
      <%= f.number_field :bracket_position, class: "form-input w-full", min: 0 %>
    </div>
    <div>
      <label class="form-label">브라켓 레벨</label>
      <%= f.number_field :bracket_level, class: "form-input w-full", min: 1 %>
    </div>
  </div>

  <hr class="border-gray-200">

  <!-- 일정 -->
  <div>
    <h3 class="font-semibold text-gray-900 mb-3">일정</h3>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div>
        <label class="form-label">경기 일시</label>
        <%= f.datetime_local_field :scheduled_at, class: "form-input w-full" %>
      </div>
      <div>
        <label class="form-label">상태</label>
        <%= f.select :status,
                     options_for_select([
                       ["예정", "scheduled"],
                       ["진행중", "in_progress"],
                       ["완료", "completed"],
                       ["취소", "cancelled"]
                     ], f.object.status),
                     {},
                     class: "form-select w-full" %>
      </div>
    </div>
  </div>

  <!-- 장소 -->
  <div>
    <h3 class="font-semibold text-gray-900 mb-3">장소</h3>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div>
        <label class="form-label">경기장</label>
        <%= f.text_field :venue_name, class: "form-input w-full", placeholder: "예: OO체육관" %>
      </div>
      <div>
        <label class="form-label">코트 번호</label>
        <%= f.text_field :court_number, class: "form-input w-full", placeholder: "예: A코트, 1번" %>
      </div>
    </div>
  </div>

  <!-- 메모 -->
  <div>
    <label class="form-label">메모</label>
    <%= f.text_area :notes, class: "form-input w-full", rows: 2, placeholder: "운영 참고사항..." %>
  </div>
</div>
