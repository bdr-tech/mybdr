<% content_for :title, "#{@tournament.name} - 일괄 일정 등록" %>

<div class="space-y-6">
  <!-- 헤더 -->
  <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">일괄 일정 등록</h1>
      <p class="text-gray-500 mt-1">여러 경기의 일정을 한 번에 등록합니다</p>
    </div>
  </div>

  <!-- 탭 네비게이션 -->
  <div class="border-b border-gray-200">
    <nav class="flex gap-4">
      <%= link_to tournament_admin_tournament_matches_path(@tournament),
                  class: "py-3 px-1 border-b-2 border-transparent text-gray-500 hover:text-gray-700 font-medium text-sm" do %>
        경기 목록
      <% end %>
      <%= link_to draw_tournament_admin_tournament_matches_path(@tournament),
                  class: "py-3 px-1 border-b-2 border-transparent text-gray-500 hover:text-gray-700 font-medium text-sm" do %>
        조 추첨
      <% end %>
      <%= link_to seeds_tournament_admin_tournament_matches_path(@tournament),
                  class: "py-3 px-1 border-b-2 border-transparent text-gray-500 hover:text-gray-700 font-medium text-sm" do %>
        시드 배정
      <% end %>
      <%= link_to bulk_schedule_tournament_admin_tournament_matches_path(@tournament),
                  class: "py-3 px-1 border-b-2 border-primary-500 text-primary-600 font-medium text-sm" do %>
        일괄 일정
      <% end %>
    </nav>
  </div>

  <div class="card">
    <div class="p-4 border-b border-gray-100 flex justify-between items-center">
      <div>
        <h2 class="font-semibold text-gray-900">일정 미확정 경기</h2>
        <p class="text-sm text-gray-500 mt-1">총 <%= @matches.count %>경기</p>
      </div>
    </div>

    <% if @matches.any? %>
      <%= form_tag update_bulk_schedule_tournament_admin_tournament_matches_path(@tournament), method: :patch do %>
        <div class="overflow-x-auto">
          <table class="w-full">
            <thead class="bg-gray-50">
              <tr>
                <th class="text-left text-xs font-semibold text-gray-600 px-4 py-3">경기</th>
                <th class="text-left text-xs font-semibold text-gray-600 px-4 py-3">라운드</th>
                <th class="text-left text-xs font-semibold text-gray-600 px-4 py-3">일시</th>
                <th class="text-left text-xs font-semibold text-gray-600 px-4 py-3">장소</th>
                <th class="text-left text-xs font-semibold text-gray-600 px-4 py-3">코트</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
              <% @matches.each do |match| %>
                <tr class="hover:bg-gray-50">
                  <td class="px-4 py-3">
                    <div class="flex items-center gap-2">
                      <span class="text-xs text-gray-400">#<%= match.match_number %></span>
                      <span class="font-medium text-gray-900 text-sm">
                        <%= match.home_team&.team&.name || 'TBD' %>
                        <span class="text-gray-400">vs</span>
                        <%= match.away_team&.team&.name || 'TBD' %>
                      </span>
                    </div>
                  </td>
                  <td class="px-4 py-3">
                    <span class="text-sm text-gray-600"><%= match.round_name || "#{match.round_number}라운드" %></span>
                  </td>
                  <td class="px-4 py-3">
                    <input type="datetime-local"
                           name="schedules[<%= match.id %>][scheduled_at]"
                           value="<%= match.scheduled_at&.strftime('%Y-%m-%dT%H:%M') %>"
                           class="text-sm border rounded px-2 py-1.5 w-48 focus:ring-2 focus:ring-primary-500">
                  </td>
                  <td class="px-4 py-3">
                    <input type="text"
                           name="schedules[<%= match.id %>][venue_name]"
                           value="<%= match.venue_name %>"
                           placeholder="경기장명"
                           class="text-sm border rounded px-2 py-1.5 w-32 focus:ring-2 focus:ring-primary-500">
                  </td>
                  <td class="px-4 py-3">
                    <input type="text"
                           name="schedules[<%= match.id %>][court_number]"
                           value="<%= match.court_number %>"
                           placeholder="코트"
                           class="text-sm border rounded px-2 py-1.5 w-20 focus:ring-2 focus:ring-primary-500">
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>

        <div class="p-4 bg-gray-50 border-t border-gray-100 flex justify-between items-center">
          <p class="text-sm text-gray-500">모든 변경사항을 저장하려면 버튼을 클릭하세요</p>
          <button type="submit" class="btn btn-primary">
            일정 일괄 저장
          </button>
        </div>
      <% end %>
    <% else %>
      <div class="p-12 text-center">
        <svg class="w-16 h-16 mx-auto text-gray-300 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        <p class="text-gray-500">모든 경기의 일정이 확정되었습니다</p>
        <%= link_to "경기 목록으로", tournament_admin_tournament_matches_path(@tournament), class: "text-primary-600 hover:underline" %>
      </div>
    <% end %>
  </div>

  <!-- 빠른 일정 입력 도움말 -->
  <div class="card p-6 bg-yellow-50 border-yellow-200">
    <h3 class="font-semibold text-yellow-900 mb-2">빠른 일정 입력 팁</h3>
    <ul class="text-sm text-yellow-800 space-y-1">
      <li>• 같은 날 여러 경기: 날짜만 바꾸면 같은 장소/코트가 유지됩니다</li>
      <li>• Tab 키로 다음 필드로 빠르게 이동</li>
      <li>• 일시만 입력해도 저장 가능 (장소는 나중에 수정)</li>
    </ul>
  </div>
</div>
