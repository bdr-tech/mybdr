<% content_for :title, "#{@tournament.name} - 경기 수정" %>

<div class="max-w-2xl mx-auto space-y-6">
  <div>
    <%= link_to tournament_admin_tournament_matches_path(@tournament), class: "text-primary-600 hover:underline text-sm" do %>
      &larr; 경기 목록으로
    <% end %>
    <h1 class="text-2xl font-bold text-gray-900 mt-2">경기 수정</h1>
    <p class="text-gray-500">#<%= @match.match_number %> - <%= @match.round_name || "#{@match.round_number}라운드" %></p>
  </div>

  <div class="card p-6">
    <%= form_with model: [@tournament, @match], url: tournament_admin_tournament_match_path(@tournament, @match), local: true do |f| %>
      <%= render "form", f: f, teams: @teams %>

      <div class="flex gap-3 mt-6 pt-6 border-t border-gray-100">
        <%= link_to "취소", tournament_admin_tournament_matches_path(@tournament), class: "btn btn-secondary" %>
        <%= f.submit "변경사항 저장", class: "btn btn-primary" %>
      </div>
    <% end %>
  </div>

  <!-- 위험 영역 -->
  <div class="card p-6 border-red-200 bg-red-50">
    <h3 class="font-semibold text-red-900 mb-2">위험 영역</h3>
    <%= button_to tournament_admin_tournament_match_path(@tournament, @match),
                  method: :delete,
                  class: "btn btn-danger",
                  data: { turbo_confirm: "이 경기를 삭제하시겠습니까? 이 작업은 되돌릴 수 없습니다." } do %>
      경기 삭제
    <% end %>
  </div>
</div>
