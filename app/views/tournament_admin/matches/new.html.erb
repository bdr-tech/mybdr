<% content_for :title, "#{@tournament.name} - 경기 추가" %>

<div class="max-w-2xl mx-auto space-y-6">
  <div>
    <%= link_to tournament_admin_tournament_matches_path(@tournament), class: "text-primary-600 hover:underline text-sm" do %>
      &larr; 경기 목록으로
    <% end %>
    <h1 class="text-2xl font-bold text-gray-900 mt-2">경기 추가</h1>
  </div>

  <div class="card p-6">
    <%= form_with model: [@tournament, @match], url: tournament_admin_tournament_matches_path(@tournament), local: true do |f| %>
      <%= render "form", f: f, teams: @teams %>

      <div class="flex gap-3 mt-6 pt-6 border-t border-gray-100">
        <%= link_to "취소", tournament_admin_tournament_matches_path(@tournament), class: "btn btn-secondary" %>
        <%= f.submit "경기 추가", class: "btn btn-primary" %>
      </div>
    <% end %>
  </div>
</div>
