<%# Player Card Section Form Fields %>

<div class="bg-blue-50 text-blue-800 p-4 rounded-lg">
  <p class="text-sm">
    <strong>선수 카드:</strong> 특정 선수의 정보와 통계를 카드 형식으로 표시합니다.
  </p>
</div>

<div>
  <%= f.label :player_id, "선수 선택", class: "block text-sm font-medium text-gray-700 mb-1" %>
  <%= f.select :player_id,
              [["MVP 자동 표시", ""]],
              {},
              class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500" %>
  <p class="mt-1 text-sm text-gray-500">비워두면 대회 MVP가 자동으로 표시됩니다</p>
</div>

<div class="space-y-3">
  <div class="flex items-center gap-3">
    <%= f.check_box :show_photo,
                   class: "w-5 h-5 text-primary-600 border-gray-300 rounded focus:ring-primary-500",
                   checked: true %>
    <%= f.label :show_photo, "선수 사진 표시", class: "text-sm text-gray-700" %>
  </div>

  <div class="flex items-center gap-3">
    <%= f.check_box :show_stats,
                   class: "w-5 h-5 text-primary-600 border-gray-300 rounded focus:ring-primary-500",
                   checked: true %>
    <%= f.label :show_stats, "통계 표시", class: "text-sm text-gray-700" %>
  </div>

  <div class="flex items-center gap-3">
    <%= f.check_box :show_team_info,
                   class: "w-5 h-5 text-primary-600 border-gray-300 rounded focus:ring-primary-500",
                   checked: true %>
    <%= f.label :show_team_info, "팀 정보 표시", class: "text-sm text-gray-700" %>
  </div>

  <div class="flex items-center gap-3">
    <%= f.check_box :show_bio,
                   class: "w-5 h-5 text-primary-600 border-gray-300 rounded focus:ring-primary-500" %>
    <%= f.label :show_bio, "선수 소개 표시", class: "text-sm text-gray-700" %>
  </div>
</div>

<div>
  <label class="block text-sm font-medium text-gray-700 mb-2">카드 스타일</label>
  <div class="flex gap-4">
    <label class="flex items-center gap-2">
      <%= f.radio_button :card_style, "default", class: "text-primary-600", checked: true %>
      <span class="text-sm">기본</span>
    </label>
    <label class="flex items-center gap-2">
      <%= f.radio_button :card_style, "compact", class: "text-primary-600" %>
      <span class="text-sm">컴팩트</span>
    </label>
    <label class="flex items-center gap-2">
      <%= f.radio_button :card_style, "featured", class: "text-primary-600" %>
      <span class="text-sm">강조</span>
    </label>
  </div>
</div>

<div>
  <label class="block text-sm font-medium text-gray-700 mb-2">표시할 통계</label>
  <div class="grid grid-cols-3 gap-3">
    <label class="flex items-center gap-2">
      <%= f.check_box :stat_ppg, checked: true, class: "w-4 h-4 text-primary-600 border-gray-300 rounded" %>
      <span class="text-sm">평균 득점</span>
    </label>
    <label class="flex items-center gap-2">
      <%= f.check_box :stat_rpg, checked: true, class: "w-4 h-4 text-primary-600 border-gray-300 rounded" %>
      <span class="text-sm">평균 리바운드</span>
    </label>
    <label class="flex items-center gap-2">
      <%= f.check_box :stat_apg, checked: true, class: "w-4 h-4 text-primary-600 border-gray-300 rounded" %>
      <span class="text-sm">평균 어시스트</span>
    </label>
    <label class="flex items-center gap-2">
      <%= f.check_box :stat_fg, class: "w-4 h-4 text-primary-600 border-gray-300 rounded" %>
      <span class="text-sm">야투율</span>
    </label>
    <label class="flex items-center gap-2">
      <%= f.check_box :stat_3pt, class: "w-4 h-4 text-primary-600 border-gray-300 rounded" %>
      <span class="text-sm">3점슛</span>
    </label>
    <label class="flex items-center gap-2">
      <%= f.check_box :stat_games, class: "w-4 h-4 text-primary-600 border-gray-300 rounded" %>
      <span class="text-sm">경기 수</span>
    </label>
  </div>
</div>
