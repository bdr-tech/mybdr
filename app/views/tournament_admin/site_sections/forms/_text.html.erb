<%# Text Section Form Fields %>

<div>
  <%= f.label :body, "본문", class: "block text-sm font-medium text-gray-700 mb-1" %>
  <%= f.text_area :body,
                 rows: 8,
                 class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500",
                 placeholder: "마크다운 형식으로 작성할 수 있습니다..." %>
  <p class="mt-1 text-sm text-gray-500">마크다운 문법을 지원합니다 (예: **굵게**, *기울임*, # 제목)</p>
</div>

<div>
  <label class="block text-sm font-medium text-gray-700 mb-2">정렬</label>
  <div class="flex gap-4">
    <label class="flex items-center gap-2">
      <%= f.radio_button :alignment, "left", class: "text-primary-600", checked: true %>
      <span class="text-sm">왼쪽</span>
    </label>
    <label class="flex items-center gap-2">
      <%= f.radio_button :alignment, "center", class: "text-primary-600" %>
      <span class="text-sm">가운데</span>
    </label>
    <label class="flex items-center gap-2">
      <%= f.radio_button :alignment, "right", class: "text-primary-600" %>
      <span class="text-sm">오른쪽</span>
    </label>
  </div>
</div>

<div class="grid grid-cols-2 gap-4">
  <div>
    <%= f.label :background_color, "배경색", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.color_field :background_color,
                     value: "#FFFFFF",
                     class: "w-full h-10 border border-gray-300 rounded-lg cursor-pointer" %>
  </div>
  <div>
    <%= f.label :text_color, "텍스트 색상", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.color_field :text_color,
                     value: "#1F2937",
                     class: "w-full h-10 border border-gray-300 rounded-lg cursor-pointer" %>
  </div>
</div>
