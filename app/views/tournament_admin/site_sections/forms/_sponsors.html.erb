<%# Sponsors Section Form Fields %>

<div id="sponsors-list" class="space-y-4">
  <p class="text-sm text-gray-500">스폰서 정보를 입력하세요. JSON 형식으로 저장됩니다.</p>

  <div>
    <%= f.label :sponsors_data, "스폰서 데이터 (JSON)", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_area :sponsors_data,
                   rows: 8,
                   class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 font-mono text-sm",
                   placeholder: '[
  {"name": "스폰서1", "logo": "https://...", "url": "https://..."},
  {"name": "스폰서2", "logo": "https://...", "url": "https://..."}
]' %>
  </div>
</div>

<div>
  <label class="block text-sm font-medium text-gray-700 mb-2">레이아웃</label>
  <div class="flex gap-4">
    <label class="flex items-center gap-2">
      <%= f.radio_button :layout, "grid", class: "text-primary-600", checked: true %>
      <span class="text-sm">그리드</span>
    </label>
    <label class="flex items-center gap-2">
      <%= f.radio_button :layout, "carousel", class: "text-primary-600" %>
      <span class="text-sm">캐러셀</span>
    </label>
    <label class="flex items-center gap-2">
      <%= f.radio_button :layout, "marquee", class: "text-primary-600" %>
      <span class="text-sm">마퀴</span>
    </label>
  </div>
</div>

<div>
  <%= f.label :logo_size, "로고 크기", class: "block text-sm font-medium text-gray-700 mb-1" %>
  <%= f.select :logo_size,
              [["작게", "small"], ["보통", "medium"], ["크게", "large"]],
              { selected: "medium" },
              class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500" %>
</div>
