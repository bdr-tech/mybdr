<%# Instagram Section Form Fields %>

<div>
  <%= f.label :username, "인스타그램 사용자명", class: "block text-sm font-medium text-gray-700 mb-1" %>
  <div class="flex">
    <span class="inline-flex items-center px-3 rounded-l-lg border border-r-0 border-gray-300 bg-gray-50 text-gray-500">@</span>
    <%= f.text_field :username,
                    class: "flex-1 px-4 py-2 border border-gray-300 rounded-r-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500",
                    placeholder: "instagram_username" %>
  </div>
</div>

<div>
  <%= f.label :post_count, "표시할 게시물 수", class: "block text-sm font-medium text-gray-700 mb-1" %>
  <%= f.number_field :post_count,
                    min: 1,
                    max: 12,
                    value: 6,
                    class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500" %>
</div>

<div>
  <%= f.label :columns, "열 개수", class: "block text-sm font-medium text-gray-700 mb-1" %>
  <%= f.select :columns,
              [[2, 2], [3, 3], [4, 4], [6, 6]],
              { selected: 3 },
              class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500" %>
</div>

<div class="bg-yellow-50 text-yellow-800 p-4 rounded-lg">
  <p class="text-sm">
    <strong>참고:</strong> 인스타그램 API 연동이 필요합니다.
    설정에서 인스타그램 액세스 토큰을 먼저 연결해주세요.
  </p>
</div>
