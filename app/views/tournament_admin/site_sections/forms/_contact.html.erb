<%# Contact Section Form Fields %>

<div>
  <%= f.label :email, "이메일", class: "block text-sm font-medium text-gray-700 mb-1" %>
  <%= f.email_field :email,
                   class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500",
                   placeholder: "contact@tournament.com" %>
</div>

<div>
  <%= f.label :phone, "전화번호", class: "block text-sm font-medium text-gray-700 mb-1" %>
  <%= f.tel_field :phone,
                 class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500",
                 placeholder: "010-1234-5678" %>
</div>

<div>
  <%= f.label :address, "주소", class: "block text-sm font-medium text-gray-700 mb-1" %>
  <%= f.text_field :address,
                  class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500",
                  placeholder: "서울시 강남구 테헤란로 123" %>
</div>

<div>
  <%= f.label :sns_links, "SNS 링크 (JSON)", class: "block text-sm font-medium text-gray-700 mb-1" %>
  <%= f.text_area :sns_links,
                 rows: 4,
                 class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 font-mono text-sm",
                 placeholder: '{
  "instagram": "https://instagram.com/...",
  "youtube": "https://youtube.com/..."
}' %>
</div>

<div class="flex items-center gap-3">
  <%= f.check_box :show_map,
                 class: "w-5 h-5 text-primary-600 border-gray-300 rounded focus:ring-primary-500" %>
  <%= f.label :show_map, "지도 표시", class: "text-sm text-gray-700" %>
</div>
