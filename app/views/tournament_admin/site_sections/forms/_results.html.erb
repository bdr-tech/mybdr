<%# Results Section Form Fields %>

<div class="bg-blue-50 text-blue-800 p-4 rounded-lg">
  <p class="text-sm">
    <strong>자동 데이터:</strong> 이 섹션은 대회 결과와 순위를 자동으로 표시합니다.
  </p>
</div>

<div class="space-y-3">
  <div class="flex items-center gap-3">
    <%= f.check_box :show_brackets,
                   class: "w-5 h-5 text-primary-600 border-gray-300 rounded focus:ring-primary-500",
                   checked: true %>
    <%= f.label :show_brackets, "대진표 표시", class: "text-sm text-gray-700" %>
  </div>

  <div class="flex items-center gap-3">
    <%= f.check_box :show_standings,
                   class: "w-5 h-5 text-primary-600 border-gray-300 rounded focus:ring-primary-500",
                   checked: true %>
    <%= f.label :show_standings, "순위표 표시", class: "text-sm text-gray-700" %>
  </div>

  <div class="flex items-center gap-3">
    <%= f.check_box :show_mvp,
                   class: "w-5 h-5 text-primary-600 border-gray-300 rounded focus:ring-primary-500" %>
    <%= f.label :show_mvp, "MVP 표시", class: "text-sm text-gray-700" %>
  </div>

  <div class="flex items-center gap-3">
    <%= f.check_box :show_awards,
                   class: "w-5 h-5 text-primary-600 border-gray-300 rounded focus:ring-primary-500" %>
    <%= f.label :show_awards, "수상 내역 표시", class: "text-sm text-gray-700" %>
  </div>
</div>

<div>
  <label class="block text-sm font-medium text-gray-700 mb-2">대진표 스타일</label>
  <div class="flex gap-4">
    <label class="flex items-center gap-2">
      <%= f.radio_button :bracket_style, "single", class: "text-primary-600", checked: true %>
      <span class="text-sm">단일 토너먼트</span>
    </label>
    <label class="flex items-center gap-2">
      <%= f.radio_button :bracket_style, "double", class: "text-primary-600" %>
      <span class="text-sm">더블 엘리미네이션</span>
    </label>
  </div>
</div>

<div>
  <%= f.label :max_standings, "순위표 최대 표시", class: "block text-sm font-medium text-gray-700 mb-1" %>
  <%= f.number_field :max_standings,
                    min: 1,
                    max: 100,
                    value: 8,
                    class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500" %>
</div>
