<%# FAQ Section Form Fields %>
<% section ||= nil %>
<% existing_content = section&.content || {} %>
<% existing_settings = section&.settings || {} %>

<div>
  <%= f.label :questions, "FAQ 항목 (JSON)", class: "block text-sm font-medium text-gray-700 mb-1" %>
  <%= text_area_tag "site_section[content][questions]",
               existing_content["questions"] || '[
  {"question": "참가 자격은 어떻게 되나요?", "answer": "누구나 참가 가능합니다."},
  {"question": "참가비가 있나요?", "answer": "무료 참가입니다."}
]',
               rows: 10,
               class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 font-mono text-sm" %>
  <p class="mt-1 text-sm text-gray-500">JSON 배열 형식으로 작성하세요</p>
</div>

<div>
  <label class="block text-sm font-medium text-gray-700 mb-2">스타일</label>
  <div class="flex gap-4">
    <label class="flex items-center gap-2">
      <%= radio_button_tag "site_section[settings][style]", "accordion", existing_settings["style"] == "accordion" || existing_settings["style"].nil?, class: "text-primary-600" %>
      <span class="text-sm">아코디언</span>
    </label>
    <label class="flex items-center gap-2">
      <%= radio_button_tag "site_section[settings][style]", "list", existing_settings["style"] == "list", class: "text-primary-600" %>
      <span class="text-sm">리스트</span>
    </label>
    <label class="flex items-center gap-2">
      <%= radio_button_tag "site_section[settings][style]", "grid", existing_settings["style"] == "grid", class: "text-primary-600" %>
      <span class="text-sm">그리드</span>
    </label>
  </div>
</div>

<div class="flex items-center gap-3">
  <%= check_box_tag "site_section[settings][expand_first]", "1",
               existing_settings["expand_first"] == true || existing_settings["expand_first"].nil?,
               class: "w-5 h-5 text-primary-600 border-gray-300 rounded focus:ring-primary-500" %>
  <label for="site_section_settings_expand_first" class="text-sm text-gray-700">첫 번째 항목 자동 펼치기</label>
</div>
