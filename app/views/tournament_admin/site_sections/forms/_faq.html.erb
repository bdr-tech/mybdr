<%# FAQ Section Form Fields %>

<div>
  <%= f.label :questions, "FAQ 항목 (JSON)", class: "block text-sm font-medium text-gray-700 mb-1" %>
  <%= f.text_area :questions,
                 rows: 10,
                 class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 font-mono text-sm",
                 placeholder: '[
  {"question": "참가 자격은 어떻게 되나요?", "answer": "누구나 참가 가능합니다."},
  {"question": "참가비가 있나요?", "answer": "무료 참가입니다."}
]' %>
  <p class="mt-1 text-sm text-gray-500">JSON 배열 형식으로 작성하세요</p>
</div>

<div>
  <label class="block text-sm font-medium text-gray-700 mb-2">스타일</label>
  <div class="flex gap-4">
    <label class="flex items-center gap-2">
      <%= f.radio_button :style, "accordion", class: "text-primary-600", checked: true %>
      <span class="text-sm">아코디언</span>
    </label>
    <label class="flex items-center gap-2">
      <%= f.radio_button :style, "list", class: "text-primary-600" %>
      <span class="text-sm">리스트</span>
    </label>
    <label class="flex items-center gap-2">
      <%= f.radio_button :style, "grid", class: "text-primary-600" %>
      <span class="text-sm">그리드</span>
    </label>
  </div>
</div>

<div class="flex items-center gap-3">
  <%= f.check_box :expand_first,
                 class: "w-5 h-5 text-primary-600 border-gray-300 rounded focus:ring-primary-500",
                 checked: true %>
  <%= f.label :expand_first, "첫 번째 항목 자동 펼치기", class: "text-sm text-gray-700" %>
</div>
