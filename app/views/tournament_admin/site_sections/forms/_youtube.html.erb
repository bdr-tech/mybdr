<%# YouTube Section Form Fields %>

<div>
  <%= f.label :video_url, "유튜브 영상 URL", class: "block text-sm font-medium text-gray-700 mb-1" %>
  <%= f.url_field :video_url,
                 class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500",
                 placeholder: "https://www.youtube.com/watch?v=..." %>
  <p class="mt-1 text-sm text-gray-500">일반 URL 또는 임베드 URL 모두 지원합니다</p>
</div>

<div class="space-y-3">
  <div class="flex items-center gap-3">
    <%= f.check_box :autoplay,
                   class: "w-5 h-5 text-primary-600 border-gray-300 rounded focus:ring-primary-500" %>
    <%= f.label :autoplay, "자동 재생", class: "text-sm text-gray-700" %>
  </div>

  <div class="flex items-center gap-3">
    <%= f.check_box :muted,
                   class: "w-5 h-5 text-primary-600 border-gray-300 rounded focus:ring-primary-500",
                   checked: true %>
    <%= f.label :muted, "음소거로 시작", class: "text-sm text-gray-700" %>
  </div>

  <div class="flex items-center gap-3">
    <%= f.check_box :loop_video,
                   class: "w-5 h-5 text-primary-600 border-gray-300 rounded focus:ring-primary-500" %>
    <%= f.label :loop_video, "반복 재생", class: "text-sm text-gray-700" %>
  </div>
</div>

<div>
  <label class="block text-sm font-medium text-gray-700 mb-2">비율</label>
  <div class="flex gap-4">
    <label class="flex items-center gap-2">
      <%= f.radio_button :aspect_ratio, "16:9", class: "text-primary-600", checked: true %>
      <span class="text-sm">16:9</span>
    </label>
    <label class="flex items-center gap-2">
      <%= f.radio_button :aspect_ratio, "4:3", class: "text-primary-600" %>
      <span class="text-sm">4:3</span>
    </label>
    <label class="flex items-center gap-2">
      <%= f.radio_button :aspect_ratio, "1:1", class: "text-primary-600" %>
      <span class="text-sm">1:1</span>
    </label>
  </div>
</div>
