<%# CTA Section Form Fields %>
<% section ||= nil %>
<% existing_content = section&.content || {} %>
<% existing_settings = section&.settings || {} %>

<div>
  <%= f.label :description, "설명", class: "block text-sm font-medium text-gray-700 mb-1" %>
  <%= text_area_tag "site_section[content][description]",
               existing_content["description"],
               rows: 3,
               class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500",
               placeholder: "지금 참가 신청하고 우승을 향해 도전하세요!" %>
</div>

<div class="grid grid-cols-2 gap-4">
  <div>
    <%= f.label :button_text, "버튼 텍스트", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= text_field_tag "site_section[content][button_text]",
                   existing_content["button_text"],
                   class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500",
                   placeholder: "참가 신청하기" %>
  </div>
  <div>
    <%= f.label :button_url, "버튼 링크", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= text_field_tag "site_section[content][button_url]",
                   existing_content["button_url"],
                   class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500",
                   placeholder: "/register" %>
  </div>
</div>

<div class="grid grid-cols-2 gap-4">
  <div>
    <%= f.label :button_color, "버튼 색상", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= color_field_tag "site_section[settings][button_color]",
                   existing_settings["button_color"] || "#E53E3E",
                   class: "w-full h-10 border border-gray-300 rounded-lg cursor-pointer" %>
  </div>
  <div>
    <%= f.label :background_color, "배경 색상", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.color_field :background_color,
                     value: section&.background_color || "#1F2937",
                     class: "w-full h-10 border border-gray-300 rounded-lg cursor-pointer" %>
  </div>
</div>

<div>
  <label class="block text-sm font-medium text-gray-700 mb-2">정렬</label>
  <div class="flex gap-4">
    <label class="flex items-center gap-2">
      <%= radio_button_tag "site_section[settings][alignment]", "left", existing_settings["alignment"] == "left", class: "text-primary-600" %>
      <span class="text-sm">왼쪽</span>
    </label>
    <label class="flex items-center gap-2">
      <%= radio_button_tag "site_section[settings][alignment]", "center", existing_settings["alignment"] == "center" || existing_settings["alignment"].nil?, class: "text-primary-600" %>
      <span class="text-sm">가운데</span>
    </label>
    <label class="flex items-center gap-2">
      <%= radio_button_tag "site_section[settings][alignment]", "right", existing_settings["alignment"] == "right", class: "text-primary-600" %>
      <span class="text-sm">오른쪽</span>
    </label>
  </div>
</div>
