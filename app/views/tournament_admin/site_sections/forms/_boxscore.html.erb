<%# Boxscore Section Form Fields %>

<div class="bg-blue-50 text-blue-800 p-4 rounded-lg">
  <p class="text-sm">
    <strong>박스스코어:</strong> 경기의 상세 통계를 표시합니다. 특정 경기를 선택하거나 최근 경기를 자동으로 표시할 수 있습니다.
  </p>
</div>

<div>
  <%= f.label :game_id, "경기 선택", class: "block text-sm font-medium text-gray-700 mb-1" %>
  <%= f.select :game_id,
              [["최근 경기 자동 표시", ""]],
              {},
              class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500" %>
  <p class="mt-1 text-sm text-gray-500">비워두면 가장 최근 종료된 경기가 표시됩니다</p>
</div>

<div class="space-y-3">
  <div class="flex items-center gap-3">
    <%= f.check_box :show_player_stats,
                   class: "w-5 h-5 text-primary-600 border-gray-300 rounded focus:ring-primary-500",
                   checked: true %>
    <%= f.label :show_player_stats, "선수별 기록 표시", class: "text-sm text-gray-700" %>
  </div>

  <div class="flex items-center gap-3">
    <%= f.check_box :show_team_stats,
                   class: "w-5 h-5 text-primary-600 border-gray-300 rounded focus:ring-primary-500",
                   checked: true %>
    <%= f.label :show_team_stats, "팀 통계 표시", class: "text-sm text-gray-700" %>
  </div>

  <div class="flex items-center gap-3">
    <%= f.check_box :show_quarter_scores,
                   class: "w-5 h-5 text-primary-600 border-gray-300 rounded focus:ring-primary-500",
                   checked: true %>
    <%= f.label :show_quarter_scores, "쿼터별 점수 표시", class: "text-sm text-gray-700" %>
  </div>

  <div class="flex items-center gap-3">
    <%= f.check_box :show_highlights,
                   class: "w-5 h-5 text-primary-600 border-gray-300 rounded focus:ring-primary-500" %>
    <%= f.label :show_highlights, "하이라이트 표시", class: "text-sm text-gray-700" %>
  </div>
</div>

<div>
  <label class="block text-sm font-medium text-gray-700 mb-2">통계 표시 항목</label>
  <div class="grid grid-cols-3 gap-3">
    <label class="flex items-center gap-2">
      <%= f.check_box :stat_points, checked: true, class: "w-4 h-4 text-primary-600 border-gray-300 rounded" %>
      <span class="text-sm">득점</span>
    </label>
    <label class="flex items-center gap-2">
      <%= f.check_box :stat_rebounds, checked: true, class: "w-4 h-4 text-primary-600 border-gray-300 rounded" %>
      <span class="text-sm">리바운드</span>
    </label>
    <label class="flex items-center gap-2">
      <%= f.check_box :stat_assists, checked: true, class: "w-4 h-4 text-primary-600 border-gray-300 rounded" %>
      <span class="text-sm">어시스트</span>
    </label>
    <label class="flex items-center gap-2">
      <%= f.check_box :stat_steals, class: "w-4 h-4 text-primary-600 border-gray-300 rounded" %>
      <span class="text-sm">스틸</span>
    </label>
    <label class="flex items-center gap-2">
      <%= f.check_box :stat_blocks, class: "w-4 h-4 text-primary-600 border-gray-300 rounded" %>
      <span class="text-sm">블록</span>
    </label>
    <label class="flex items-center gap-2">
      <%= f.check_box :stat_turnovers, class: "w-4 h-4 text-primary-600 border-gray-300 rounded" %>
      <span class="text-sm">턴오버</span>
    </label>
  </div>
</div>
