<turbo-frame id="section_modal">
  <div class="fixed inset-0 bg-black/50 z-50 flex items-center justify-center p-4"
       data-action="click->page-editor#closeModal">
    <div class="bg-white rounded-2xl shadow-xl max-w-2xl w-full max-h-[90vh] overflow-hidden"
         data-action="click->page-editor#stopPropagation">

      <%# Modal Header %>
      <div class="px-6 py-4 border-b flex items-center justify-between">
        <div class="flex items-center gap-3">
          <span class="text-2xl"><%= section_icon(@section_type) %></span>
          <h2 class="text-lg font-bold text-gray-900">
            <%= section_type_name(@section_type) %> 추가
          </h2>
        </div>
        <button type="button" class="text-gray-400 hover:text-gray-600"
                data-action="click->page-editor#closeModal">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>

      <%# Modal Body %>
      <div class="p-6 overflow-y-auto max-h-[calc(90vh-140px)]">
        <%= form_with model: @section,
                      url: tournament_admin_tournament_site_page_site_sections_path(@tournament, @page),
                      class: "space-y-6" do |f| %>

          <%= f.hidden_field :section_type, value: @section_type %>
          <% if @position.present? %>
            <%= f.hidden_field :position, value: @position %>
          <% end %>

          <%# Common Fields %>
          <div>
            <%= f.label :title, "섹션 제목", class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= f.text_field :title,
                            class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500",
                            placeholder: "선택사항: 섹션 제목을 입력하세요" %>
          </div>

          <%# Section Type Specific Fields %>
          <%= render "tournament_admin/site_sections/forms/#{@section_type}", f: f %>

          <%# Visibility %>
          <div class="flex items-center gap-3">
            <%= f.check_box :is_visible,
                           class: "w-5 h-5 text-primary-600 border-gray-300 rounded focus:ring-primary-500",
                           checked: true %>
            <%= f.label :is_visible, "페이지에 표시", class: "text-sm text-gray-700" %>
          </div>

          <%# Submit %>
          <div class="flex justify-end gap-3 pt-4 border-t">
            <button type="button"
                    class="px-4 py-2 text-gray-700 bg-gray-100 hover:bg-gray-200 rounded-lg font-medium transition-colors"
                    data-action="click->page-editor#closeModal">
              취소
            </button>
            <%= f.submit "추가하기",
                        class: "px-6 py-2 bg-primary-600 hover:bg-primary-700 text-white rounded-lg font-medium transition-colors cursor-pointer" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</turbo-frame>
