<div class="max-w-4xl mx-auto" data-controller="design-preview">
  <%# Header %>
  <div class="flex justify-between items-start mb-8">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">디자인 편집</h1>
      <p class="mt-1 text-gray-600"><%= @tournament.name %></p>
    </div>
    <%= link_to tournament_admin_tournament_site_path(@tournament),
                class: "inline-flex items-center gap-2 px-4 py-2 text-gray-600 hover:text-gray-900 transition-colors" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
      </svg>
      돌아가기
    <% end %>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <%# Form %>
    <div class="lg:col-span-2">
      <%= form_with model: @site, url: update_design_tournament_admin_tournament_site_path(@tournament), method: :patch, class: "space-y-6" do |f| %>
        <% if @site.errors.any? %>
          <div class="bg-red-50 border border-red-200 rounded-lg p-4">
            <h3 class="text-sm font-medium text-red-800 mb-2">오류가 발생했습니다:</h3>
            <ul class="list-disc list-inside text-sm text-red-700">
              <% @site.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <%# Color Settings %>
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
          <h2 class="text-lg font-semibold text-gray-900 mb-4">🎨 색상 설정</h2>

          <div class="grid grid-cols-2 gap-6">
            <div>
              <%= f.label :primary_color, "메인 색상", class: "block text-sm font-medium text-gray-700 mb-2" %>
              <div class="flex items-center gap-3">
                <%= f.color_field :primary_color,
                                  value: @site.primary_color || "#E53E3E",
                                  class: "w-16 h-10 rounded border-0 cursor-pointer",
                                  data: { design_preview_target: "colorInput", action: "input->design-preview#updateColor" } %>
                <span class="text-sm text-gray-500"><%= @site.primary_color || "#E53E3E" %></span>
              </div>
            </div>

            <div>
              <%= f.label :secondary_color, "보조 색상", class: "block text-sm font-medium text-gray-700 mb-2" %>
              <div class="flex items-center gap-3">
                <%= f.color_field :secondary_color,
                                  value: @site.secondary_color || "#ED8936",
                                  class: "w-16 h-10 rounded border-0 cursor-pointer" %>
                <span class="text-sm text-gray-500"><%= @site.secondary_color || "#ED8936" %></span>
              </div>
            </div>
          </div>

          <%# Color Presets %>
          <div class="mt-6">
            <p class="text-sm font-medium text-gray-700 mb-3">빠른 선택</p>
            <div class="flex flex-wrap gap-2">
              <% [
                { color: "#E53E3E", name: "레드" },
                { color: "#DD6B20", name: "오렌지" },
                { color: "#D69E2E", name: "옐로우" },
                { color: "#38A169", name: "그린" },
                { color: "#3182CE", name: "블루" },
                { color: "#805AD5", name: "퍼플" },
                { color: "#D53F8C", name: "핑크" },
                { color: "#1A202C", name: "다크" }
              ].each do |preset| %>
                <button type="button"
                        data-color="<%= preset[:color] %>"
                        data-action="click->design-preview#selectColor"
                        class="w-8 h-8 rounded-lg border-2 border-gray-200 hover:border-gray-400 transition-colors hover:scale-110"
                        style="background-color: <%= preset[:color] %>"
                        title="<%= preset[:name] %>">
                </button>
              <% end %>
            </div>
          </div>
        </div>

        <%# Logo & Images %>
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
          <h2 class="text-lg font-semibold text-gray-900 mb-4">🖼️ 이미지 설정</h2>

          <div class="space-y-5">
            <div>
              <%= f.label :logo_url, "로고 이미지 URL", class: "block text-sm font-medium text-gray-700 mb-1" %>
              <%= f.url_field :logo_url, placeholder: "https://example.com/logo.png",
                              class: "w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-600/20 focus:border-primary-600 transition-colors" %>
              <p class="mt-1 text-sm text-gray-500">사이트 헤더에 표시될 로고 이미지</p>
            </div>

            <div>
              <%= f.label :hero_image_url, "히어로 배경 이미지 URL", class: "block text-sm font-medium text-gray-700 mb-1" %>
              <%= f.url_field :hero_image_url, placeholder: "https://example.com/hero.jpg",
                              class: "w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-600/20 focus:border-primary-600 transition-colors" %>
              <p class="mt-1 text-sm text-gray-500">홈 페이지 상단에 표시될 대형 배경 이미지</p>
            </div>

            <div>
              <%= f.label :favicon_url, "파비콘 URL", class: "block text-sm font-medium text-gray-700 mb-1" %>
              <%= f.url_field :favicon_url, placeholder: "https://example.com/favicon.ico",
                              class: "w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-600/20 focus:border-primary-600 transition-colors" %>
              <p class="mt-1 text-sm text-gray-500">브라우저 탭에 표시될 작은 아이콘 (32x32px 권장)</p>
            </div>
          </div>
        </div>

        <%# SEO Settings %>
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
          <h2 class="text-lg font-semibold text-gray-900 mb-4">🔍 SEO 설정</h2>

          <div class="space-y-5">
            <div>
              <%= f.label :meta_title, "메타 타이틀", class: "block text-sm font-medium text-gray-700 mb-1" %>
              <%= f.text_field :meta_title, placeholder: @tournament.name,
                               class: "w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-600/20 focus:border-primary-600 transition-colors" %>
              <p class="mt-1 text-sm text-gray-500">검색 결과에 표시될 페이지 제목</p>
            </div>

            <div>
              <%= f.label :meta_description, "메타 설명", class: "block text-sm font-medium text-gray-700 mb-1" %>
              <%= f.text_area :meta_description, rows: 3, placeholder: "대회 사이트에 대한 간략한 설명을 입력하세요",
                              class: "w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-600/20 focus:border-primary-600 transition-colors" %>
              <p class="mt-1 text-sm text-gray-500">검색 결과에 표시될 페이지 설명 (150자 내외 권장)</p>
            </div>

            <div>
              <%= f.label :og_image_url, "소셜 공유 이미지 URL", class: "block text-sm font-medium text-gray-700 mb-1" %>
              <%= f.url_field :og_image_url, placeholder: "https://example.com/og-image.jpg",
                              class: "w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-600/20 focus:border-primary-600 transition-colors" %>
              <p class="mt-1 text-sm text-gray-500">SNS 공유 시 표시될 이미지 (1200x630px 권장)</p>
            </div>
          </div>
        </div>

        <%# Submit %>
        <div class="flex justify-between items-center pt-4">
          <%= link_to "취소", tournament_admin_tournament_site_path(@tournament),
                      class: "px-6 py-2.5 text-gray-700 font-medium rounded-lg hover:bg-gray-100 transition-colors" %>
          <%= f.submit "디자인 저장",
                       class: "px-6 py-2.5 bg-primary-600 text-white font-medium rounded-lg hover:bg-primary-700 transition-colors cursor-pointer" %>
        </div>
      <% end %>
    </div>

    <%# Preview %>
    <div class="lg:col-span-1">
      <div class="sticky top-6">
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-4">
          <h3 class="text-sm font-semibold text-gray-700 mb-3">미리보기</h3>

          <div data-design-preview-target="preview" class="rounded-lg overflow-hidden border border-gray-200">
            <%# Preview Mock %>
            <div class="aspect-video flex items-center justify-center" style="background-color: <%= @site.primary_color || '#E53E3E' %>">
              <% if @site.logo_url.present? %>
                <img src="<%= @site.logo_url %>" alt="Logo" class="h-12 object-contain">
              <% else %>
                <span class="text-white text-3xl font-bold"><%= @tournament.name.first.upcase %></span>
              <% end %>
            </div>

            <div class="p-4 bg-gray-50">
              <div class="h-3 w-3/4 rounded" style="background-color: <%= @site.primary_color || '#E53E3E' %>"></div>
              <div class="mt-2 h-2 bg-gray-200 rounded w-full"></div>
              <div class="mt-1 h-2 bg-gray-200 rounded w-2/3"></div>
            </div>
          </div>

          <div class="mt-4 p-3 bg-gray-50 rounded-lg">
            <p class="text-xs text-gray-500">
              실제 사이트 URL:<br>
              <a href="<%= @site.full_url %>" target="_blank" class="text-primary-600 hover:underline font-medium">
                <%= @site.full_url %>
              </a>
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
