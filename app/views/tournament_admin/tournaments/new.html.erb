<% content_for :title do %>새 대회 만들기 - 대회관리자 콘솔<% end %>

<div class="space-y-6">
  <%# Header %>
  <div class="flex items-center gap-4">
    <%= link_to tournament_admin_tournaments_path, class: "p-2 text-gray-400 hover:text-gray-600 transition-colors" do %>
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
    <% end %>
    <div>
      <h1 class="text-2xl font-bold text-gray-900">새 대회 만들기</h1>
      <p class="text-gray-500 mt-1">대회 기본 정보를 입력하고 위자드를 통해 사이트를 완성하세요.</p>
    </div>
  </div>

  <%# Form %>
  <div class="bg-white rounded-2xl shadow-sm overflow-hidden">
    <%= form_with model: [:tournament_admin, @tournament], local: true, class: "divide-y" do |f| %>
      <%# Basic Info Section %>
      <div class="p-6 space-y-6">
        <h2 class="text-lg font-semibold text-gray-900">기본 정보</h2>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <%# Tournament Name %>
          <div class="md:col-span-2">
            <%= f.label :name, "대회 이름", class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= f.text_field :name,
                placeholder: "예: 2024 서울 3on3 농구대회",
                class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500" %>
            <% if @tournament.errors[:name].any? %>
              <p class="mt-1 text-sm text-red-600"><%= @tournament.errors[:name].first %></p>
            <% end %>
          </div>

          <%# Description %>
          <div class="md:col-span-2">
            <%= f.label :description, "대회 설명", class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= f.text_area :description,
                rows: 3,
                placeholder: "대회에 대한 간단한 소개를 작성해주세요.",
                class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500" %>
          </div>

          <%# Format %>
          <div>
            <%= f.label :format, "대회 형식", class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= f.select :format,
                [["싱글 엘리미네이션", "single_elimination"],
                 ["더블 엘리미네이션", "double_elimination"],
                 ["풀 리그", "round_robin"],
                 ["그룹 스테이지", "group_stage"]],
                {},
                class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500" %>
          </div>

          <%# Team Size %>
          <div>
            <%= f.label :team_size, "팀 인원", class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= f.select :team_size,
                [[" 3 vs 3", 3], ["5 vs 5", 5]],
                {},
                class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500" %>
          </div>
        </div>
      </div>

      <%# Date Section %>
      <div class="p-6 space-y-6">
        <h2 class="text-lg font-semibold text-gray-900">일정</h2>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <%# Start Date %>
          <div>
            <%= f.label :start_date, "대회 시작일", class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= f.date_field :start_date,
                class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500" %>
          </div>

          <%# End Date %>
          <div>
            <%= f.label :end_date, "대회 종료일", class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= f.date_field :end_date,
                class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500" %>
          </div>

          <%# Registration Start %>
          <div>
            <%= f.label :registration_start_at, "접수 시작", class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= f.datetime_local_field :registration_start_at,
                class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500" %>
          </div>

          <%# Registration End %>
          <div>
            <%= f.label :registration_end_at, "접수 마감", class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= f.datetime_local_field :registration_end_at,
                class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500" %>
          </div>
        </div>
      </div>

      <%# Team Settings Section %>
      <div class="p-6 space-y-6">
        <h2 class="text-lg font-semibold text-gray-900">참가 설정</h2>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <%# Max Teams %>
          <div>
            <%= f.label :max_teams, "최대 참가팀", class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= f.number_field :max_teams,
                min: 2,
                placeholder: "16",
                class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500" %>
          </div>

          <%# Min Teams %>
          <div>
            <%= f.label :min_teams, "최소 참가팀", class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= f.number_field :min_teams,
                min: 2,
                placeholder: "4",
                class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500" %>
          </div>

          <%# Entry Fee %>
          <div>
            <%= f.label :entry_fee, "참가비 (원)", class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= f.number_field :entry_fee,
                id: "entry_fee_field",
                min: 0,
                step: 1000,
                placeholder: "0",
                class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500",
                onchange: "toggleBankSection(this.value)" %>
          </div>
        </div>

        <%# Division Selection - 2 Step %>
        <div class="mt-4 pt-4 border-t" id="division_section">
          <label class="block text-sm font-medium text-gray-700 mb-3">참가 부별 설정</label>

          <%# Step 1: 부별 선택 %>
          <div class="mb-4">
            <p class="text-sm text-gray-600 mb-2"><strong>1단계:</strong> 부별 선택 <span class="text-gray-400">(복수 선택 가능)</span></p>
            <div class="grid grid-cols-2 md:grid-cols-3 gap-3">
              <% Tournament::DIVISION_CATEGORIES.each do |name, info| %>
                <label class="division-category flex items-center gap-3 p-3 border rounded-lg hover:bg-gray-50 cursor-pointer transition-colors"
                       data-category="<%= info[:code] %>">
                  <input type="checkbox" name="tournament[divisions][]" value="<%= name %>"
                         class="category-checkbox rounded border-gray-300 text-primary-600 focus:ring-primary-500"
                         onchange="toggleTierSelection(this)"
                         <%= 'checked' if @tournament.divisions&.include?(name) %>>
                  <div>
                    <span class="font-medium text-gray-900"><%= name %></span>
                    <p class="text-xs text-gray-500"><%= info[:description] %></p>
                  </div>
                </label>
              <% end %>
            </div>
          </div>

          <%# Step 2: 조별/리그 선택 %>
          <div id="tier_selection" class="hidden mt-4 p-4 bg-gray-50 rounded-lg">
            <p class="text-sm text-gray-600 mb-2"><strong>2단계:</strong> 조별/리그 선택 <span class="text-gray-400">(선택한 부별에 적용)</span></p>
            <div class="grid grid-cols-2 md:grid-cols-4 gap-2">
              <% Tournament::DIVISION_TIERS.each do |name, info| %>
                <label class="flex items-center gap-2 p-2 border bg-white rounded-lg hover:bg-gray-50 cursor-pointer transition-colors">
                  <input type="checkbox" name="tournament[division_tiers][]" value="<%= name %>"
                         class="tier-checkbox rounded border-gray-300 text-primary-600 focus:ring-primary-500">
                  <div>
                    <span class="text-sm font-medium text-gray-900"><%= name %></span>
                    <span class="text-xs text-gray-500 ml-1">(<%= info[:description] %>)</span>
                  </div>
                </label>
              <% end %>
            </div>
            <p class="mt-2 text-xs text-gray-500">예: 일반부 1부, 일반부 2부, 대학부 A조 등으로 구성됩니다.</p>
          </div>

          <p class="mt-3 text-sm text-gray-500">선택하지 않으면 전체 부로 진행됩니다.</p>
        </div>

        <script>
          function toggleTierSelection(checkbox) {
            const checkedCategories = document.querySelectorAll('.category-checkbox:checked');
            const tierSection = document.getElementById('tier_selection');

            if (checkedCategories.length > 0) {
              tierSection.classList.remove('hidden');
            } else {
              tierSection.classList.add('hidden');
            }
          }

          // Initialize on page load
          document.addEventListener('DOMContentLoaded', function() {
            const checkedCategories = document.querySelectorAll('.category-checkbox:checked');
            if (checkedCategories.length > 0) {
              document.getElementById('tier_selection').classList.remove('hidden');
            }
          });
        </script>

        <%# Bank Account Info %>
        <div id="bank_info_section" class="mt-4 pt-4 border-t hidden">
          <h4 class="text-sm font-medium text-gray-700 mb-3">💳 참가비 입금 계좌 정보</h4>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
            <div>
              <%= f.label :bank_name, "은행명", class: "block text-sm font-medium text-gray-700 mb-1" %>
              <%= f.select :bank_name,
                          [["선택하세요", ""], ["카카오뱅크", "카카오뱅크"], ["국민은행", "국민은행"], ["신한은행", "신한은행"],
                           ["우리은행", "우리은행"], ["하나은행", "하나은행"], ["농협", "농협"], ["기업은행", "기업은행"],
                           ["SC제일은행", "SC제일은행"], ["토스뱅크", "토스뱅크"], ["케이뱅크", "케이뱅크"]],
                          {}, class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500" %>
            </div>
            <div>
              <%= f.label :bank_account, "계좌번호", class: "block text-sm font-medium text-gray-700 mb-1" %>
              <%= f.text_field :bank_account, placeholder: "- 없이 입력",
                               class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500" %>
            </div>
            <div>
              <%= f.label :bank_holder, "예금주", class: "block text-sm font-medium text-gray-700 mb-1" %>
              <%= f.text_field :bank_holder, placeholder: "예금주명",
                               class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500" %>
            </div>
          </div>
          <p class="mt-2 text-sm text-gray-500">참가비가 있는 경우 입금 계좌를 입력해주세요.</p>
        </div>

        <script>
          function toggleBankSection(value) {
            const section = document.getElementById('bank_info_section');
            if (parseInt(value) > 0) {
              section.classList.remove('hidden');
            } else {
              section.classList.add('hidden');
            }
          }
        </script>
      </div>

      <%# Location Section %>
      <div class="p-6 space-y-6">
        <h2 class="text-lg font-semibold text-gray-900">장소</h2>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <%# City %>
          <div>
            <%= f.label :city, "시/도", class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= f.text_field :city,
                placeholder: "서울",
                class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500" %>
          </div>

          <%# District %>
          <div>
            <%= f.label :district, "구/군", class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= f.text_field :district,
                placeholder: "강남구",
                class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500" %>
          </div>

          <%# Venue %>
          <div>
            <%= f.label :venue_name, "경기장", class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= f.text_field :venue_name,
                placeholder: "삼성동 체육관",
                class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500" %>
          </div>
        </div>
      </div>

      <%# Submit Section %>
      <div class="p-6 bg-gray-50 flex items-center justify-between">
        <%= link_to "취소", tournament_admin_tournaments_path, class: "px-4 py-2 text-gray-700 hover:text-gray-900 font-medium" %>
        <%= f.submit "대회 생성 & 위자드 시작", class: "px-6 py-2 bg-primary-600 text-white rounded-lg font-medium hover:bg-primary-700 transition-colors cursor-pointer" %>
      </div>
    <% end %>
  </div>

  <%# Template Preview Section %>
  <% if @templates.present? && @templates.any? %>
    <div class="bg-white rounded-2xl shadow-sm overflow-hidden">
      <div class="p-6 border-b">
        <h2 class="text-lg font-semibold text-gray-900">인기 템플릿 미리보기</h2>
        <p class="text-gray-500 text-sm mt-1">위자드에서 원하는 템플릿을 선택할 수 있습니다.</p>
      </div>
      <div class="p-6">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          <% @templates.limit(4).each do |template| %>
            <div class="border rounded-lg overflow-hidden hover:border-primary-500 transition-colors">
              <% if template.preview_url.present? %>
                <img src="<%= template.preview_url %>" alt="<%= template.name %>" class="w-full h-24 object-cover">
              <% else %>
                <div class="w-full h-24 bg-gradient-to-br from-primary-500 to-secondary-500"></div>
              <% end %>
              <div class="p-2">
                <p class="text-sm font-medium text-gray-900 truncate"><%= template.name %></p>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>
</div>
