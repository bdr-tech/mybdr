<% content_for :title do %>새 대회 만들기 - 대회관리자 콘솔<% end %>

<div class="space-y-6">
  <%# Header %>
  <div class="flex items-center gap-4">
    <%= link_to tournament_admin_tournaments_path, class: "p-2 text-gray-400 hover:text-gray-600 transition-colors" do %>
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
    <% end %>
    <div>
      <h1 class="text-2xl font-bold text-gray-900">새 대회 만들기</h1>
      <p class="text-gray-500 mt-1">대회 기본 정보를 입력하고 위자드를 통해 사이트를 완성하세요.</p>
    </div>
  </div>

  <%# Form %>
  <div class="bg-white rounded-2xl shadow-sm overflow-hidden">
    <%= form_with model: [:tournament_admin, @tournament], local: true, class: "divide-y" do |f| %>
      <%# Basic Info Section %>
      <div class="p-6 space-y-6">
        <h2 class="text-lg font-semibold text-gray-900">기본 정보</h2>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <%# Tournament Name %>
          <div class="md:col-span-2">
            <%= f.label :name, "대회 이름", class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= f.text_field :name,
                placeholder: "예: 2024 서울 3on3 농구대회",
                class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500" %>
            <% if @tournament.errors[:name].any? %>
              <p class="mt-1 text-sm text-red-600"><%= @tournament.errors[:name].first %></p>
            <% end %>
          </div>

          <%# Description %>
          <div class="md:col-span-2">
            <%= f.label :description, "대회 설명", class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= f.text_area :description,
                rows: 3,
                placeholder: "대회에 대한 간단한 소개를 작성해주세요.",
                class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500" %>
          </div>

          <%# Format %>
          <div>
            <%= f.label :format, "대회 형식", class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= f.select :format,
                [["싱글 엘리미네이션", "single_elimination"],
                 ["더블 엘리미네이션", "double_elimination"],
                 ["풀 리그", "round_robin"],
                 ["그룹 스테이지", "group_stage"]],
                {},
                class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500" %>
          </div>

          <%# Team Size %>
          <div>
            <%= f.label :team_size, "팀 인원", class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= f.select :team_size,
                [[" 3 vs 3", 3], ["5 vs 5", 5]],
                {},
                class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500" %>
          </div>
        </div>
      </div>

      <%# Date Section %>
      <div class="p-6 space-y-6">
        <h2 class="text-lg font-semibold text-gray-900">일정</h2>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <%# Start Date %>
          <div>
            <%= f.label :start_date, "대회 시작일", class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= f.date_field :start_date,
                class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500" %>
          </div>

          <%# End Date %>
          <div>
            <%= f.label :end_date, "대회 종료일", class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= f.date_field :end_date,
                class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500" %>
          </div>

          <%# Registration Start %>
          <div>
            <%= f.label :registration_start_at, "접수 시작", class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= f.datetime_local_field :registration_start_at,
                class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500" %>
          </div>

          <%# Registration End %>
          <div>
            <%= f.label :registration_end_at, "접수 마감", class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= f.datetime_local_field :registration_end_at,
                class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500" %>
          </div>
        </div>
      </div>

      <%# Team Settings Section %>
      <div class="p-6 space-y-6">
        <h2 class="text-lg font-semibold text-gray-900">참가 설정</h2>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <%# Max Teams %>
          <div>
            <%= f.label :max_teams, "최대 참가팀", class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= f.number_field :max_teams,
                min: 2,
                placeholder: "16",
                class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500" %>
          </div>

          <%# Min Teams %>
          <div>
            <%= f.label :min_teams, "최소 참가팀", class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= f.number_field :min_teams,
                min: 2,
                placeholder: "4",
                class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500" %>
          </div>

          <%# Entry Fee %>
          <div>
            <%= f.label :entry_fee, "참가비 (원)", class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= f.number_field :entry_fee,
                id: "entry_fee_field",
                min: 0,
                step: 1000,
                placeholder: "0",
                class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500",
                onchange: "toggleBankSection(this.value)" %>
          </div>
        </div>

        <%# Division Selection - 2 Step %>
        <div class="mt-4 pt-4 border-t" id="division_section">
          <label class="block text-sm font-medium text-gray-700 mb-3">참가 부별 설정</label>

          <%# Step 1: 부별 선택 %>
          <div class="mb-4">
            <p class="text-sm text-gray-600 mb-2"><strong>1단계:</strong> 부별 선택 <span class="text-gray-400">(복수 선택 가능)</span></p>
            <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
              <% Tournament::DIVISION_CATEGORIES.each do |name, info| %>
                <label class="division-category flex items-center gap-3 p-3 border rounded-lg hover:bg-gray-50 cursor-pointer transition-colors"
                       data-category="<%= name %>">
                  <input type="checkbox" name="tournament[divisions][]" value="<%= name %>"
                         class="category-checkbox rounded border-gray-300 text-primary-600 focus:ring-primary-500"
                         onchange="updateTierSelection()"
                         <%= 'checked' if @tournament.divisions&.include?(name) %>>
                  <div>
                    <span class="font-medium text-gray-900"><%= name %></span>
                    <p class="text-xs text-gray-500"><%= info[:description] %></p>
                  </div>
                </label>
              <% end %>
            </div>
          </div>

          <%# Step 2: 하위 종목 선택 (부별에 따라 동적으로 표시) %>
          <div id="tier_selection" class="hidden mt-4 space-y-4">
            <p class="text-sm text-gray-600"><strong>2단계:</strong> 하위 종목 선택</p>

            <% Tournament::DIVISION_TIERS_BY_CATEGORY.each do |category, tiers| %>
              <div id="tiers_<%= category.gsub(/[^가-힣a-zA-Z0-9]/, '') %>"
                   class="tier-group hidden p-4 bg-gray-50 rounded-lg"
                   data-category="<%= category %>">
                <p class="text-sm font-medium text-gray-700 mb-2"><%= category %> 종목</p>
                <div class="flex flex-wrap gap-2">
                  <% tiers.each do |tier_name, tier_info| %>
                    <label class="flex items-center gap-2 px-3 py-2 border bg-white rounded-lg hover:bg-gray-50 cursor-pointer transition-colors">
                      <input type="checkbox" name="tournament[division_tiers][]" value="<%= tier_name %>"
                             class="tier-checkbox rounded border-gray-300 text-primary-600 focus:ring-primary-500"
                             <%= 'checked' if @tournament.division_tiers&.include?(tier_name) %>>
                      <span class="text-sm font-medium text-gray-900"><%= tier_name %></span>
                    </label>
                  <% end %>
                </div>
              </div>
            <% end %>
          </div>

          <p class="mt-3 text-sm text-gray-500">선택하지 않으면 전체 부로 진행됩니다.</p>
        </div>

        <script>
          function updateTierSelection() {
            const checkedCategories = document.querySelectorAll('.category-checkbox:checked');
            const tierSection = document.getElementById('tier_selection');
            const allTierGroups = document.querySelectorAll('.tier-group');

            // Hide all tier groups first
            allTierGroups.forEach(group => group.classList.add('hidden'));

            if (checkedCategories.length > 0) {
              tierSection.classList.remove('hidden');

              // Show tier groups for selected categories
              checkedCategories.forEach(checkbox => {
                const categoryName = checkbox.value;
                const tierGroup = document.querySelector(`.tier-group[data-category="${categoryName}"]`);
                if (tierGroup) {
                  tierGroup.classList.remove('hidden');
                }
              });
            } else {
              tierSection.classList.add('hidden');
            }
          }

          // Initialize on page load
          document.addEventListener('DOMContentLoaded', function() {
            updateTierSelection();
          });
        </script>

        <%# Bank Account Info %>
        <div id="bank_info_section" class="mt-4 pt-4 border-t hidden">
          <h4 class="text-sm font-medium text-gray-700 mb-3">💳 참가비 입금 계좌 정보</h4>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
            <div>
              <%= f.label :bank_name, "은행명", class: "block text-sm font-medium text-gray-700 mb-1" %>
              <%= f.select :bank_name,
                          [["선택하세요", ""], ["카카오뱅크", "카카오뱅크"], ["국민은행", "국민은행"], ["신한은행", "신한은행"],
                           ["우리은행", "우리은행"], ["하나은행", "하나은행"], ["농협", "농협"], ["기업은행", "기업은행"],
                           ["SC제일은행", "SC제일은행"], ["토스뱅크", "토스뱅크"], ["케이뱅크", "케이뱅크"]],
                          {}, class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500" %>
            </div>
            <div>
              <%= f.label :bank_account, "계좌번호", class: "block text-sm font-medium text-gray-700 mb-1" %>
              <%= f.text_field :bank_account, placeholder: "- 없이 입력",
                               class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500" %>
            </div>
            <div>
              <%= f.label :bank_holder, "예금주", class: "block text-sm font-medium text-gray-700 mb-1" %>
              <%= f.text_field :bank_holder, placeholder: "예금주명",
                               class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500" %>
            </div>
          </div>
          <p class="mt-2 text-sm text-gray-500">참가비가 있는 경우 입금 계좌를 입력해주세요.</p>
        </div>

        <script>
          function toggleBankSection(value) {
            const section = document.getElementById('bank_info_section');
            if (parseInt(value) > 0) {
              section.classList.remove('hidden');
            } else {
              section.classList.add('hidden');
            }
          }
        </script>
      </div>

      <%# Location Section %>
      <div class="p-6 space-y-6">
        <h2 class="text-lg font-semibold text-gray-900">장소</h2>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <%# City %>
          <div>
            <%= f.label :city, "시/도", class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= f.text_field :city,
                placeholder: "서울",
                class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500" %>
          </div>

          <%# District %>
          <div>
            <%= f.label :district, "구/군", class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= f.text_field :district,
                placeholder: "강남구",
                class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500" %>
          </div>

          <%# Venue %>
          <div>
            <%= f.label :venue_name, "경기장", class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= f.text_field :venue_name,
                placeholder: "삼성동 체육관",
                class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500" %>
          </div>
        </div>
      </div>

      <%# Submit Section %>
      <div class="p-6 bg-gray-50 flex items-center justify-between">
        <%= link_to "취소", tournament_admin_tournaments_path, class: "px-4 py-2 text-gray-700 hover:text-gray-900 font-medium" %>
        <%= f.submit "대회 생성 & 위자드 시작", id: "submit_tournament", class: "px-6 py-2 bg-primary-600 text-white rounded-lg font-medium hover:bg-primary-700 transition-colors cursor-pointer" %>
      </div>

      <%# Validation Errors Display %>
      <div id="validation_errors" class="hidden p-4 mx-6 mb-6 bg-red-50 border border-red-200 rounded-lg">
        <h4 class="font-medium text-red-800 mb-2">⚠️ 필수 항목을 확인해주세요</h4>
        <ul id="error_list" class="list-disc list-inside text-sm text-red-700 space-y-1"></ul>
      </div>
    <% end %>
  </div>

  <%# Template Preview Section %>
  <% if @templates.present? && @templates.any? %>
    <div class="bg-white rounded-2xl shadow-sm overflow-hidden">
      <div class="p-6 border-b">
        <h2 class="text-lg font-semibold text-gray-900">인기 템플릿 미리보기</h2>
        <p class="text-gray-500 text-sm mt-1">위자드에서 원하는 템플릿을 선택할 수 있습니다.</p>
      </div>
      <div class="p-6">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          <% @templates.limit(4).each do |template| %>
            <div class="border rounded-lg overflow-hidden hover:border-primary-500 transition-colors">
              <% if template.preview_url.present? %>
                <img src="<%= template.preview_url %>" alt="<%= template.name %>" class="w-full h-24 object-cover">
              <% else %>
                <div class="w-full h-24 bg-gradient-to-br from-primary-500 to-secondary-500"></div>
              <% end %>
              <div class="p-2">
                <p class="text-sm font-medium text-gray-900 truncate"><%= template.name %></p>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const form = document.querySelector('form');
    const submitBtn = document.getElementById('submit_tournament');
    const validationErrors = document.getElementById('validation_errors');
    const errorList = document.getElementById('error_list');

    form.addEventListener('submit', function(e) {
      const errors = [];

      // 대회 이름 검증
      const name = document.getElementById('tournament_name');
      if (!name || !name.value.trim()) {
        errors.push('대회 이름을 입력해주세요.');
        name?.classList.add('border-red-500');
      } else {
        name?.classList.remove('border-red-500');
      }

      // 일정 검증 (시작일)
      const startDate = document.getElementById('tournament_start_date');
      if (!startDate || !startDate.value) {
        errors.push('대회 시작일을 선택해주세요.');
        startDate?.classList.add('border-red-500');
      } else {
        startDate?.classList.remove('border-red-500');
      }

      // 참가 부별 설정 검증
      const divisions = document.querySelectorAll('.category-checkbox:checked');
      if (divisions.length === 0) {
        errors.push('참가 부별을 최소 하나 이상 선택해주세요.');
      }

      // 장소 검증
      const city = document.getElementById('tournament_city');
      const district = document.getElementById('tournament_district');
      const venue = document.getElementById('tournament_venue_name');

      if ((!city || !city.value.trim()) && (!district || !district.value.trim()) && (!venue || !venue.value.trim())) {
        errors.push('장소 정보를 입력해주세요. (시/도, 구/군, 경기장 중 최소 하나)');
        city?.classList.add('border-red-500');
        district?.classList.add('border-red-500');
        venue?.classList.add('border-red-500');
      } else {
        city?.classList.remove('border-red-500');
        district?.classList.remove('border-red-500');
        venue?.classList.remove('border-red-500');
      }

      // 참가비 입력시 계좌 정보 검증
      const entryFee = document.getElementById('entry_fee_field');
      if (entryFee && parseInt(entryFee.value) > 0) {
        const bankName = document.getElementById('tournament_bank_name');
        const bankAccount = document.getElementById('tournament_bank_account');
        if (!bankName || !bankName.value || bankName.value === '') {
          errors.push('참가비가 있는 경우 은행명을 선택해주세요.');
        }
        if (!bankAccount || !bankAccount.value.trim()) {
          errors.push('참가비가 있는 경우 계좌번호를 입력해주세요.');
        }
      }

      if (errors.length > 0) {
        e.preventDefault();
        errorList.innerHTML = errors.map(err => `<li>${err}</li>`).join('');
        validationErrors.classList.remove('hidden');
        validationErrors.scrollIntoView({ behavior: 'smooth', block: 'center' });
      } else {
        validationErrors.classList.add('hidden');
      }
    });

    // 입력 필드 변경시 에러 표시 제거
    form.querySelectorAll('input, select, textarea').forEach(field => {
      field.addEventListener('input', function() {
        this.classList.remove('border-red-500');
      });
    });
  });
</script>
