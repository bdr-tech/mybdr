<% content_for :title, @tournament.name %>
<% primary_color = @tournament.theme_primary_color %>
<% secondary_color = @tournament.theme_secondary_color %>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <!-- 대회 헤더 -->
  <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden mb-6">
    <% has_banner = @tournament.banner.attached? || @tournament.banner_url.present? %>
    <% if has_banner %>
      <div class="h-48 md:h-64 bg-gray-100 relative">
        <% if @tournament.banner.attached? %>
          <%= image_tag @tournament.banner, alt: "", class: "w-full h-full object-cover" %>
        <% else %>
          <img src="<%= @tournament.banner_url %>" alt="" class="w-full h-full object-cover">
        <% end %>
        <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent"></div>
      </div>
    <% else %>
      <div class="h-32" style="background: linear-gradient(to right, <%= primary_color %>, <%= secondary_color %>);"></div>
    <% end %>

    <div class="p-6 <%= has_banner ? '-mt-16 relative' : '' %>">
      <div class="flex flex-col md:flex-row md:items-end justify-between gap-4">
        <div>
          <div class="flex items-center gap-2 mb-2">
            <%
              status_class = case
                when @tournament.status_registration_open? then "bg-blue-100 text-blue-700"
                when @tournament.status_in_progress? then "bg-yellow-100 text-yellow-700"
                when @tournament.status_completed? then "bg-green-100 text-green-700"
                else "bg-gray-100 text-gray-600"
              end
            %>
            <span class="px-3 py-1 text-sm font-medium rounded-full <%= status_class %>">
              <%= @tournament.status_name %>
            </span>
            <% if @tournament.series.present? %>
              <%= link_to tournament_series_path(@tournament.series), class: "hover:underline text-sm", style: "color: #{primary_color};" do %>
                <%= @tournament.series.name %> <%= @tournament.edition_number %>회
              <% end %>
            <% end %>
          </div>
          <h1 class="text-2xl md:text-3xl font-bold <%= has_banner ? 'text-white' : 'text-gray-900' %> mb-2"><%= @tournament.name %></h1>
          <p class="<%= has_banner ? 'text-white/80' : 'text-gray-500' %>">
            주최: <%= @tournament.organizer.display_name %> |
            조회 <%= @tournament.views_count %>회
          </p>
        </div>

        <% if logged_in? && @tournament.organizer_id == current_user.id %>
          <div class="flex flex-wrap gap-2">
            <%= link_to edit_tournament_path(@tournament), class: "btn btn-secondary" do %>
              수정
            <% end %>
            <% if @tournament.status_draft? %>
              <%= button_to open_registration_tournament_path(@tournament), method: :post, class: "btn btn-primary" do %>
                등록 시작
              <% end %>
            <% elsif @tournament.status_registration_open? %>
              <%= button_to close_registration_tournament_path(@tournament), method: :post, class: "btn btn-secondary" do %>
                등록 마감
              <% end %>
            <% elsif @tournament.status_registration_closed? %>
              <%= button_to start_tournament_path(@tournament), method: :post, class: "btn btn-primary" do %>
                대회 시작
              <% end %>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <!-- 왼쪽: 대회 정보 -->
    <div class="lg:col-span-2 space-y-6">
      <!-- 기본 정보 -->
      <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
        <h2 class="text-lg font-bold text-gray-900 mb-4">대회 정보</h2>

        <div class="grid grid-cols-2 gap-4">
          <div>
            <span class="text-gray-500 text-sm">대회 일정</span>
            <p class="text-gray-900 font-medium"><%= @tournament.date_range %></p>
          </div>
          <div>
            <span class="text-gray-500 text-sm">장소</span>
            <p class="text-gray-900 font-medium"><%= @tournament.location_display %></p>
          </div>
          <div>
            <span class="text-gray-500 text-sm">대회 형식</span>
            <div class="flex items-center gap-1">
              <p class="text-gray-900 font-medium"><%= @tournament.format_name %></p>
              <button type="button"
                      onclick="document.getElementById('format-info-modal').classList.remove('hidden')"
                      class="w-5 h-5 rounded-full bg-gray-200 hover:bg-gray-300 text-gray-600 flex items-center justify-center text-xs font-bold transition-colors"
                      title="대회 형식 설명">
                !
              </button>
            </div>
          </div>
          <div>
            <span class="text-gray-500 text-sm">팀당 인원</span>
            <p class="text-gray-900 font-medium"><%= @tournament.team_size %>명</p>
          </div>
          <div>
            <span class="text-gray-500 text-sm">참가비</span>
            <% if @tournament.has_fee? %>
              <p class="font-bold" style="color: <%= primary_color %>;">
                <%= number_with_delimiter(@tournament.entry_fee) %>원
              </p>
            <% else %>
              <p class="text-green-600 font-medium">무료</p>
            <% end %>
          </div>
          <div>
            <span class="text-gray-500 text-sm">참가팀</span>
            <p class="text-gray-900 font-medium"><%= @tournament.teams_count %>/<%= @tournament.max_teams %>팀</p>
          </div>
        </div>

        <% if @tournament.description.present? %>
          <div class="mt-6 pt-6 border-t border-gray-100">
            <h3 class="text-gray-900 font-semibold mb-2">대회 설명</h3>
            <p class="text-gray-600 whitespace-pre-line"><%= @tournament.description %></p>
          </div>
        <% end %>

        <% if @tournament.rules.present? %>
          <div class="mt-6 pt-6 border-t border-gray-100">
            <h3 class="text-gray-900 font-semibold mb-2">대회 규칙</h3>
            <p class="text-gray-600 whitespace-pre-line"><%= @tournament.rules %></p>
          </div>
        <% end %>

        <% if @tournament.prize_info.present? %>
          <div class="mt-6 pt-6 border-t border-gray-100">
            <h3 class="text-gray-900 font-semibold mb-2">상금/상품</h3>
            <p class="text-gray-600 whitespace-pre-line"><%= @tournament.prize_info %></p>
          </div>
        <% end %>
      </div>

      <!-- 참가팀 목록 -->
      <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-lg font-bold text-gray-900">참가팀</h2>
          <%= link_to standings_tournament_path(@tournament), class: "hover:underline text-sm", style: "color: #{primary_color};" do %>
            순위표 보기 &rarr;
          <% end %>
        </div>

        <% if @teams.any? %>
          <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
            <% @teams.each do |tournament_team| %>
              <% team = tournament_team.team %>
              <% next unless team %>
              <div class="bg-gray-50 rounded-lg p-3 flex items-center gap-3 hover:bg-gray-100 transition-colors">
                <% if tournament_team.seed_number.present? %>
                  <span class="font-bold" style="color: <%= primary_color %>;">#<%= tournament_team.seed_number %></span>
                <% end %>
                <div class="w-10 h-10 rounded-full bg-gray-200 flex items-center justify-center flex-shrink-0">
                  <% if team.logo.attached? %>
                    <%= image_tag team.logo, alt: "", class: "w-full h-full rounded-full object-cover" %>
                  <% elsif team.logo_url.present? %>
                    <img src="<%= team.logo_url %>" alt="" class="w-full h-full rounded-full object-cover">
                  <% else %>
                    <span class="text-sm text-gray-600 font-medium"><%= team.name.first(2) %></span>
                  <% end %>
                </div>
                <div class="min-w-0">
                  <p class="text-gray-900 font-medium truncate"><%= team.name %></p>
                  <p class="text-xs text-gray-500"><%= tournament_team.record_display %></p>
                </div>
              </div>
            <% end %>
          </div>
        <% else %>
          <p class="text-gray-500 text-center py-8">아직 참가팀이 없습니다</p>
        <% end %>
      </div>

      <!-- 최근 경기 결과 -->
      <% if @recent_matches.any? %>
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
          <div class="flex items-center justify-between mb-4">
            <h2 class="text-lg font-bold text-gray-900">최근 경기 결과</h2>
            <%= link_to schedule_tournament_path(@tournament), class: "hover:underline text-sm", style: "color: #{primary_color};" do %>
              전체 일정 &rarr;
            <% end %>
          </div>

          <div class="space-y-3">
            <% @recent_matches.each do |match| %>
              <%= link_to box_score_tournament_tournament_match_path(@tournament, match), class: "block bg-gray-50 rounded-lg p-4 hover:bg-gray-100 transition-colors" do %>
                <div class="flex items-center justify-between">
                  <div class="flex-1">
                    <div class="flex items-center gap-2">
                      <span class="text-gray-900 font-medium"><%= match.home_team&.team&.name || 'TBD' %></span>
                      <% if match.winner_team == match.home_team %>
                        <span class="text-xs font-medium" style="color: <%= primary_color %>;">WIN</span>
                      <% end %>
                    </div>
                  </div>
                  <div class="text-center px-4">
                    <div class="text-xl font-bold text-gray-900"><%= match.home_score %> - <%= match.away_score %></div>
                    <div class="text-xs text-gray-500"><%= match.round_display %></div>
                  </div>
                  <div class="flex-1 text-right">
                    <div class="flex items-center justify-end gap-2">
                      <% if match.winner_team == match.away_team %>
                        <span class="text-xs font-medium" style="color: <%= primary_color %>;">WIN</span>
                      <% end %>
                      <span class="text-gray-900 font-medium"><%= match.away_team&.team&.name || 'TBD' %></span>
                    </div>
                  </div>
                </div>
              <% end %>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>

    <!-- 오른쪽: 사이드바 -->
    <div class="space-y-6">
      <!-- 퀵 액션 -->
      <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
        <div class="space-y-3">
          <%= link_to bracket_tournament_path(@tournament), class: "btn btn-secondary w-full justify-center" do %>
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h8m-8 6h16"></path>
            </svg>
            대진표
          <% end %>
          <%= link_to standings_tournament_path(@tournament), class: "btn btn-secondary w-full justify-center" do %>
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
            </svg>
            순위표
          <% end %>
          <%= link_to schedule_tournament_path(@tournament), class: "btn btn-secondary w-full justify-center" do %>
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
            </svg>
            일정
          <% end %>

          <div class="pt-3 border-t border-gray-100">
            <button type="button"
                    data-controller="clipboard"
                    data-clipboard-text-value="<%= request.base_url %><%= tournament_path(@tournament) %>"
                    data-action="click->clipboard#copy"
                    class="btn btn-ghost w-full justify-center text-gray-600 hover:bg-gray-50"
                    onmouseover="this.style.color='<%= primary_color %>'"
                    onmouseout="this.style.color=''">
              <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3"></path>
              </svg>
              대회 링크 복사
            </button>
          </div>
        </div>
      </div>

      <!-- 우승팀 (완료된 대회) -->
      <% if @tournament.status_completed? && @tournament.champion_team.present? %>
        <div class="bg-gradient-to-br from-amber-50 to-orange-50 rounded-xl p-6 border border-amber-200">
          <div class="text-center">
            <div class="text-amber-600 text-sm font-medium mb-2">CHAMPION</div>
            <div class="w-20 h-20 rounded-full bg-white shadow-md mx-auto mb-3 flex items-center justify-center">
              <% if @tournament.champion_team.logo.attached? %>
                <%= image_tag @tournament.champion_team.logo, alt: "", class: "w-16 h-16 rounded-full object-cover" %>
              <% elsif @tournament.champion_team.logo_url.present? %>
                <img src="<%= @tournament.champion_team.logo_url %>" alt="" class="w-16 h-16 rounded-full object-cover">
              <% else %>
                <span class="text-2xl font-bold text-gray-700"><%= @tournament.champion_team.name.first(2) %></span>
              <% end %>
            </div>
            <h3 class="text-xl font-bold text-gray-900"><%= @tournament.champion_team.name %></h3>
            <% if @tournament.mvp_player.present? %>
              <div class="mt-3 text-sm">
                <span class="text-gray-500">MVP:</span>
                <span class="font-medium" style="color: <%= primary_color %>;"><%= @tournament.mvp_player.display_name %></span>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>

      <!-- 다가오는 경기 -->
      <% if @upcoming_matches.any? %>
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
          <h3 class="text-lg font-bold text-gray-900 mb-4">다가오는 경기</h3>

          <div class="space-y-3">
            <% @upcoming_matches.each do |match| %>
              <div class="bg-gray-50 rounded-lg p-3">
                <div class="text-xs text-gray-500 mb-1"><%= match.time_display %></div>
                <div class="text-gray-900 text-sm font-medium"><%= match.matchup_display %></div>
                <div class="text-xs text-gray-500"><%= match.round_display %></div>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>

      <!-- 시리즈 대회 히스토리 -->
      <% if @tournament.series.present? %>
        <% series_tournaments = @tournament.series.tournaments.where.not(id: @tournament.id).order(edition_number: :desc) %>
        <% if series_tournaments.any? %>
          <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
            <div class="flex items-center justify-between mb-4">
              <h3 class="text-lg font-bold text-gray-900"><%= @tournament.series.name %></h3>
              <%= link_to tournament_series_path(@tournament.series), class: "hover:underline text-sm", style: "color: #{primary_color};" do %>
                전체 보기 &rarr;
              <% end %>
            </div>

            <div class="space-y-2">
              <% series_tournaments.each do |t| %>
                <%= link_to tournament_path(t), class: "block bg-gray-50 rounded-lg p-3 hover:bg-gray-100 transition-colors" do %>
                  <div class="flex items-center justify-between">
                    <div class="flex items-center gap-2">
                      <span class="w-7 h-7 rounded-full flex items-center justify-center text-sm font-bold" style="background-color: <%= primary_color %>15; color: <%= primary_color %>;">
                        <%= t.edition_number %>
                      </span>
                      <div>
                        <div class="text-gray-900 font-medium text-sm"><%= t.name %></div>
                        <div class="text-xs text-gray-500"><%= t.start_date&.strftime('%Y.%m') %></div>
                      </div>
                    </div>
                    <div class="text-right">
                      <% if t.status_completed? %>
                        <span class="px-2 py-0.5 text-xs bg-green-100 text-green-700 rounded-full">완료</span>
                        <% if t.champion_team.present? %>
                          <div class="text-xs text-gray-500 mt-1">우승: <%= t.champion_team.name %></div>
                        <% end %>
                      <% elsif t.status_in_progress? %>
                        <span class="px-2 py-0.5 text-xs bg-yellow-100 text-yellow-700 rounded-full">진행중</span>
                      <% elsif t.status_registration_open? %>
                        <span class="px-2 py-0.5 text-xs bg-blue-100 text-blue-700 rounded-full">모집중</span>
                      <% else %>
                        <span class="px-2 py-0.5 text-xs bg-gray-100 text-gray-600 rounded-full"><%= t.status_name %></span>
                      <% end %>
                    </div>
                  </div>
                <% end %>
              <% end %>
            </div>

            <!-- 현재 대회 표시 -->
            <div class="mt-3 pt-3 border-t border-gray-100">
              <div class="flex items-center gap-2 text-sm text-gray-500">
                <span class="w-7 h-7 rounded-full text-white flex items-center justify-center text-sm font-bold" style="background-color: <%= primary_color %>;">
                  <%= @tournament.edition_number %>
                </span>
                <span class="font-medium text-gray-900"><%= @tournament.name %></span>
                <span style="color: <%= primary_color %>;">(현재)</span>
              </div>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>
  </div>
</div>

<%# 대회 형식 설명 모달 %>
<div id="format-info-modal" class="hidden fixed inset-0 z-50 overflow-y-auto" aria-labelledby="modal-title" role="dialog" aria-modal="true">
  <div class="flex items-center justify-center min-h-screen px-4 pt-4 pb-20 text-center sm:p-0">
    <%# 배경 오버레이 %>
    <div class="fixed inset-0 bg-gray-500 bg-opacity-75 transition-opacity"
         onclick="document.getElementById('format-info-modal').classList.add('hidden')"></div>

    <%# 모달 콘텐츠 %>
    <div class="relative inline-block bg-white rounded-2xl text-left overflow-hidden shadow-xl transform transition-all sm:my-8 sm:max-w-lg sm:w-full">
      <div class="bg-white px-6 pt-6 pb-4">
        <div class="flex items-center justify-between mb-4">
          <h3 class="text-lg font-bold text-gray-900" id="modal-title">대회 형식 안내</h3>
          <button type="button"
                  onclick="document.getElementById('format-info-modal').classList.add('hidden')"
                  class="text-gray-400 hover:text-gray-600 transition-colors">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
            </svg>
          </button>
        </div>

        <div class="space-y-4">
          <%# 현재 대회 형식 강조 %>
          <div class="p-4 rounded-lg" style="background-color: <%= primary_color %>10; border: 1px solid <%= primary_color %>30;">
            <div class="flex items-center gap-2 mb-2">
              <span class="px-2 py-0.5 text-xs font-medium text-white rounded" style="background-color: <%= primary_color %>;">현재 대회</span>
              <span class="font-bold text-gray-900"><%= @tournament.format_name %></span>
            </div>
            <p class="text-sm text-gray-600">
              <% case @tournament.format %>
              <% when "single_elimination" %>
                한 번 지면 탈락하는 토너먼트 방식입니다. 빠른 진행이 특징입니다.
              <% when "double_elimination" %>
                두 번 패배해야 탈락하는 방식입니다. 한 번의 패배로 탈락하지 않아 더 많은 경기 기회가 있습니다.
              <% when "round_robin" %>
                모든 팀이 서로 한 번씩 경기하는 방식입니다. 가장 공정한 순위 결정이 가능합니다.
              <% when "group_stage" %>
                조별 리그 후 토너먼트를 진행하는 방식입니다. 리그와 토너먼트의 장점을 결합했습니다.
              <% when "swiss" %>
                비슷한 성적의 팀끼리 매칭되는 방식입니다. 적은 경기로 정확한 순위를 결정할 수 있습니다.
              <% end %>
            </p>
          </div>

          <hr class="border-gray-200">

          <%# 모든 형식 설명 %>
          <div class="space-y-3">
            <h4 class="text-sm font-semibold text-gray-700">모든 대회 형식</h4>

            <div class="space-y-3 text-sm">
              <div class="flex gap-3">
                <div class="w-8 h-8 rounded-lg bg-red-100 flex items-center justify-center flex-shrink-0">
                  <svg class="w-4 h-4 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
                  </svg>
                </div>
                <div>
                  <p class="font-medium text-gray-900">싱글 엘리미네이션</p>
                  <p class="text-gray-500">1패 탈락 토너먼트. 빠른 진행, 긴장감 높음</p>
                </div>
              </div>

              <div class="flex gap-3">
                <div class="w-8 h-8 rounded-lg bg-orange-100 flex items-center justify-center flex-shrink-0">
                  <svg class="w-4 h-4 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
                  </svg>
                </div>
                <div>
                  <p class="font-medium text-gray-900">더블 엘리미네이션</p>
                  <p class="text-gray-500">2패 탈락 토너먼트. 패자부활전 있음</p>
                </div>
              </div>

              <div class="flex gap-3">
                <div class="w-8 h-8 rounded-lg bg-blue-100 flex items-center justify-center flex-shrink-0">
                  <svg class="w-4 h-4 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
                  </svg>
                </div>
                <div>
                  <p class="font-medium text-gray-900">리그전 (Round Robin)</p>
                  <p class="text-gray-500">모든 팀이 서로 대결. 가장 공정한 방식</p>
                </div>
              </div>

              <div class="flex gap-3">
                <div class="w-8 h-8 rounded-lg bg-green-100 flex items-center justify-center flex-shrink-0">
                  <svg class="w-4 h-4 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/>
                  </svg>
                </div>
                <div>
                  <p class="font-medium text-gray-900">조별 리그</p>
                  <p class="text-gray-500">조별 예선 + 본선 토너먼트 혼합</p>
                </div>
              </div>

              <div class="flex gap-3">
                <div class="w-8 h-8 rounded-lg bg-purple-100 flex items-center justify-center flex-shrink-0">
                  <svg class="w-4 h-4 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
                  </svg>
                </div>
                <div>
                  <p class="font-medium text-gray-900">스위스 리그</p>
                  <p class="text-gray-500">비슷한 성적끼리 대결. 효율적인 순위 결정</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="bg-gray-50 px-6 py-4">
        <button type="button"
                onclick="document.getElementById('format-info-modal').classList.add('hidden')"
                class="w-full px-4 py-2 text-white font-medium rounded-lg transition-colors"
                style="background-color: <%= primary_color %>;">
          확인
        </button>
      </div>
    </div>
  </div>
</div>
