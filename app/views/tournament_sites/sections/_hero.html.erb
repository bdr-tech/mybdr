<%# Hero section - Modern minimalist style with mobile optimization %>
<% bg_image = section.content['background_image'] || @tournament_site.hero_image_url %>
<% title = section.title || @tournament_site.tournament.name %>
<% subtitle = section.subtitle || @tournament_site.tournament.description&.truncate(200) %>
<% primary_color = @tournament_site.primary_color || '#7C3AED' %>

<section class="relative bg-white py-12 sm:py-16 md:py-20 lg:py-24">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <%# Badge/Label %>
    <% if @tournament_site.tournament.series.present? %>
      <span class="inline-block px-3 py-1 sm:px-4 sm:py-1.5 text-xs sm:text-sm font-semibold rounded-full mb-4 sm:mb-6"
            style="color: <%= primary_color %>; background-color: <%= primary_color %>15;">
        <%= @tournament_site.tournament.series.name %>
      </span>
    <% else %>
      <span class="inline-block px-3 py-1 sm:px-4 sm:py-1.5 text-xs sm:text-sm font-semibold rounded-full mb-4 sm:mb-6"
            style="color: <%= primary_color %>; background-color: <%= primary_color %>15;">
        Basketball Tournament
      </span>
    <% end %>

    <%# Main Title %>
    <h1 class="text-2xl sm:text-3xl md:text-4xl lg:text-5xl font-bold text-gray-900 mb-4 sm:mb-6 leading-tight break-keep">
      <%= title %>
    </h1>

    <%# Subtitle/Description %>
    <% if subtitle.present? %>
      <p class="text-base sm:text-lg md:text-xl text-gray-600 max-w-2xl mx-auto mb-6 sm:mb-8 md:mb-10 leading-relaxed px-2">
        <%= subtitle %>
      </p>
    <% end %>

    <%# CTA Buttons %>
    <% if section.content['buttons'].present? %>
      <div class="flex flex-col sm:flex-row flex-wrap justify-center gap-3 sm:gap-4">
        <% section.content['buttons'].each_with_index do |button, index| %>
          <% if index == 0 %>
            <%= link_to button['text'], button['url'],
                        class: "w-full sm:w-auto px-6 sm:px-8 py-3 sm:py-3.5 text-white font-semibold rounded-lg shadow-lg hover:shadow-xl transition-all text-center",
                        style: "background-color: #{primary_color};" %>
          <% else %>
            <%= link_to button['text'], button['url'],
                        class: "w-full sm:w-auto px-6 sm:px-8 py-3 sm:py-3.5 font-semibold rounded-lg border-2 transition-all hover:bg-gray-50 text-center",
                        style: "color: #{primary_color}; border-color: #{primary_color};" %>
          <% end %>
        <% end %>
      </div>
    <% else %>
      <div class="flex flex-col sm:flex-row flex-wrap justify-center gap-3 sm:gap-4">
        <% if @tournament_site.tournament.registration_period_active? %>
          <%= link_to "참가 신청하기", tournament_path(@tournament_site.tournament),
                      class: "w-full sm:w-auto px-6 sm:px-8 py-3 sm:py-3.5 text-white font-semibold rounded-lg shadow-lg hover:shadow-xl transition-all text-center",
                      style: "background-color: #{primary_color};" %>
        <% end %>
        <%= link_to "일정 확인하기", site_path("/schedule"),
                    class: "w-full sm:w-auto px-6 sm:px-8 py-3 sm:py-3.5 font-semibold rounded-lg border-2 transition-all hover:bg-gray-50 text-center",
                    style: "color: #{primary_color}; border-color: #{primary_color};" %>
      </div>
    <% end %>
  </div>
</section>
