<%# Schedule section - Modern minimalist style with mobile optimization %>
<% data = section.dynamic_data %>
<% matches = data[:matches] || [] %>
<% primary_color = @tournament_site.primary_color || '#7C3AED' %>

<section class="bg-gray-50 py-12 sm:py-16 md:py-20 lg:py-24">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <%# Section Header %>
    <div class="text-center mb-8 sm:mb-10 md:mb-12">
      <span class="inline-block px-3 py-1 sm:px-4 sm:py-1.5 text-xs sm:text-sm font-semibold rounded-full mb-3 sm:mb-4"
            style="color: <%= primary_color %>; background-color: <%= primary_color %>15;">
        Schedule
      </span>
      <h2 class="text-2xl sm:text-3xl md:text-4xl font-bold text-gray-900 mb-3 sm:mb-4 break-keep">
        <%= section.title || '경기일정' %>
      </h2>
      <% if section.subtitle.present? %>
        <p class="text-base sm:text-lg text-gray-600 max-w-2xl mx-auto px-2">
          <%= section.subtitle %>
        </p>
      <% end %>
    </div>

    <% if matches.any? %>
      <div class="space-y-3 sm:space-y-4 md:grid md:grid-cols-2 md:gap-4 md:space-y-0 lg:gap-6">
        <% matches.take(6).each do |match| %>
          <div class="bg-white rounded-xl sm:rounded-2xl p-4 sm:p-5 md:p-6 hover:shadow-md transition-shadow">
            <%# Match Header %>
            <div class="flex items-center justify-between mb-3 sm:mb-4">
              <span class="text-xs sm:text-sm font-medium text-gray-500 truncate max-w-[120px] sm:max-w-none">
                <%= match.round_name || match.round_display %>
              </span>
              <% if match.status_completed? %>
                <span class="px-2 py-0.5 sm:px-2.5 sm:py-1 text-[10px] sm:text-xs font-semibold rounded-full bg-green-100 text-green-700 flex-shrink-0">종료</span>
              <% elsif match.status_live? %>
                <span class="px-2 py-0.5 sm:px-2.5 sm:py-1 text-[10px] sm:text-xs font-semibold rounded-full bg-red-100 text-red-600 animate-pulse flex-shrink-0">LIVE</span>
              <% else %>
                <span class="px-2 py-0.5 sm:px-2.5 sm:py-1 text-[10px] sm:text-xs font-semibold rounded-full flex-shrink-0"
                      style="background-color: <%= primary_color %>15; color: <%= primary_color %>;">
                  <%= match.scheduled_at&.strftime("%m/%d %H:%M") || '미정' %>
                </span>
              <% end %>
            </div>

            <%# Teams & Score - Mobile optimized layout %>
            <div class="flex items-center justify-between gap-2">
              <%# Home Team %>
              <div class="flex items-center gap-2 sm:gap-3 flex-1 min-w-0">
                <% if match.home_team&.team&.logo_url.present? %>
                  <div class="w-8 h-8 sm:w-10 sm:h-10 rounded-lg sm:rounded-xl bg-gray-50 p-1 sm:p-1.5 flex items-center justify-center flex-shrink-0">
                    <img src="<%= match.home_team.team.logo_url %>" alt="" class="w-full h-full object-contain">
                  </div>
                <% else %>
                  <div class="w-8 h-8 sm:w-10 sm:h-10 rounded-lg sm:rounded-xl flex items-center justify-center flex-shrink-0"
                       style="background-color: <%= primary_color %>15;">
                    <span class="text-xs sm:text-sm font-bold" style="color: <%= primary_color %>;">
                      <%= match.home_team&.team&.name&.first&.upcase || '?' %>
                    </span>
                  </div>
                <% end %>
                <span class="text-xs sm:text-sm md:text-base font-semibold text-gray-900 truncate">
                  <%= match.home_team&.team&.name || 'TBD' %>
                </span>
              </div>

              <%# Score %>
              <div class="px-2 sm:px-4 text-center flex-shrink-0">
                <% if match.status_completed? || match.status_live? %>
                  <div class="flex items-center gap-1 sm:gap-2">
                    <span class="text-base sm:text-lg md:text-xl font-bold <%= match.home_score > match.away_score ? 'text-gray-900' : 'text-gray-400' %>">
                      <%= match.home_score %>
                    </span>
                    <span class="text-gray-300 text-sm">:</span>
                    <span class="text-base sm:text-lg md:text-xl font-bold <%= match.away_score > match.home_score ? 'text-gray-900' : 'text-gray-400' %>">
                      <%= match.away_score %>
                    </span>
                  </div>
                <% else %>
                  <span class="text-sm sm:text-base md:text-lg font-semibold text-gray-300">VS</span>
                <% end %>
              </div>

              <%# Away Team %>
              <div class="flex items-center gap-2 sm:gap-3 flex-1 min-w-0 justify-end">
                <span class="text-xs sm:text-sm md:text-base font-semibold text-gray-900 truncate text-right">
                  <%= match.away_team&.team&.name || 'TBD' %>
                </span>
                <% if match.away_team&.team&.logo_url.present? %>
                  <div class="w-8 h-8 sm:w-10 sm:h-10 rounded-lg sm:rounded-xl bg-gray-50 p-1 sm:p-1.5 flex items-center justify-center flex-shrink-0">
                    <img src="<%= match.away_team.team.logo_url %>" alt="" class="w-full h-full object-contain">
                  </div>
                <% else %>
                  <div class="w-8 h-8 sm:w-10 sm:h-10 rounded-lg sm:rounded-xl flex items-center justify-center flex-shrink-0"
                       style="background-color: <%= primary_color %>15;">
                    <span class="text-xs sm:text-sm font-bold" style="color: <%= primary_color %>;">
                      <%= match.away_team&.team&.name&.first&.upcase || '?' %>
                    </span>
                  </div>
                <% end %>
              </div>
            </div>

            <%# Venue %>
            <% if match.venue.present? %>
              <div class="mt-3 sm:mt-4 pt-3 sm:pt-4 border-t border-gray-100">
                <p class="text-xs sm:text-sm text-gray-500 flex items-center gap-1.5">
                  <svg class="w-3.5 h-3.5 sm:w-4 sm:h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                  </svg>
                  <span class="truncate"><%= match.venue.name %></span>
                </p>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>

      <div class="text-center mt-8 sm:mt-10">
        <%= link_to site_path("/schedule"),
                    class: "inline-flex items-center gap-2 text-sm sm:text-base font-semibold transition-colors hover:opacity-80",
                    style: "color: #{primary_color};" do %>
          전체 일정 보기
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
        <% end %>
      </div>
    <% else %>
      <div class="bg-white rounded-xl sm:rounded-2xl p-8 sm:p-12 text-center">
        <div class="w-14 h-14 sm:w-16 sm:h-16 rounded-xl sm:rounded-2xl mx-auto mb-3 sm:mb-4 flex items-center justify-center"
             style="background-color: <%= primary_color %>15;">
          <svg class="w-6 h-6 sm:w-8 sm:h-8" style="color: <%= primary_color %>;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
          </svg>
        </div>
        <p class="text-sm sm:text-base text-gray-600">아직 등록된 경기 일정이 없습니다.</p>
      </div>
    <% end %>
  </div>
</section>
