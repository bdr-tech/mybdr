<%# Player card section %>
<% player_id = section.content['player_id'] %>
<% player = Player.find_by(id: player_id) if player_id.present? %>

<section class="<%= section.padding_classes %>" style="<%= section.style_attributes.map { |k, v| "#{k}: #{v};" }.join(' ') %>">
  <div class="max-w-md mx-auto px-4 sm:px-6 lg:px-8">
    <% if player %>
      <div class="bg-white rounded-2xl shadow-lg overflow-hidden">
        <%# Player Image %>
        <div class="aspect-square bg-gradient-to-b from-gray-100 to-gray-200 relative">
          <% if player.photo_url.present? %>
            <img src="<%= player.photo_url %>" alt="<%= player.name %>" class="w-full h-full object-cover">
          <% else %>
            <div class="absolute inset-0 flex items-center justify-center">
              <span class="text-8xl text-gray-300">👤</span>
            </div>
          <% end %>
          <% if player.jersey_number.present? %>
            <div class="absolute top-4 right-4 bg-primary text-white text-3xl font-bold px-4 py-2 rounded-lg">
              #<%= player.jersey_number %>
            </div>
          <% end %>
        </div>

        <%# Player Info %>
        <div class="p-6">
          <h3 class="text-2xl font-bold text-gray-900 mb-1"><%= player.name %></h3>
          <% if player.position.present? %>
            <p class="text-primary font-medium mb-4"><%= player.position %></p>
          <% end %>

          <div class="grid grid-cols-3 gap-4 text-center">
            <% if player.height.present? %>
              <div>
                <p class="text-2xl font-bold text-gray-900"><%= player.height %></p>
                <p class="text-sm text-gray-500">신장</p>
              </div>
            <% end %>
            <% if player.weight.present? %>
              <div>
                <p class="text-2xl font-bold text-gray-900"><%= player.weight %></p>
                <p class="text-sm text-gray-500">체중</p>
              </div>
            <% end %>
            <% if player.age.present? %>
              <div>
                <p class="text-2xl font-bold text-gray-900"><%= player.age %></p>
                <p class="text-sm text-gray-500">나이</p>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    <% else %>
      <div class="bg-gray-100 rounded-xl p-12 text-center">
        <p class="text-gray-500">선수 정보가 없습니다.</p>
      </div>
    <% end %>
  </div>
</section>
