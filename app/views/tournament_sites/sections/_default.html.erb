<%# Default section rendering for unknown section types %>
<section class="<%= section.padding_classes %>" style="<%= section.style_attributes.map { |k, v| "#{k}: #{v};" }.join(' ') %>">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <% if section.title.present? %>
      <h2 class="text-2xl md:text-3xl font-bold text-gray-900 mb-4"><%= section.title %></h2>
    <% end %>
    <% if section.subtitle.present? %>
      <p class="text-gray-600 mb-6"><%= section.subtitle %></p>
    <% end %>
    <% if section.body.present? %>
      <div class="prose max-w-none">
        <%= simple_format(section.body) %>
      </div>
    <% end %>
  </div>
</section>
