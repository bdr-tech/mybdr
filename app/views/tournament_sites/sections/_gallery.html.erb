<%# Gallery section %>
<% images = section.items %>

<section class="<%= section.padding_classes %>" style="<%= section.style_attributes.map { |k, v| "#{k}: #{v};" }.join(' ') %>">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-8">
      <h2 class="text-2xl md:text-3xl font-bold text-gray-900"><%= section.title || '갤러리' %></h2>
      <% if section.subtitle.present? %>
        <p class="text-gray-600 mt-2"><%= section.subtitle %></p>
      <% end %>
    </div>

    <% if images.any? %>
      <div class="grid grid-cols-2 md:grid-cols-<%= section.columns %> gap-4">
        <% images.each do |image| %>
          <div class="aspect-square rounded-lg overflow-hidden">
            <img src="<%= image['url'] %>"
                 alt="<%= image['caption'] || '갤러리 이미지' %>"
                 class="w-full h-full object-cover hover:scale-105 transition-transform duration-300">
          </div>
        <% end %>
      </div>

      <%= link_to "전체 갤러리 보기 →", site_path("/gallery"),
                  class: "block text-center text-primary font-medium mt-6 hover:underline" %>
    <% else %>
      <div class="bg-gray-100 rounded-xl p-12 text-center">
        <p class="text-gray-500">아직 등록된 사진이 없습니다.</p>
      </div>
    <% end %>
  </div>
</section>
