<%# Text/Content section %>
<section class="<%= section.padding_classes %>" style="<%= section.style_attributes.map { |k, v| "#{k}: #{v};" }.join(' ') %>">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <% if section.title.present? %>
      <h2 class="text-2xl md:text-3xl font-bold text-gray-900 mb-4 text-center"><%= section.title %></h2>
    <% end %>
    <% if section.subtitle.present? %>
      <p class="text-gray-600 text-center mb-8 max-w-2xl mx-auto"><%= section.subtitle %></p>
    <% end %>
    <% if section.body.present? %>
      <div class="prose prose-lg max-w-none mx-auto">
        <%= raw(section.body) %>
      </div>
    <% end %>
  </div>
</section>
