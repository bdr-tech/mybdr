<%# Notice page template - Modern minimalist style with mobile optimization %>
<% tournament = @tournament_site.tournament %>
<% primary_color = @tournament_site.primary_color || '#7C3AED' %>

<%# Page Header %>
<section class="bg-white py-12 sm:py-16 md:py-20">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <span class="inline-block px-3 py-1 sm:px-4 sm:py-1.5 text-xs sm:text-sm font-semibold rounded-full mb-4 sm:mb-6"
          style="color: <%= primary_color %>; background-color: <%= primary_color %>15;">
      Notice
    </span>
    <h1 class="text-2xl sm:text-3xl md:text-4xl font-bold text-gray-900 mb-3 sm:mb-4 break-keep"><%= page.title %></h1>
    <% if page.meta_description.present? %>
      <p class="text-base sm:text-lg text-gray-600 max-w-2xl mx-auto px-2"><%= page.meta_description %></p>
    <% else %>
      <p class="text-base sm:text-lg text-gray-600 max-w-2xl mx-auto px-2">대회 관련 안내사항을 확인하세요.</p>
    <% end %>
  </div>
</section>

<%# Render custom sections %>
<% sections.each do |section| %>
  <%= render "tournament_sites/sections/#{section.section_type}", section: section %>
<% rescue ActionView::MissingTemplate %>
  <%= render "tournament_sites/sections/default", section: section %>
<% end %>

<%# Default notice content if no sections %>
<% if sections.empty? %>
  <section class="bg-gray-50 py-12 sm:py-16 md:py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <%# Tournament Info Card %>
      <div class="bg-white rounded-xl sm:rounded-2xl overflow-hidden mb-6 sm:mb-8">
        <div class="px-5 py-4 sm:px-6 sm:py-5" style="background-color: <%= primary_color %>;">
          <div class="flex items-center gap-3">
            <div class="w-8 h-8 sm:w-10 sm:h-10 rounded-lg sm:rounded-xl bg-white/20 flex items-center justify-center flex-shrink-0">
              <svg class="w-4 h-4 sm:w-5 sm:h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
            </div>
            <h2 class="text-base sm:text-lg font-bold text-white">대회 안내</h2>
          </div>
        </div>

        <div class="p-5 sm:p-6 md:p-8">
          <% if tournament.description.present? %>
            <div class="prose prose-sm sm:prose max-w-none text-gray-600">
              <%= simple_format(tournament.description) %>
            </div>
          <% else %>
            <p class="text-sm sm:text-base text-gray-500 text-center py-4">대회 상세 정보가 등록되지 않았습니다.</p>
          <% end %>
        </div>
      </div>

      <%# Rules Card %>
      <% if tournament.rules.present? %>
        <div class="bg-white rounded-xl sm:rounded-2xl overflow-hidden mb-6 sm:mb-8">
          <div class="px-5 py-4 sm:px-6 sm:py-5 bg-gray-900">
            <div class="flex items-center gap-3">
              <div class="w-8 h-8 sm:w-10 sm:h-10 rounded-lg sm:rounded-xl bg-white/10 flex items-center justify-center flex-shrink-0">
                <svg class="w-4 h-4 sm:w-5 sm:h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
                </svg>
              </div>
              <h2 class="text-base sm:text-lg font-bold text-white">대회 규정</h2>
            </div>
          </div>

          <div class="p-5 sm:p-6 md:p-8">
            <div class="prose prose-sm sm:prose max-w-none text-gray-600">
              <%= simple_format(tournament.rules) %>
            </div>
          </div>
        </div>
      <% end %>

      <%# Tournament Details Grid %>
      <div class="bg-white rounded-xl sm:rounded-2xl p-5 sm:p-6 md:p-8 mb-6 sm:mb-8">
        <h3 class="text-base sm:text-lg font-bold text-gray-900 mb-4 sm:mb-6 flex items-center gap-2">
          <div class="w-8 h-8 sm:w-10 sm:h-10 rounded-lg sm:rounded-xl flex items-center justify-center flex-shrink-0"
               style="background-color: <%= primary_color %>15;">
            <svg class="w-4 h-4 sm:w-5 sm:h-5" style="color: <%= primary_color %>;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
            </svg>
          </div>
          대회 정보
        </h3>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 sm:gap-6">
          <%# Date %>
          <div class="flex items-start gap-3 sm:gap-4">
            <div class="w-10 h-10 sm:w-12 sm:h-12 rounded-lg sm:rounded-xl flex items-center justify-center flex-shrink-0"
                 style="background-color: <%= primary_color %>15;">
              <svg class="w-5 h-5 sm:w-6 sm:h-6" style="color: <%= primary_color %>;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
              </svg>
            </div>
            <div>
              <p class="text-xs sm:text-sm text-gray-500 mb-0.5 sm:mb-1">대회 기간</p>
              <p class="text-sm sm:text-base font-semibold text-gray-900 break-keep"><%= tournament.date_range %></p>
            </div>
          </div>

          <%# Location %>
          <% if tournament.venue_name.present? %>
            <div class="flex items-start gap-3 sm:gap-4">
              <div class="w-10 h-10 sm:w-12 sm:h-12 rounded-lg sm:rounded-xl flex items-center justify-center flex-shrink-0"
                   style="background-color: <%= primary_color %>15;">
                <svg class="w-5 h-5 sm:w-6 sm:h-6" style="color: <%= primary_color %>;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                </svg>
              </div>
              <div>
                <p class="text-xs sm:text-sm text-gray-500 mb-0.5 sm:mb-1">장소</p>
                <p class="text-sm sm:text-base font-semibold text-gray-900"><%= tournament.venue_name %></p>
              </div>
            </div>
          <% end %>

          <%# Teams %>
          <div class="flex items-start gap-3 sm:gap-4">
            <div class="w-10 h-10 sm:w-12 sm:h-12 rounded-lg sm:rounded-xl flex items-center justify-center flex-shrink-0"
                 style="background-color: <%= primary_color %>15;">
              <svg class="w-5 h-5 sm:w-6 sm:h-6" style="color: <%= primary_color %>;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
            </div>
            <div>
              <p class="text-xs sm:text-sm text-gray-500 mb-0.5 sm:mb-1">참가팀</p>
              <p class="text-sm sm:text-base font-semibold text-gray-900"><%= tournament.teams_count %>팀</p>
            </div>
          </div>

          <%# Entry Fee %>
          <% if tournament.entry_fee.present? && tournament.entry_fee > 0 %>
            <div class="flex items-start gap-3 sm:gap-4">
              <div class="w-10 h-10 sm:w-12 sm:h-12 rounded-lg sm:rounded-xl flex items-center justify-center flex-shrink-0"
                   style="background-color: <%= primary_color %>15;">
                <svg class="w-5 h-5 sm:w-6 sm:h-6" style="color: <%= primary_color %>;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
              </div>
              <div>
                <p class="text-xs sm:text-sm text-gray-500 mb-0.5 sm:mb-1">참가비</p>
                <p class="text-sm sm:text-base font-semibold text-gray-900"><%= number_with_delimiter(tournament.entry_fee) %>원</p>
              </div>
            </div>
          <% end %>
        </div>
      </div>

      <%# Contact Card %>
      <div class="bg-white rounded-xl sm:rounded-2xl p-5 sm:p-6 md:p-8">
        <h3 class="text-base sm:text-lg font-bold text-gray-900 mb-3 sm:mb-4 flex items-center gap-2">
          <div class="w-8 h-8 sm:w-10 sm:h-10 rounded-lg sm:rounded-xl flex items-center justify-center flex-shrink-0"
               style="background-color: <%= primary_color %>15;">
            <svg class="w-4 h-4 sm:w-5 sm:h-5" style="color: <%= primary_color %>;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
          </div>
          문의
        </h3>
        <p class="text-sm sm:text-base text-gray-600">
          대회 관련 문의사항은 대회 운영진에게 연락해주세요.
        </p>
      </div>
    </div>
  </section>
<% end %>

<%# Back to Home Link %>
<section class="bg-white py-8 sm:py-12">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <%= link_to site_home_path,
                class: "inline-flex items-center gap-2 text-sm sm:text-base font-semibold transition-colors hover:opacity-80",
                style: "color: #{primary_color};" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
      </svg>
      홈으로 돌아가기
    <% end %>
  </div>
</section>
