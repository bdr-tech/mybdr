<%# Registration page template - Modern minimalist style with mobile optimization %>
<% tournament = @tournament_site.tournament %>
<% primary_color = @tournament_site.primary_color || '#7C3AED' %>

<%# Dummy data for preview %>
<% dummy_data = {
  preparing: {
    status_badge: "준비중",
    status_color: primary_color,
    title: "참가 신청 준비중",
    registration_start: 7.days.from_now,
    entry_fee: 50000,
    max_teams: 16,
    current_teams: 0
  },
  open: {
    status_badge: "접수중",
    status_color: "#10B981",
    title: "참가 신청 접수중",
    registration_end: 14.days.from_now,
    entry_fee: 50000,
    max_teams: 16,
    current_teams: 8
  },
  in_progress: {
    status_badge: "대회 진행중",
    status_color: "#F59E0B",
    title: "대회가 진행중입니다",
    start_date: 3.days.ago,
    end_date: 7.days.from_now,
    current_teams: 12,
    completed_matches: 8,
    remaining_matches: 4
  },
  finished: {
    status_badge: "대회 종료",
    status_color: "#6B7280",
    title: "대회가 종료되었습니다",
    end_date: 3.days.ago,
    total_teams: 16,
    total_matches: 15,
    champion: "서울 버커스"
  }
} %>

<%# Page Header %>
<section class="bg-white py-12 sm:py-16 md:py-20">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <span class="inline-block px-3 py-1 sm:px-4 sm:py-1.5 text-xs sm:text-sm font-semibold rounded-full mb-4 sm:mb-6"
          style="color: <%= primary_color %>; background-color: <%= primary_color %>15;">
      Registration
    </span>
    <h1 class="text-2xl sm:text-3xl md:text-4xl font-bold text-gray-900 mb-3 sm:mb-4 break-keep"><%= page.title %></h1>
    <% if page.meta_description.present? %>
      <p class="text-base sm:text-lg text-gray-600 max-w-2xl mx-auto px-2"><%= page.meta_description %></p>
    <% else %>
      <p class="text-base sm:text-lg text-gray-600 max-w-2xl mx-auto px-2">대회 참가 신청을 진행하세요.</p>
    <% end %>
  </div>
</section>

<%# Render custom sections %>
<% sections.each do |section| %>
  <%= render "tournament_sites/sections/#{section.section_type}", section: section %>
<% rescue ActionView::MissingTemplate %>
  <%= render "tournament_sites/sections/default", section: section %>
<% end %>

<%# Default registration content if no sections %>
<% if sections.empty? %>
  <%# Status Preview Section %>
  <section class="bg-gray-50 py-12 sm:py-16">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-8 sm:mb-10">
        <span class="inline-block px-3 py-1 text-xs font-semibold rounded-full bg-gray-200 text-gray-600 mb-3">
          미리보기
        </span>
        <h2 class="text-xl sm:text-2xl font-bold text-gray-900 mb-2">대회 상태별 레이아웃</h2>
        <p class="text-sm text-gray-500">각 상태별 화면을 미리 확인하세요</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 sm:gap-8">

        <%# 1. 준비중 (Registration Not Started) %>
        <div class="bg-white rounded-xl sm:rounded-2xl overflow-hidden shadow-sm">
          <div class="px-4 py-2 bg-gray-100 border-b border-gray-200">
            <span class="text-xs font-medium text-gray-500">상태 1: 참가 신청 준비중</span>
          </div>
          <div class="p-6 sm:p-8 text-center">
            <div class="w-12 h-12 sm:w-14 sm:h-14 rounded-xl sm:rounded-2xl mx-auto mb-4 flex items-center justify-center"
                 style="background-color: <%= primary_color %>15;">
              <svg class="w-6 h-6 sm:w-7 sm:h-7" style="color: <%= primary_color %>;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
            </div>

            <span class="inline-block px-3 py-1 text-xs font-semibold rounded-full mb-3"
                  style="background-color: <%= primary_color %>15; color: <%= primary_color %>;">
              <%= dummy_data[:preparing][:status_badge] %>
            </span>

            <h3 class="text-lg sm:text-xl font-bold text-gray-900 mb-2"><%= dummy_data[:preparing][:title] %></h3>
            <p class="text-sm text-gray-600 mb-4">
              참가 신청은 <strong class="text-gray-900"><%= dummy_data[:preparing][:registration_start].strftime("%Y년 %m월 %d일") %></strong>부터 시작됩니다.
            </p>

            <%# Countdown Preview %>
            <div class="p-4 bg-gray-50 rounded-xl">
              <p class="text-xs text-gray-500 mb-2">신청 시작까지</p>
              <div class="flex justify-center gap-3">
                <div class="text-center">
                  <span class="block text-lg font-bold text-gray-900">07</span>
                  <span class="text-[10px] text-gray-500">일</span>
                </div>
                <div class="text-center">
                  <span class="block text-lg font-bold text-gray-900">12</span>
                  <span class="text-[10px] text-gray-500">시간</span>
                </div>
                <div class="text-center">
                  <span class="block text-lg font-bold text-gray-900">30</span>
                  <span class="text-[10px] text-gray-500">분</span>
                </div>
                <div class="text-center">
                  <span class="block text-lg font-bold text-gray-900">45</span>
                  <span class="text-[10px] text-gray-500">초</span>
                </div>
              </div>
            </div>
          </div>
        </div>

        <%# 2. 접수중 (Registration Open) %>
        <div class="bg-white rounded-xl sm:rounded-2xl overflow-hidden shadow-sm">
          <div class="px-4 py-2 bg-gray-100 border-b border-gray-200">
            <span class="text-xs font-medium text-gray-500">상태 2: 참가 신청 접수중</span>
          </div>
          <div class="p-6 sm:p-8 text-center">
            <div class="w-12 h-12 sm:w-14 sm:h-14 rounded-xl sm:rounded-2xl mx-auto mb-4 flex items-center justify-center"
                 style="background-color: <%= dummy_data[:open][:status_color] %>15;">
              <svg class="w-6 h-6 sm:w-7 sm:h-7" style="color: <%= dummy_data[:open][:status_color] %>;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
            </div>

            <span class="inline-block px-3 py-1 text-xs font-semibold rounded-full bg-green-100 text-green-700 mb-3">
              <%= dummy_data[:open][:status_badge] %>
            </span>

            <h3 class="text-lg sm:text-xl font-bold text-gray-900 mb-2"><%= dummy_data[:open][:title] %></h3>
            <p class="text-sm text-gray-600 mb-4">
              마감일: <span class="font-semibold"><%= dummy_data[:open][:registration_end].strftime("%Y년 %m월 %d일 %H:%M") %></span>
            </p>

            <%# Registration Info %>
            <div class="bg-gray-50 rounded-xl p-4 text-left mb-4">
              <ul class="space-y-2">
                <li class="flex items-center gap-2 text-sm text-gray-600">
                  <div class="w-1.5 h-1.5 rounded-full" style="background-color: <%= primary_color %>;"></div>
                  <span>참가비: <strong class="text-gray-900"><%= number_with_delimiter(dummy_data[:open][:entry_fee]) %>원</strong></span>
                </li>
                <li class="flex items-center gap-2 text-sm text-gray-600">
                  <div class="w-1.5 h-1.5 rounded-full" style="background-color: <%= primary_color %>;"></div>
                  <span>참가팀: <strong class="text-gray-900"><%= dummy_data[:open][:current_teams] %>/<%= dummy_data[:open][:max_teams] %>팀</strong></span>
                </li>
              </ul>
            </div>

            <button class="w-full py-3 text-white font-semibold rounded-lg shadow-md"
                    style="background-color: <%= primary_color %>;">
              참가 신청하기
            </button>
          </div>
        </div>

        <%# 3. 대회 진행중 (Tournament In Progress) %>
        <div class="bg-white rounded-xl sm:rounded-2xl overflow-hidden shadow-sm">
          <div class="px-4 py-2 bg-gray-100 border-b border-gray-200">
            <span class="text-xs font-medium text-gray-500">상태 3: 대회 진행중</span>
          </div>
          <div class="p-6 sm:p-8 text-center">
            <div class="w-12 h-12 sm:w-14 sm:h-14 rounded-xl sm:rounded-2xl mx-auto mb-4 flex items-center justify-center"
                 style="background-color: <%= dummy_data[:in_progress][:status_color] %>15;">
              <svg class="w-6 h-6 sm:w-7 sm:h-7" style="color: <%= dummy_data[:in_progress][:status_color] %>;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
            </div>

            <span class="inline-block px-3 py-1 text-xs font-semibold rounded-full mb-3"
                  style="background-color: <%= dummy_data[:in_progress][:status_color] %>15; color: <%= dummy_data[:in_progress][:status_color] %>;">
              <%= dummy_data[:in_progress][:status_badge] %>
            </span>

            <h3 class="text-lg sm:text-xl font-bold text-gray-900 mb-2"><%= dummy_data[:in_progress][:title] %></h3>
            <p class="text-sm text-gray-600 mb-4">
              참가 신청이 마감되었습니다
            </p>

            <%# Progress Info %>
            <div class="bg-gray-50 rounded-xl p-4 mb-4">
              <div class="grid grid-cols-3 gap-3 text-center">
                <div>
                  <span class="block text-xl font-bold text-gray-900"><%= dummy_data[:in_progress][:current_teams] %></span>
                  <span class="text-xs text-gray-500">참가팀</span>
                </div>
                <div>
                  <span class="block text-xl font-bold" style="color: <%= primary_color %>;"><%= dummy_data[:in_progress][:completed_matches] %></span>
                  <span class="text-xs text-gray-500">완료 경기</span>
                </div>
                <div>
                  <span class="block text-xl font-bold text-gray-900"><%= dummy_data[:in_progress][:remaining_matches] %></span>
                  <span class="text-xs text-gray-500">남은 경기</span>
                </div>
              </div>
            </div>

            <div class="flex gap-2">
              <button class="flex-1 py-2.5 text-sm font-semibold rounded-lg border-2 transition-colors"
                      style="color: <%= primary_color %>; border-color: <%= primary_color %>;">
                경기 일정 보기
              </button>
              <button class="flex-1 py-2.5 text-sm text-white font-semibold rounded-lg"
                      style="background-color: <%= primary_color %>;">
                대진표 보기
              </button>
            </div>
          </div>
        </div>

        <%# 4. 대회 종료 (Tournament Finished) %>
        <div class="bg-white rounded-xl sm:rounded-2xl overflow-hidden shadow-sm">
          <div class="px-4 py-2 bg-gray-100 border-b border-gray-200">
            <span class="text-xs font-medium text-gray-500">상태 4: 대회 종료</span>
          </div>
          <div class="p-6 sm:p-8 text-center">
            <div class="w-12 h-12 sm:w-14 sm:h-14 rounded-xl sm:rounded-2xl bg-gray-100 mx-auto mb-4 flex items-center justify-center">
              <svg class="w-6 h-6 sm:w-7 sm:h-7 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
            </div>

            <span class="inline-block px-3 py-1 text-xs font-semibold rounded-full bg-gray-100 text-gray-600 mb-3">
              <%= dummy_data[:finished][:status_badge] %>
            </span>

            <h3 class="text-lg sm:text-xl font-bold text-gray-900 mb-2"><%= dummy_data[:finished][:title] %></h3>
            <p class="text-sm text-gray-600 mb-4">
              다음 대회에서 만나요!
            </p>

            <%# Champion Banner %>
            <div class="bg-gradient-to-r from-yellow-50 to-amber-50 rounded-xl p-4 mb-4 border border-yellow-200">
              <div class="flex items-center justify-center gap-2 mb-2">
                <svg class="w-5 h-5 text-yellow-500" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                </svg>
                <span class="text-sm font-semibold text-yellow-700">우승</span>
              </div>
              <p class="text-lg font-bold text-gray-900"><%= dummy_data[:finished][:champion] %></p>
            </div>

            <%# Final Stats %>
            <div class="bg-gray-50 rounded-xl p-4 mb-4">
              <div class="grid grid-cols-2 gap-3 text-center">
                <div>
                  <span class="block text-xl font-bold text-gray-900"><%= dummy_data[:finished][:total_teams] %></span>
                  <span class="text-xs text-gray-500">총 참가팀</span>
                </div>
                <div>
                  <span class="block text-xl font-bold text-gray-900"><%= dummy_data[:finished][:total_matches] %></span>
                  <span class="text-xs text-gray-500">총 경기수</span>
                </div>
              </div>
            </div>

            <button class="w-full py-2.5 text-sm font-semibold rounded-lg border-2 transition-colors"
                    style="color: <%= primary_color %>; border-color: <%= primary_color %>;">
              경기 결과 보기
            </button>
          </div>
        </div>

      </div>
    </div>
  </section>

  <%# Current Status Section %>
  <section class="bg-white py-12 sm:py-16 md:py-20">
    <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-6 sm:mb-8">
        <span class="inline-block px-3 py-1 text-xs font-semibold rounded-full mb-3"
              style="background-color: <%= primary_color %>15; color: <%= primary_color %>;">
          현재 상태
        </span>
        <h2 class="text-xl sm:text-2xl font-bold text-gray-900">실제 대회 정보</h2>
      </div>

      <div class="bg-gray-50 rounded-xl sm:rounded-2xl overflow-hidden">
        <%# Registration Status %>
        <div class="p-6 sm:p-8 md:p-10 text-center">
          <% if tournament.registration_period_active? %>
            <%# Active Registration %>
            <div class="w-14 h-14 sm:w-16 sm:h-16 rounded-xl sm:rounded-2xl mx-auto mb-4 sm:mb-6 flex items-center justify-center"
                 style="background-color: <%= primary_color %>15;">
              <svg class="w-7 h-7 sm:w-8 sm:h-8" style="color: <%= primary_color %>;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
            </div>

            <span class="inline-block px-3 py-1 sm:px-4 sm:py-1.5 text-xs sm:text-sm font-semibold rounded-full bg-green-100 text-green-700 mb-4">
              접수중
            </span>

            <h2 class="text-xl sm:text-2xl font-bold text-gray-900 mb-2 sm:mb-3 break-keep">참가 신청 접수중</h2>

            <% if tournament.registration_end_at.present? %>
              <p class="text-sm sm:text-base text-gray-600 mb-6 sm:mb-8">
                마감일: <span class="font-semibold"><%= tournament.registration_end_at.strftime("%Y년 %m월 %d일 %H:%M") %></span>
              </p>
            <% end %>

            <%# Registration Info %>
            <div class="bg-white rounded-xl p-5 sm:p-6 text-left mb-6 sm:mb-8">
              <h3 class="text-sm sm:text-base font-bold text-gray-900 mb-4 flex items-center gap-2">
                <div class="w-6 h-6 sm:w-7 sm:h-7 rounded-lg flex items-center justify-center flex-shrink-0"
                     style="background-color: <%= primary_color %>15;">
                  <svg class="w-3.5 h-3.5 sm:w-4 sm:h-4" style="color: <%= primary_color %>;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                  </svg>
                </div>
                참가 안내
              </h3>
              <ul class="space-y-2.5 sm:space-y-3">
                <li class="flex items-center gap-2.5 sm:gap-3 text-sm sm:text-base text-gray-600">
                  <div class="w-1.5 h-1.5 rounded-full flex-shrink-0" style="background-color: <%= primary_color %>;"></div>
                  <span>참가비: <strong class="text-gray-900"><%= tournament.entry_fee.present? && tournament.entry_fee > 0 ? number_with_delimiter(tournament.entry_fee) + '원' : '무료' %></strong></span>
                </li>
                <% if tournament.max_teams.present? %>
                  <li class="flex items-center gap-2.5 sm:gap-3 text-sm sm:text-base text-gray-600">
                    <div class="w-1.5 h-1.5 rounded-full flex-shrink-0" style="background-color: <%= primary_color %>;"></div>
                    <span>참가팀 제한: <strong class="text-gray-900">최대 <%= tournament.max_teams %>팀</strong></span>
                  </li>
                <% end %>
                <li class="flex items-center gap-2.5 sm:gap-3 text-sm sm:text-base text-gray-600">
                  <div class="w-1.5 h-1.5 rounded-full flex-shrink-0" style="background-color: <%= primary_color %>;"></div>
                  <span>현재 신청팀: <strong class="text-gray-900"><%= tournament.teams_count %>팀</strong></span>
                </li>
              </ul>
            </div>

            <%# Bank Account Info (if entry fee exists) %>
            <% if tournament.has_fee? && tournament.has_bank_info? %>
              <div class="bg-amber-50 border border-amber-200 rounded-xl p-5 sm:p-6 text-left mb-6 sm:mb-8">
                <h3 class="text-sm sm:text-base font-bold text-gray-900 mb-4 flex items-center gap-2">
                  <div class="w-6 h-6 sm:w-7 sm:h-7 rounded-lg flex items-center justify-center flex-shrink-0 bg-amber-100">
                    <svg class="w-3.5 h-3.5 sm:w-4 sm:h-4 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/>
                    </svg>
                  </div>
                  💳 참가비 입금 안내
                </h3>
                <div class="space-y-2.5 sm:space-y-3">
                  <div class="flex flex-col gap-1 p-3 bg-white rounded-lg border border-amber-200">
                    <span class="text-xs text-gray-500">입금 금액</span>
                    <span class="text-lg font-bold text-gray-900"><%= number_with_delimiter(tournament.entry_fee) %>원</span>
                  </div>
                  <div class="flex flex-col gap-1 p-3 bg-white rounded-lg border border-amber-200">
                    <span class="text-xs text-gray-500">입금 계좌</span>
                    <span class="text-base font-bold text-gray-900"><%= tournament.bank_name %></span>
                    <span class="text-sm text-gray-700 font-mono tracking-wide"><%= tournament.bank_account %></span>
                    <% if tournament.bank_holder.present? %>
                      <span class="text-sm text-gray-600">예금주: <%= tournament.bank_holder %></span>
                    <% end %>
                  </div>
                  <p class="text-xs text-amber-700 mt-2">
                    ⚠️ 입금 후 참가 신청을 진행해주세요. 입금자명은 팀명 또는 신청자 이름으로 해주세요.
                  </p>
                </div>
              </div>
            <% end %>

            <%= link_to tournament_path(tournament),
                        class: "inline-flex items-center justify-center gap-2 w-full py-3.5 sm:py-4 text-white font-semibold rounded-lg shadow-lg hover:shadow-xl transition-all",
                        style: "background-color: #{primary_color};" do %>
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
              </svg>
              참가 신청하기
            <% end %>

          <% elsif tournament.registration_end_at.present? && Time.current > tournament.registration_end_at %>
            <%# Registration Closed %>
            <div class="w-14 h-14 sm:w-16 sm:h-16 rounded-xl sm:rounded-2xl bg-gray-100 mx-auto mb-4 sm:mb-6 flex items-center justify-center">
              <svg class="w-7 h-7 sm:w-8 sm:h-8 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
            </div>

            <span class="inline-block px-3 py-1 sm:px-4 sm:py-1.5 text-xs sm:text-sm font-semibold rounded-full bg-gray-100 text-gray-600 mb-4">
              마감됨
            </span>

            <h2 class="text-xl sm:text-2xl font-bold text-gray-900 mb-2 sm:mb-3 break-keep">참가 신청이 마감되었습니다</h2>
            <p class="text-sm sm:text-base text-gray-600">
              다음 대회에서 만나요!
            </p>

            <div class="mt-6 sm:mt-8 pt-6 sm:pt-8 border-t border-gray-200">
              <%= link_to site_path("/schedule"),
                          class: "inline-flex items-center gap-2 text-sm sm:text-base font-semibold transition-colors hover:opacity-80",
                          style: "color: #{primary_color};" do %>
                경기 일정 보기
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                </svg>
              <% end %>
            </div>

          <% else %>
            <%# Registration Not Started %>
            <div class="w-14 h-14 sm:w-16 sm:h-16 rounded-xl sm:rounded-2xl mx-auto mb-4 sm:mb-6 flex items-center justify-center"
                 style="background-color: <%= primary_color %>15;">
              <svg class="w-7 h-7 sm:w-8 sm:h-8" style="color: <%= primary_color %>;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
            </div>

            <span class="inline-block px-3 py-1 sm:px-4 sm:py-1.5 text-xs sm:text-sm font-semibold rounded-full mb-4"
                  style="background-color: <%= primary_color %>15; color: <%= primary_color %>;">
              준비중
            </span>

            <h2 class="text-xl sm:text-2xl font-bold text-gray-900 mb-2 sm:mb-3 break-keep">참가 신청 준비중</h2>
            <p class="text-sm sm:text-base text-gray-600">
              <% if tournament.registration_start_at.present? %>
                참가 신청은 <strong class="text-gray-900"><%= tournament.registration_start_at.strftime("%Y년 %m월 %d일") %></strong>부터 시작됩니다.
              <% else %>
                곧 참가 신청이 시작됩니다.
              <% end %>
            </p>

            <%# Countdown to registration start %>
            <% if tournament.registration_start_at.present? && tournament.registration_start_at > Time.current %>
              <div class="mt-6 sm:mt-8 p-4 sm:p-6 bg-white rounded-xl">
                <p class="text-xs sm:text-sm text-gray-500 mb-3">신청 시작까지</p>
                <div class="flex justify-center gap-3 sm:gap-4" data-controller="countdown" data-countdown-target="<%= tournament.registration_start_at.iso8601 %>">
                  <div class="text-center">
                    <span class="block text-xl sm:text-2xl font-bold text-gray-900" data-countdown-target="days">--</span>
                    <span class="text-[10px] sm:text-xs text-gray-500">일</span>
                  </div>
                  <div class="text-center">
                    <span class="block text-xl sm:text-2xl font-bold text-gray-900" data-countdown-target="hours">--</span>
                    <span class="text-[10px] sm:text-xs text-gray-500">시간</span>
                  </div>
                  <div class="text-center">
                    <span class="block text-xl sm:text-2xl font-bold text-gray-900" data-countdown-target="minutes">--</span>
                    <span class="text-[10px] sm:text-xs text-gray-500">분</span>
                  </div>
                  <div class="text-center">
                    <span class="block text-xl sm:text-2xl font-bold text-gray-900" data-countdown-target="seconds">--</span>
                    <span class="text-[10px] sm:text-xs text-gray-500">초</span>
                  </div>
                </div>
              </div>
            <% end %>
          <% end %>
        </div>
      </div>

      <%# Tournament Info Summary %>
      <div class="mt-6 sm:mt-8 bg-gray-50 rounded-xl sm:rounded-2xl p-5 sm:p-6 md:p-8">
        <h3 class="text-sm sm:text-base font-bold text-gray-900 mb-4 sm:mb-6">대회 정보</h3>
        <div class="space-y-3 sm:space-y-4">
          <div class="flex items-center justify-between pb-3 sm:pb-4 border-b border-gray-200">
            <span class="text-sm text-gray-500">대회명</span>
            <span class="text-sm sm:text-base font-semibold text-gray-900 text-right"><%= tournament.name %></span>
          </div>
          <div class="flex items-center justify-between pb-3 sm:pb-4 border-b border-gray-200">
            <span class="text-sm text-gray-500">대회 기간</span>
            <span class="text-sm sm:text-base font-semibold text-gray-900"><%= tournament.date_range %></span>
          </div>
          <% if tournament.venue_name.present? %>
            <div class="flex items-center justify-between pb-3 sm:pb-4 border-b border-gray-200">
              <span class="text-sm text-gray-500">장소</span>
              <span class="text-sm sm:text-base font-semibold text-gray-900"><%= tournament.venue_name %></span>
            </div>
          <% end %>
          <div class="flex items-center justify-between">
            <span class="text-sm text-gray-500">현재 참가팀</span>
            <span class="text-sm sm:text-base font-semibold" style="color: <%= primary_color %>;"><%= tournament.teams_count %>팀</span>
          </div>
        </div>
      </div>
    </div>
  </section>
<% end %>

<%# Back to Home Link %>
<section class="bg-gray-50 py-8 sm:py-12">
  <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <%= link_to site_home_path,
                class: "inline-flex items-center gap-2 text-sm sm:text-base font-semibold transition-colors hover:opacity-80",
                style: "color: #{primary_color};" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
      </svg>
      홈으로 돌아가기
    <% end %>
  </div>
</section>
