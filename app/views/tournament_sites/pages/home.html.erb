<%# Home page template for tournament sites - Modern minimalist style with mobile optimization %>
<% primary_color = @tournament_site.primary_color || '#7C3AED' %>

<%# Hero Section (default for home page) %>
<% hero_section = sections.find { |s| s.hero? } %>
<% unless hero_section %>
  <%# Default hero if no hero section exists %>
  <section class="relative bg-white py-12 sm:py-16 md:py-20 lg:py-24">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <%# Badge/Label %>
      <% if @tournament_site.tournament.series.present? %>
        <span class="inline-block px-3 py-1 sm:px-4 sm:py-1.5 text-xs sm:text-sm font-semibold rounded-full mb-4 sm:mb-6"
              style="color: <%= primary_color %>; background-color: <%= primary_color %>15;">
          <%= @tournament_site.tournament.series.name %>
        </span>
      <% else %>
        <span class="inline-block px-3 py-1 sm:px-4 sm:py-1.5 text-xs sm:text-sm font-semibold rounded-full mb-4 sm:mb-6"
              style="color: <%= primary_color %>; background-color: <%= primary_color %>15;">
          Basketball Tournament
        </span>
      <% end %>

      <%# Main Title %>
      <h1 class="text-2xl sm:text-3xl md:text-4xl lg:text-5xl font-bold text-gray-900 mb-4 sm:mb-6 leading-tight break-keep">
        <%= @tournament_site.tournament.name %>
      </h1>

      <%# Description %>
      <% if @tournament_site.tournament.description.present? %>
        <p class="text-base sm:text-lg md:text-xl text-gray-600 max-w-2xl mx-auto mb-6 sm:mb-8 md:mb-10 leading-relaxed px-2">
          <%= @tournament_site.tournament.description.truncate(200) %>
        </p>
      <% end %>

      <%# CTA Buttons %>
      <div class="flex flex-col sm:flex-row flex-wrap justify-center gap-3 sm:gap-4">
        <% if @tournament_site.tournament.registration_period_active? %>
          <%= link_to "참가 신청하기", tournament_path(@tournament_site.tournament),
                      class: "w-full sm:w-auto px-6 sm:px-8 py-3 sm:py-3.5 text-white font-semibold rounded-lg shadow-lg hover:shadow-xl transition-all text-center",
                      style: "background-color: #{primary_color};" %>
        <% end %>
        <%= link_to "일정 확인하기", site_path("/schedule"),
                    class: "w-full sm:w-auto px-6 sm:px-8 py-3 sm:py-3.5 font-semibold rounded-lg border-2 transition-all hover:bg-gray-50 text-center",
                    style: "color: #{primary_color}; border-color: #{primary_color};" %>
      </div>
    </div>
  </section>
<% end %>

<%# Render all sections %>
<% sections.each do |section| %>
  <%= render "tournament_sites/sections/#{section.section_type}", section: section %>
<% rescue ActionView::MissingTemplate %>
  <%= render "tournament_sites/sections/default", section: section %>
<% end %>

<%# Default content if no sections exist %>
<% if sections.empty? %>
  <%# Features/Quick Links Section %>
  <section class="bg-white py-12 sm:py-16 md:py-20 lg:py-24">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <%# Section Header %>
      <div class="text-center mb-8 sm:mb-10 md:mb-12">
        <span class="inline-block px-3 py-1 sm:px-4 sm:py-1.5 text-xs sm:text-sm font-semibold rounded-full mb-3 sm:mb-4"
              style="color: <%= primary_color %>; background-color: <%= primary_color %>15;">
          Features
        </span>
        <h2 class="text-2xl sm:text-3xl md:text-4xl font-bold text-gray-900 mb-3 sm:mb-4 break-keep">
          대회 정보를 한눈에
        </h2>
        <p class="text-base sm:text-lg text-gray-600 max-w-2xl mx-auto px-2">
          경기 일정, 참가팀, 결과까지 모든 정보를 확인하세요.
        </p>
      </div>

      <%# Feature Cards - 4 columns %>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 sm:gap-6 md:gap-8">
        <%# Schedule %>
        <%= link_to site_path("/schedule"), class: "text-center group" do %>
          <div class="mb-3 sm:mb-4 flex justify-center">
            <div class="w-14 h-14 sm:w-16 sm:h-16 md:w-20 md:h-20 rounded-xl sm:rounded-2xl flex items-center justify-center group-hover:shadow-md transition-shadow"
                 style="background-color: <%= primary_color %>15;">
              <svg class="w-6 h-6 sm:w-8 sm:h-8 md:w-10 md:h-10" style="color: <%= primary_color %>;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
              </svg>
            </div>
          </div>
          <h3 class="text-sm sm:text-base font-semibold text-gray-900 mb-1">경기일정</h3>
          <p class="text-xs sm:text-sm text-gray-500 leading-relaxed">전체 경기 일정을<br class="hidden sm:block">확인하세요.</p>
        <% end %>

        <%# Teams %>
        <%= link_to site_path("/teams"), class: "text-center group" do %>
          <div class="mb-3 sm:mb-4 flex justify-center">
            <div class="w-14 h-14 sm:w-16 sm:h-16 md:w-20 md:h-20 rounded-xl sm:rounded-2xl flex items-center justify-center group-hover:shadow-md transition-shadow"
                 style="background-color: <%= primary_color %>15;">
              <svg class="w-6 h-6 sm:w-8 sm:h-8 md:w-10 md:h-10" style="color: <%= primary_color %>;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
            </div>
          </div>
          <h3 class="text-sm sm:text-base font-semibold text-gray-900 mb-1">참가팀</h3>
          <p class="text-xs sm:text-sm text-gray-500 leading-relaxed">대회 참가팀을<br class="hidden sm:block">확인하세요.</p>
        <% end %>

        <%# Results %>
        <%= link_to site_path("/results"), class: "text-center group" do %>
          <div class="mb-3 sm:mb-4 flex justify-center">
            <div class="w-14 h-14 sm:w-16 sm:h-16 md:w-20 md:h-20 rounded-xl sm:rounded-2xl flex items-center justify-center group-hover:shadow-md transition-shadow"
                 style="background-color: <%= primary_color %>15;">
              <svg class="w-6 h-6 sm:w-8 sm:h-8 md:w-10 md:h-10" style="color: <%= primary_color %>;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
              </svg>
            </div>
          </div>
          <h3 class="text-sm sm:text-base font-semibold text-gray-900 mb-1">경기결과</h3>
          <p class="text-xs sm:text-sm text-gray-500 leading-relaxed">경기 결과와 순위를<br class="hidden sm:block">확인하세요.</p>
        <% end %>

        <%# Notice %>
        <%= link_to site_path("/notice"), class: "text-center group" do %>
          <div class="mb-3 sm:mb-4 flex justify-center">
            <div class="w-14 h-14 sm:w-16 sm:h-16 md:w-20 md:h-20 rounded-xl sm:rounded-2xl flex items-center justify-center group-hover:shadow-md transition-shadow"
                 style="background-color: <%= primary_color %>15;">
              <svg class="w-6 h-6 sm:w-8 sm:h-8 md:w-10 md:h-10" style="color: <%= primary_color %>;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z"/>
              </svg>
            </div>
          </div>
          <h3 class="text-sm sm:text-base font-semibold text-gray-900 mb-1">공지사항</h3>
          <p class="text-xs sm:text-sm text-gray-500 leading-relaxed">대회 관련 소식을<br class="hidden sm:block">확인하세요.</p>
        <% end %>
      </div>
    </div>
  </section>

  <%# Tournament Info Section %>
  <section class="bg-gray-50 py-12 sm:py-16 md:py-20 lg:py-24">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-8 sm:mb-10 md:mb-12">
        <span class="inline-block px-3 py-1 sm:px-4 sm:py-1.5 text-xs sm:text-sm font-semibold rounded-full mb-3 sm:mb-4"
              style="color: <%= primary_color %>; background-color: <%= primary_color %>15;">
          Info
        </span>
        <h2 class="text-2xl sm:text-3xl md:text-4xl font-bold text-gray-900 mb-3 sm:mb-4 break-keep">대회 정보</h2>
      </div>

      <div class="bg-white rounded-xl sm:rounded-2xl p-6 sm:p-8 md:p-10">
        <% if @tournament_site.tournament.description.present? %>
          <p class="text-sm sm:text-base md:text-lg text-gray-600 text-center mb-6 sm:mb-8 leading-relaxed px-2">
            <%= @tournament_site.tournament.description %>
          </p>
        <% end %>

        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 sm:gap-6">
          <div class="text-center">
            <div class="w-10 h-10 sm:w-12 sm:h-12 rounded-lg sm:rounded-xl mx-auto mb-2 sm:mb-3 flex items-center justify-center"
                 style="background-color: <%= primary_color %>15;">
              <svg class="w-5 h-5 sm:w-6 sm:h-6" style="color: <%= primary_color %>;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
              </svg>
            </div>
            <p class="text-[10px] sm:text-xs md:text-sm text-gray-500 mb-0.5 sm:mb-1">대회 기간</p>
            <p class="text-xs sm:text-sm md:text-base font-semibold text-gray-900 break-keep"><%= @tournament_site.tournament.date_range %></p>
          </div>

          <div class="text-center">
            <div class="w-10 h-10 sm:w-12 sm:h-12 rounded-lg sm:rounded-xl mx-auto mb-2 sm:mb-3 flex items-center justify-center"
                 style="background-color: <%= primary_color %>15;">
              <svg class="w-5 h-5 sm:w-6 sm:h-6" style="color: <%= primary_color %>;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
            </div>
            <p class="text-[10px] sm:text-xs md:text-sm text-gray-500 mb-0.5 sm:mb-1">참가팀</p>
            <p class="text-xs sm:text-sm md:text-base font-semibold text-gray-900"><%= @tournament_site.tournament.teams_count %>팀</p>
          </div>

          <% if @tournament_site.tournament.venue_name.present? %>
            <div class="text-center">
              <div class="w-10 h-10 sm:w-12 sm:h-12 rounded-lg sm:rounded-xl mx-auto mb-2 sm:mb-3 flex items-center justify-center"
                   style="background-color: <%= primary_color %>15;">
                <svg class="w-5 h-5 sm:w-6 sm:h-6" style="color: <%= primary_color %>;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                </svg>
              </div>
              <p class="text-[10px] sm:text-xs md:text-sm text-gray-500 mb-0.5 sm:mb-1">장소</p>
              <p class="text-xs sm:text-sm md:text-base font-semibold text-gray-900 truncate px-1"><%= @tournament_site.tournament.venue_name %></p>
            </div>
          <% end %>

          <% if @tournament_site.tournament.entry_fee.present? && @tournament_site.tournament.entry_fee > 0 %>
            <div class="text-center">
              <div class="w-10 h-10 sm:w-12 sm:h-12 rounded-lg sm:rounded-xl mx-auto mb-2 sm:mb-3 flex items-center justify-center"
                   style="background-color: <%= primary_color %>15;">
                <svg class="w-5 h-5 sm:w-6 sm:h-6" style="color: <%= primary_color %>;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
              </div>
              <p class="text-[10px] sm:text-xs md:text-sm text-gray-500 mb-0.5 sm:mb-1">참가비</p>
              <p class="text-xs sm:text-sm md:text-base font-semibold text-gray-900"><%= number_with_delimiter(@tournament_site.tournament.entry_fee) %>원</p>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </section>
<% end %>
