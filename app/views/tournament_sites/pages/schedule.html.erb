<%# Schedule page template - Modern minimalist style with mobile optimization %>
<% tournament = @tournament_site.tournament %>
<% matches = tournament.tournament_matches.includes(:home_team, :away_team, :venue).order(:scheduled_at) %>
<% primary_color = @tournament_site.primary_color || '#7C3AED' %>

<%# Page Header %>
<section class="bg-white py-12 sm:py-16 md:py-20">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <span class="inline-block px-3 py-1 sm:px-4 sm:py-1.5 text-xs sm:text-sm font-semibold rounded-full mb-4 sm:mb-6"
          style="color: <%= primary_color %>; background-color: <%= primary_color %>15;">
      Schedule
    </span>
    <h1 class="text-2xl sm:text-3xl md:text-4xl font-bold text-gray-900 mb-3 sm:mb-4 break-keep"><%= page.title %></h1>
    <% if page.meta_description.present? %>
      <p class="text-base sm:text-lg text-gray-600 max-w-2xl mx-auto px-2"><%= page.meta_description %></p>
    <% else %>
      <p class="text-base sm:text-lg text-gray-600 max-w-2xl mx-auto px-2">전체 경기 일정을 확인하세요.</p>
    <% end %>
  </div>
</section>

<%# Render custom sections %>
<% sections.each do |section| %>
  <%= render "tournament_sites/sections/#{section.section_type}", section: section %>
<% rescue ActionView::MissingTemplate %>
  <%= render "tournament_sites/sections/default", section: section %>
<% end %>

<%# Default schedule content if no sections %>
<% if sections.empty? %>
  <section class="bg-gray-50 py-12 sm:py-16 md:py-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <% if matches.any? %>
        <%# Group by date %>
        <% matches.group_by { |m| m.scheduled_at&.to_date }.each do |date, day_matches| %>
          <div class="mb-8 sm:mb-10">
            <h2 class="text-base sm:text-lg font-bold text-gray-900 mb-4 sm:mb-6 pb-2 border-b border-gray-200 flex items-center gap-2">
              <div class="w-8 h-8 sm:w-10 sm:h-10 rounded-lg sm:rounded-xl flex items-center justify-center flex-shrink-0"
                   style="background-color: <%= primary_color %>15;">
                <svg class="w-4 h-4 sm:w-5 sm:h-5" style="color: <%= primary_color %>;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                </svg>
              </div>
              <span class="break-keep"><%= date&.strftime("%Y년 %m월 %d일 (%a)") || '날짜 미정' %></span>
            </h2>

            <div class="space-y-3 sm:space-y-4">
              <% day_matches.each do |match| %>
                <div class="bg-white rounded-xl sm:rounded-2xl p-4 sm:p-5 md:p-6 hover:shadow-md transition-shadow">
                  <%# Match Header %>
                  <div class="flex items-center justify-between mb-3 sm:mb-4">
                    <span class="text-xs sm:text-sm font-medium text-gray-500 truncate max-w-[120px] sm:max-w-none">
                      <%= match.round_name || match.round_display %>
                    </span>
                    <div class="flex items-center gap-2">
                      <% if match.scheduled_at.present? %>
                        <span class="text-xs sm:text-sm font-semibold" style="color: <%= primary_color %>;">
                          <%= match.scheduled_at.strftime("%H:%M") %>
                        </span>
                      <% end %>
                      <% if match.status_completed? %>
                        <span class="px-2 py-0.5 sm:px-2.5 sm:py-1 text-[10px] sm:text-xs font-semibold rounded-full bg-green-100 text-green-700 flex-shrink-0">종료</span>
                      <% elsif match.status_live? %>
                        <span class="px-2 py-0.5 sm:px-2.5 sm:py-1 text-[10px] sm:text-xs font-semibold rounded-full bg-red-100 text-red-600 animate-pulse flex-shrink-0">LIVE</span>
                      <% else %>
                        <span class="px-2 py-0.5 sm:px-2.5 sm:py-1 text-[10px] sm:text-xs font-semibold rounded-full flex-shrink-0"
                              style="background-color: <%= primary_color %>15; color: <%= primary_color %>;">
                          예정
                        </span>
                      <% end %>
                    </div>
                  </div>

                  <%# Teams & Score %>
                  <div class="flex items-center justify-between gap-2">
                    <%# Home Team %>
                    <div class="flex items-center gap-2 sm:gap-3 flex-1 min-w-0">
                      <% if match.home_team&.team&.logo_url.present? %>
                        <div class="w-10 h-10 sm:w-12 sm:h-12 rounded-lg sm:rounded-xl bg-gray-50 p-1.5 sm:p-2 flex items-center justify-center flex-shrink-0">
                          <img src="<%= match.home_team.team.logo_url %>" alt="" class="w-full h-full object-contain">
                        </div>
                      <% else %>
                        <div class="w-10 h-10 sm:w-12 sm:h-12 rounded-lg sm:rounded-xl flex items-center justify-center flex-shrink-0"
                             style="background-color: <%= primary_color %>15;">
                          <span class="text-sm sm:text-base font-bold" style="color: <%= primary_color %>;">
                            <%= match.home_team&.team&.name&.first&.upcase || '?' %>
                          </span>
                        </div>
                      <% end %>
                      <span class="text-sm sm:text-base font-semibold text-gray-900 truncate">
                        <%= match.home_team&.team&.name || 'TBD' %>
                      </span>
                    </div>

                    <%# Score %>
                    <div class="px-3 sm:px-6 text-center flex-shrink-0">
                      <% if match.status_completed? || match.status_live? %>
                        <div class="flex items-center gap-1 sm:gap-2">
                          <span class="text-lg sm:text-2xl md:text-3xl font-bold <%= match.home_score > match.away_score ? 'text-gray-900' : 'text-gray-400' %>">
                            <%= match.home_score %>
                          </span>
                          <span class="text-gray-300 text-base sm:text-lg">:</span>
                          <span class="text-lg sm:text-2xl md:text-3xl font-bold <%= match.away_score > match.home_score ? 'text-gray-900' : 'text-gray-400' %>">
                            <%= match.away_score %>
                          </span>
                        </div>
                      <% else %>
                        <span class="text-base sm:text-lg md:text-xl font-semibold text-gray-300">VS</span>
                      <% end %>
                    </div>

                    <%# Away Team %>
                    <div class="flex items-center gap-2 sm:gap-3 flex-1 min-w-0 justify-end">
                      <span class="text-sm sm:text-base font-semibold text-gray-900 truncate text-right">
                        <%= match.away_team&.team&.name || 'TBD' %>
                      </span>
                      <% if match.away_team&.team&.logo_url.present? %>
                        <div class="w-10 h-10 sm:w-12 sm:h-12 rounded-lg sm:rounded-xl bg-gray-50 p-1.5 sm:p-2 flex items-center justify-center flex-shrink-0">
                          <img src="<%= match.away_team.team.logo_url %>" alt="" class="w-full h-full object-contain">
                        </div>
                      <% else %>
                        <div class="w-10 h-10 sm:w-12 sm:h-12 rounded-lg sm:rounded-xl flex items-center justify-center flex-shrink-0"
                             style="background-color: <%= primary_color %>15;">
                          <span class="text-sm sm:text-base font-bold" style="color: <%= primary_color %>;">
                            <%= match.away_team&.team&.name&.first&.upcase || '?' %>
                          </span>
                        </div>
                      <% end %>
                    </div>
                  </div>

                  <%# Venue %>
                  <% if match.venue.present? %>
                    <div class="mt-3 sm:mt-4 pt-3 sm:pt-4 border-t border-gray-100">
                      <p class="text-xs sm:text-sm text-gray-500 flex items-center gap-1.5">
                        <svg class="w-3.5 h-3.5 sm:w-4 sm:h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                        </svg>
                        <span class="truncate"><%= match.venue.name %></span>
                      </p>
                    </div>
                  <% end %>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>
      <% else %>
        <div class="bg-white rounded-xl sm:rounded-2xl p-8 sm:p-12 text-center">
          <div class="w-14 h-14 sm:w-16 sm:h-16 rounded-xl sm:rounded-2xl mx-auto mb-3 sm:mb-4 flex items-center justify-center"
               style="background-color: <%= primary_color %>15;">
            <svg class="w-6 h-6 sm:w-8 sm:h-8" style="color: <%= primary_color %>;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
            </svg>
          </div>
          <h3 class="text-base sm:text-lg font-semibold text-gray-900 mb-1 sm:mb-2">아직 경기 일정이 없습니다</h3>
          <p class="text-sm sm:text-base text-gray-600">경기 일정이 확정되면 이곳에서 확인하실 수 있습니다.</p>
        </div>
      <% end %>
    </div>
  </section>
<% end %>

<%# Back to Home Link %>
<section class="bg-white py-8 sm:py-12">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <%= link_to site_home_path,
                class: "inline-flex items-center gap-2 text-sm sm:text-base font-semibold transition-colors hover:opacity-80",
                style: "color: #{primary_color};" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
      </svg>
      홈으로 돌아가기
    <% end %>
  </div>
</section>
