<%# Teams page template - Modern minimalist style with mobile optimization %>
<% tournament = @tournament_site.tournament %>
<% teams = tournament.tournament_teams.includes(:team).approved.order(:seed_number, :created_at) %>
<% primary_color = @tournament_site.primary_color || '#7C3AED' %>

<%# Page Header %>
<section class="bg-white py-12 sm:py-16 md:py-20">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <span class="inline-block px-3 py-1 sm:px-4 sm:py-1.5 text-xs sm:text-sm font-semibold rounded-full mb-4 sm:mb-6"
          style="color: <%= primary_color %>; background-color: <%= primary_color %>15;">
      Teams
    </span>
    <h1 class="text-2xl sm:text-3xl md:text-4xl font-bold text-gray-900 mb-3 sm:mb-4 break-keep"><%= page.title %></h1>
    <% if page.meta_description.present? %>
      <p class="text-base sm:text-lg text-gray-600 max-w-2xl mx-auto px-2"><%= page.meta_description %></p>
    <% else %>
      <p class="text-base sm:text-lg text-gray-600 max-w-2xl mx-auto px-2">총 <%= teams.count %>개 팀이 참가합니다.</p>
    <% end %>
  </div>
</section>

<%# Render custom sections %>
<% sections.each do |section| %>
  <%= render "tournament_sites/sections/#{section.section_type}", section: section %>
<% rescue ActionView::MissingTemplate %>
  <%= render "tournament_sites/sections/default", section: section %>
<% end %>

<%# Default teams content if no sections %>
<% if sections.empty? %>
  <section class="bg-gray-50 py-12 sm:py-16 md:py-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <% if teams.any? %>
        <%# Group by group_name if exists %>
        <% grouped_teams = teams.group_by(&:group_name) %>

        <% if grouped_teams.keys.compact.any? %>
          <%# Display by groups %>
          <% grouped_teams.each do |group_name, group_teams| %>
            <% if group_name.present? %>
              <div class="mb-10 sm:mb-12">
                <h2 class="text-base sm:text-lg font-bold text-gray-900 mb-4 sm:mb-6 pb-2 border-b border-gray-200 flex items-center gap-2">
                  <div class="w-8 h-8 sm:w-10 sm:h-10 rounded-lg sm:rounded-xl flex items-center justify-center flex-shrink-0"
                       style="background-color: <%= primary_color %>15;">
                    <span class="text-sm sm:text-base font-bold" style="color: <%= primary_color %>;"><%= group_name %></span>
                  </div>
                  <span><%= group_name %> 조</span>
                </h2>

                <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-4 sm:gap-6">
                  <% group_teams.each do |tournament_team| %>
                    <% team = tournament_team.team %>
                    <div class="bg-white rounded-xl sm:rounded-2xl p-4 sm:p-6 text-center hover:shadow-md transition-shadow group">
                      <div class="mb-3 sm:mb-4 flex justify-center">
                        <% if team.logo_url.present? %>
                          <div class="w-14 h-14 sm:w-16 sm:h-16 md:w-20 md:h-20 rounded-xl sm:rounded-2xl bg-gray-50 p-2 sm:p-3 flex items-center justify-center group-hover:shadow-md transition-shadow">
                            <img src="<%= team.logo_url %>" alt="<%= team.name %>" class="w-full h-full object-contain">
                          </div>
                        <% else %>
                          <div class="w-14 h-14 sm:w-16 sm:h-16 md:w-20 md:h-20 rounded-xl sm:rounded-2xl flex items-center justify-center group-hover:shadow-md transition-shadow"
                               style="background-color: <%= primary_color %>15;">
                            <span class="text-xl sm:text-2xl md:text-3xl font-bold" style="color: <%= primary_color %>;"><%= team.name.first.upcase %></span>
                          </div>
                        <% end %>
                      </div>
                      <h3 class="text-sm sm:text-base font-semibold text-gray-900 mb-1 sm:mb-2 truncate px-1"><%= team.name %></h3>
                      <div class="flex flex-wrap justify-center gap-1.5 sm:gap-2">
                        <% if tournament_team.seed_number.present? %>
                          <span class="inline-block px-2 py-0.5 sm:px-2.5 sm:py-1 text-[10px] sm:text-xs font-semibold rounded-full"
                                style="background-color: <%= primary_color %>15; color: <%= primary_color %>;">
                            시드 #<%= tournament_team.seed_number %>
                          </span>
                        <% end %>
                      </div>
                    </div>
                  <% end %>
                </div>
              </div>
            <% end %>
          <% end %>

          <%# Teams without group %>
          <% ungrouped = grouped_teams[nil] %>
          <% if ungrouped&.any? %>
            <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-4 sm:gap-6">
              <% ungrouped.each do |tournament_team| %>
                <% team = tournament_team.team %>
                <div class="bg-white rounded-xl sm:rounded-2xl p-4 sm:p-6 text-center hover:shadow-md transition-shadow group">
                  <div class="mb-3 sm:mb-4 flex justify-center">
                    <% if team.logo_url.present? %>
                      <div class="w-14 h-14 sm:w-16 sm:h-16 md:w-20 md:h-20 rounded-xl sm:rounded-2xl bg-gray-50 p-2 sm:p-3 flex items-center justify-center group-hover:shadow-md transition-shadow">
                        <img src="<%= team.logo_url %>" alt="<%= team.name %>" class="w-full h-full object-contain">
                      </div>
                    <% else %>
                      <div class="w-14 h-14 sm:w-16 sm:h-16 md:w-20 md:h-20 rounded-xl sm:rounded-2xl flex items-center justify-center group-hover:shadow-md transition-shadow"
                           style="background-color: <%= primary_color %>15;">
                        <span class="text-xl sm:text-2xl md:text-3xl font-bold" style="color: <%= primary_color %>;"><%= team.name.first.upcase %></span>
                      </div>
                    <% end %>
                  </div>
                  <h3 class="text-sm sm:text-base font-semibold text-gray-900 mb-1 sm:mb-2 truncate px-1"><%= team.name %></h3>
                  <div class="flex flex-wrap justify-center gap-1.5 sm:gap-2">
                    <% if tournament_team.seed_number.present? %>
                      <span class="inline-block px-2 py-0.5 sm:px-2.5 sm:py-1 text-[10px] sm:text-xs font-semibold rounded-full"
                            style="background-color: <%= primary_color %>15; color: <%= primary_color %>;">
                        시드 #<%= tournament_team.seed_number %>
                      </span>
                    <% end %>
                  </div>
                </div>
              <% end %>
            </div>
          <% end %>
        <% else %>
          <%# No groups - display all teams in grid %>
          <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-4 sm:gap-6">
            <% teams.each do |tournament_team| %>
              <% team = tournament_team.team %>
              <div class="bg-white rounded-xl sm:rounded-2xl p-4 sm:p-6 text-center hover:shadow-md transition-shadow group">
                <%# Team Logo %>
                <div class="mb-3 sm:mb-4 flex justify-center">
                  <% if team.logo_url.present? %>
                    <div class="w-14 h-14 sm:w-16 sm:h-16 md:w-20 md:h-20 rounded-xl sm:rounded-2xl bg-gray-50 p-2 sm:p-3 flex items-center justify-center group-hover:shadow-md transition-shadow">
                      <img src="<%= team.logo_url %>" alt="<%= team.name %>" class="w-full h-full object-contain">
                    </div>
                  <% else %>
                    <div class="w-14 h-14 sm:w-16 sm:h-16 md:w-20 md:h-20 rounded-xl sm:rounded-2xl flex items-center justify-center group-hover:shadow-md transition-shadow"
                         style="background-color: <%= primary_color %>15;">
                      <span class="text-xl sm:text-2xl md:text-3xl font-bold" style="color: <%= primary_color %>;"><%= team.name.first.upcase %></span>
                    </div>
                  <% end %>
                </div>

                <%# Team Name %>
                <h3 class="text-sm sm:text-base font-semibold text-gray-900 mb-1 sm:mb-2 truncate px-1"><%= team.name %></h3>

                <%# Seed & Group %>
                <div class="flex flex-wrap justify-center gap-1.5 sm:gap-2">
                  <% if tournament_team.seed_number.present? %>
                    <span class="inline-block px-2 py-0.5 sm:px-2.5 sm:py-1 text-[10px] sm:text-xs font-semibold rounded-full"
                          style="background-color: <%= primary_color %>15; color: <%= primary_color %>;">
                      시드 #<%= tournament_team.seed_number %>
                    </span>
                  <% end %>

                  <% if tournament_team.group_name.present? %>
                    <span class="inline-block px-2 py-0.5 sm:px-2.5 sm:py-1 text-[10px] sm:text-xs font-semibold rounded-full bg-gray-100 text-gray-600">
                      <%= tournament_team.group_name %> 조
                    </span>
                  <% end %>
                </div>

                <%# Team Description %>
                <% if team.description.present? %>
                  <p class="text-xs sm:text-sm text-gray-500 mt-2 sm:mt-3 line-clamp-2 px-1"><%= team.description %></p>
                <% end %>
              </div>
            <% end %>
          </div>
        <% end %>
      <% else %>
        <div class="bg-white rounded-xl sm:rounded-2xl p-8 sm:p-12 text-center">
          <div class="w-14 h-14 sm:w-16 sm:h-16 rounded-xl sm:rounded-2xl mx-auto mb-3 sm:mb-4 flex items-center justify-center"
               style="background-color: <%= primary_color %>15;">
            <svg class="w-6 h-6 sm:w-8 sm:h-8" style="color: <%= primary_color %>;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
          </div>
          <h3 class="text-base sm:text-lg font-semibold text-gray-900 mb-1 sm:mb-2">아직 확정된 참가팀이 없습니다</h3>
          <p class="text-sm sm:text-base text-gray-600">참가팀이 확정되면 이곳에서 확인하실 수 있습니다.</p>
        </div>
      <% end %>
    </div>
  </section>
<% end %>

<%# Back to Home Link %>
<section class="bg-white py-8 sm:py-12">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <%= link_to site_home_path,
                class: "inline-flex items-center gap-2 text-sm sm:text-base font-semibold transition-colors hover:opacity-80",
                style: "color: #{primary_color};" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
      </svg>
      홈으로 돌아가기
    <% end %>
  </div>
</section>
