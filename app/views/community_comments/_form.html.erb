<%= form_with model: [post, comment], id: "comment-form", class: "space-y-4" do |f| %>
  <% if comment.errors.any? %>
    <div class="bg-red-50 border border-red-200 rounded-lg p-4">
      <ul class="list-disc list-inside text-sm text-red-600">
        <% comment.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%= f.hidden_field :parent_id %>

  <div>
    <%= f.text_area :content,
        rows: 3,
        placeholder: "댓글을 작성하세요...",
        class: "w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-orange-500 focus:border-orange-500 resize-none" %>
  </div>

  <div class="flex justify-end">
    <%= f.submit "댓글 작성", class: "btn btn-primary" %>
  </div>
<% end %>
