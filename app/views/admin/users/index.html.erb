<% content_for :title, '사용자 관리' %>

<div class="px-4 sm:px-6 lg:px-8">
  <div class="sm:flex sm:items-center">
    <div class="sm:flex-auto">
      <h1 class="text-2xl font-semibold text-gray-900">사용자 관리</h1>
      <p class="mt-2 text-sm text-gray-700">등록된 모든 사용자를 관리합니다.</p>
    </div>
  </div>

  <!-- Filters -->
  <div class="mt-6 bg-white rounded-lg shadow p-4">
    <%= form_with url: admin_users_path, method: :get, class: "flex items-center gap-3" do |f| %>
      <div class="flex-[2]">
        <%= f.text_field :q, value: params[:q], placeholder: "이메일, 닉네임, 이름, 전화번호 검색...", class: "w-full h-10 px-3 text-sm rounded-md border border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 focus:ring-1" %>
      </div>
      <div class="flex-1">
        <%= f.select :status, options_for_select([["모든 상태", ""], ["활성", "active"], ["정지", "suspended"], ["탈퇴", "withdrawn"]], params[:status]), {}, class: "w-full h-10 pl-3 pr-8 text-sm rounded-md border border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 focus:ring-1" %>
      </div>
      <div class="flex-1">
        <%= f.select :membership, options_for_select([["모든 멤버십", ""], ["일반", "free"], ["프로", "pro"], ["픽업호스트", "pickup_host"], ["대회관리자", "tournament_admin"], ["슈퍼관리자", "super_admin"]], params[:membership]), {}, class: "w-full h-10 pl-3 pr-8 text-sm rounded-md border border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 focus:ring-1" %>
      </div>
      <div class="flex items-center flex-shrink-0">
        <%= f.check_box :admins_only, { checked: params[:admins_only] == "true", class: "h-4 w-4 rounded border-gray-300 text-indigo-600 focus:ring-indigo-500" }, "true", "false" %>
        <%= f.label :admins_only, "관리자만", class: "ml-2 text-sm text-gray-600 whitespace-nowrap" %>
      </div>
      <div class="flex items-center gap-2 flex-shrink-0">
        <%= f.submit "검색", class: "h-10 w-20 inline-flex items-center justify-center rounded-md bg-indigo-600 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 cursor-pointer transition-colors" %>
        <%= link_to "초기화", admin_users_path, class: "h-10 w-20 inline-flex items-center justify-center rounded-md bg-gray-100 text-sm font-semibold text-gray-700 shadow-sm hover:bg-gray-200 transition-colors" %>
      </div>
    <% end %>
  </div>

  <!-- Users List -->
  <div class="mt-6 bg-white shadow rounded-lg overflow-hidden">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">사용자</th>
          <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">연락처</th>
          <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">멤버십</th>
          <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">상태</th>
          <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">가입일</th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-gray-200">
        <% @users.each do |user| %>
          <tr class="hover:bg-indigo-50 cursor-pointer transition-colors" onclick="window.location='<%= admin_user_path(user) %>'">
            <td class="px-6 py-4 whitespace-nowrap">
              <div class="flex items-center">
                <div class="flex-shrink-0 h-10 w-10">
                  <div class="h-10 w-10 rounded-full bg-indigo-100 flex items-center justify-center">
                    <span class="text-indigo-600 font-medium"><%= user.display_name&.first || "?" %></span>
                  </div>
                </div>
                <div class="ml-4">
                  <div class="text-sm font-medium text-gray-900">
                    <%= user.display_name %>
                    <% if user.is_admin? %>
                      <span class="ml-1 inline-flex rounded-full px-2 text-xs font-semibold leading-5 bg-red-100 text-red-800">관리자</span>
                    <% end %>
                  </div>
                  <div class="text-sm text-gray-500"><%= user.email %></div>
                </div>
              </div>
            </td>
            <td class="px-6 py-4 whitespace-nowrap">
              <div class="text-sm text-gray-900"><%= user.phone || "-" %></div>
              <div class="text-sm text-gray-500"><%= [user.city, user.district].compact.join(" ") %></div>
            </td>
            <td class="px-6 py-4 whitespace-nowrap">
              <span class="inline-flex rounded-full px-2 text-xs font-semibold leading-5
                <%= case user.membership_type
                    when 'pro' then 'bg-yellow-100 text-yellow-800'
                    when 'pickup_host' then 'bg-blue-100 text-blue-800'
                    when 'tournament_admin' then 'bg-purple-100 text-purple-800'
                    when 'super_admin' then 'bg-red-100 text-red-800'
                    else 'bg-gray-100 text-gray-800'
                    end %>">
                <%= case user.membership_type
                    when 'free' then '일반'
                    when 'pro' then '프로'
                    when 'pickup_host' then '픽업호스트'
                    when 'tournament_admin' then '대회관리자'
                    when 'super_admin' then '슈퍼관리자'
                    else user.membership_type
                    end %>
              </span>
            </td>
            <td class="px-6 py-4 whitespace-nowrap">
              <span class="inline-flex rounded-full px-2 text-xs font-semibold leading-5
                <%= case user.status
                    when 'active' then 'bg-green-100 text-green-800'
                    when 'suspended' then 'bg-red-100 text-red-800'
                    when 'withdrawn' then 'bg-gray-100 text-gray-800'
                    else 'bg-gray-100 text-gray-800'
                    end %>">
                <%= case user.status
                    when 'active' then '활성'
                    when 'suspended' then '정지'
                    when 'withdrawn' then '탈퇴'
                    else user.status
                    end %>
              </span>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
              <%= l(user.created_at, format: :short) %>
            </td>
          </tr>
        <% end %>

        <% if @users.empty? %>
          <tr>
            <td colspan="5" class="px-6 py-12 text-center text-gray-500">
              사용자가 없습니다.
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>

    <% if @pagy && @pagy.pages > 1 %>
      <div class="bg-white px-4 py-3 border-t border-gray-200 sm:px-6">
        <%== pagy_nav(@pagy) %>
      </div>
    <% end %>
  </div>
</div>
