<% content_for :title, '매출 분석' %>

<div class="px-4 sm:px-6 lg:px-8">
  <!-- Header -->
  <div class="mb-6">
    <%= link_to admin_analytics_path, class: "inline-flex items-center text-sm text-gray-500 hover:text-gray-700" do %>
      <svg class="w-5 h-5 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
      분석 대시보드
    <% end %>
  </div>

  <div class="sm:flex sm:items-center sm:justify-between">
    <div class="sm:flex-auto">
      <h1 class="text-2xl font-semibold text-gray-900">매출 분석</h1>
      <p class="mt-2 text-sm text-gray-700">상세 매출 데이터를 분석합니다.</p>
    </div>
    <div class="mt-4 sm:mt-0">
      <%= form_with url: admin_analytics_revenue_path, method: :get, class: "flex items-center space-x-2" do |f| %>
        <%= f.select :period, options_for_select([["오늘", "today"], ["이번 주", "week"], ["이번 달", "month"], ["이번 분기", "quarter"], ["올해", "year"]], @period), {}, class: "rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500" %>
        <%= f.submit "조회", class: "inline-flex items-center rounded-md bg-indigo-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 cursor-pointer" %>
      <% end %>
    </div>
  </div>

  <!-- Summary Stats -->
  <div class="mt-6 grid grid-cols-2 gap-4 sm:grid-cols-4">
    <div class="bg-green-50 rounded-lg shadow p-4">
      <p class="text-sm text-green-600">총 매출</p>
      <p class="text-2xl font-semibold text-green-700"><%= number_to_currency(@revenue_data[:total], unit: '', precision: 0) %>원</p>
    </div>
    <div class="bg-blue-50 rounded-lg shadow p-4">
      <p class="text-sm text-blue-600">평균 결제액</p>
      <p class="text-2xl font-semibold text-blue-700"><%= number_to_currency(@revenue_data[:average_transaction], unit: '', precision: 0) %>원</p>
    </div>
    <div class="bg-purple-50 rounded-lg shadow p-4">
      <p class="text-sm text-purple-600">결제 건수</p>
      <p class="text-2xl font-semibold text-purple-700"><%= @revenue_data[:transaction_count] %>건</p>
    </div>
    <div class="bg-gray-50 rounded-lg shadow p-4">
      <p class="text-sm text-gray-600">기간</p>
      <p class="text-lg font-semibold text-gray-700">
        <%= case @period
            when "today" then "오늘"
            when "week" then "이번 주"
            when "month" then "이번 달"
            when "quarter" then "이번 분기"
            when "year" then "올해"
            else "이번 달"
            end %>
      </p>
    </div>
  </div>

  <div class="mt-8 grid grid-cols-1 gap-6 lg:grid-cols-2">
    <!-- Revenue by Payment Method -->
    <div class="bg-white shadow rounded-lg overflow-hidden">
      <div class="px-6 py-4 border-b border-gray-200">
        <h2 class="text-lg font-medium text-gray-900">결제 방법별 매출</h2>
      </div>
      <div class="px-6 py-4">
        <% if @revenue_data[:by_method].present? %>
          <dl class="space-y-4">
            <% @revenue_data[:by_method].each do |method, amount| %>
              <div class="flex items-center justify-between">
                <dt class="text-sm text-gray-500">
                  <%= case method
                      when 'card' then '신용카드'
                      when 'virtual_account' then '가상계좌'
                      when 'transfer' then '계좌이체'
                      else method || '기타'
                      end %>
                </dt>
                <dd class="text-sm font-medium text-gray-900"><%= number_to_currency(amount, unit: '', precision: 0) %>원</dd>
              </div>
              <% percentage = @revenue_data[:total] > 0 ? (amount.to_f / @revenue_data[:total] * 100).round(1) : 0 %>
              <div class="w-full bg-gray-200 rounded-full h-2">
                <div class="bg-indigo-600 h-2 rounded-full" style="width: <%= percentage %>%"></div>
              </div>
            <% end %>
          </dl>
        <% else %>
          <p class="text-center text-gray-500 py-8">데이터가 없습니다.</p>
        <% end %>
      </div>
    </div>

    <!-- Revenue by Type -->
    <div class="bg-white shadow rounded-lg overflow-hidden">
      <div class="px-6 py-4 border-b border-gray-200">
        <h2 class="text-lg font-medium text-gray-900">결제 유형별 매출</h2>
      </div>
      <div class="px-6 py-4">
        <% if @revenue_data[:by_type].present? %>
          <dl class="space-y-4">
            <% @revenue_data[:by_type].each do |type, amount| %>
              <div class="flex items-center justify-between">
                <dt class="text-sm text-gray-500"><%= type %></dt>
                <dd class="text-sm font-medium text-gray-900"><%= number_to_currency(amount, unit: '', precision: 0) %>원</dd>
              </div>
              <% percentage = @revenue_data[:total] > 0 ? (amount.to_f / @revenue_data[:total] * 100).round(1) : 0 %>
              <div class="w-full bg-gray-200 rounded-full h-2">
                <div class="bg-green-600 h-2 rounded-full" style="width: <%= percentage %>%"></div>
              </div>
            <% end %>
          </dl>
        <% else %>
          <p class="text-center text-gray-500 py-8">데이터가 없습니다.</p>
        <% end %>
      </div>
    </div>
  </div>

  <!-- Daily Revenue Table -->
  <div class="mt-8 bg-white shadow rounded-lg overflow-hidden">
    <div class="px-6 py-4 border-b border-gray-200">
      <h2 class="text-lg font-medium text-gray-900">일별 매출</h2>
    </div>
    <% if @revenue_data[:by_day].present? %>
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">날짜</th>
            <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">매출</th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          <% @revenue_data[:by_day].sort.reverse.each do |date, amount| %>
            <tr class="hover:bg-gray-50">
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900"><%= date %></td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-right font-medium text-gray-900"><%= number_to_currency(amount, unit: '', precision: 0) %>원</td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <div class="px-6 py-12 text-center text-gray-500">
        해당 기간의 매출 데이터가 없습니다.
      </div>
    <% end %>
  </div>
</div>
