<% content_for :title, '결제 관리' %>

<div class="px-4 sm:px-6 lg:px-8">
  <!-- Header -->
  <div class="sm:flex sm:items-center">
    <div class="sm:flex-auto">
      <h1 class="text-2xl font-semibold text-gray-900">결제 관리</h1>
      <p class="mt-2 text-sm text-gray-700">모든 결제 내역을 확인하고 관리합니다.</p>
    </div>
  </div>

  <!-- Stats -->
  <div class="mt-6 grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-5">
    <div class="bg-white rounded-lg shadow p-4">
      <p class="text-sm text-gray-500">전체 결제</p>
      <p class="text-2xl font-semibold text-gray-900"><%= number_with_delimiter(@stats[:total_count]) %></p>
    </div>
    <div class="bg-green-50 rounded-lg shadow p-4">
      <p class="text-sm text-green-600">총 매출</p>
      <p class="text-2xl font-semibold text-green-700"><%= number_to_currency(@stats[:total_amount], unit: '', precision: 0) %>원</p>
    </div>
    <div class="bg-blue-50 rounded-lg shadow p-4">
      <p class="text-sm text-blue-600">오늘 매출</p>
      <p class="text-2xl font-semibold text-blue-700"><%= number_to_currency(@stats[:today_amount], unit: '', precision: 0) %>원</p>
    </div>
    <div class="bg-yellow-50 rounded-lg shadow p-4">
      <p class="text-sm text-yellow-600">대기중</p>
      <p class="text-2xl font-semibold text-yellow-700"><%= @stats[:pending_count] %></p>
    </div>
    <div class="bg-red-50 rounded-lg shadow p-4">
      <p class="text-sm text-red-600">환불액</p>
      <p class="text-2xl font-semibold text-red-700"><%= number_to_currency(@stats[:refunded_amount], unit: '', precision: 0) %>원</p>
    </div>
  </div>

  <!-- Filters -->
  <div class="mt-6 bg-white rounded-lg shadow p-4">
    <%= form_with url: admin_payments_path, method: :get, class: "flex items-center gap-3" do |f| %>
      <div class="flex-[2]">
        <%= f.text_field :q, value: params[:q], placeholder: "결제코드, 주문ID, 이메일 검색...", class: "w-full h-10 px-3 text-sm rounded-md border border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 focus:ring-1" %>
      </div>
      <div class="flex-1">
        <%= f.select :status, options_for_select([["모든 상태", ""], ["대기중", "pending"], ["결제 준비", "ready"], ["진행중", "in_progress"], ["완료", "done"], ["취소", "cancelled"], ["환불됨", "refunded"]], params[:status]), {}, class: "w-full h-10 pl-3 pr-8 text-sm rounded-md border border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 focus:ring-1" %>
      </div>
      <div class="flex-1">
        <%= f.select :method, options_for_select([["모든 방법", ""], ["카드", "card"], ["가상계좌", "virtual_account"], ["계좌이체", "transfer"]], params[:method]), {}, class: "w-full h-10 pl-3 pr-8 text-sm rounded-md border border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 focus:ring-1" %>
      </div>
      <div class="flex-1">
        <%= f.date_field :date_from, value: params[:date_from], class: "w-full h-10 px-3 text-sm rounded-md border border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 focus:ring-1", placeholder: "시작일" %>
      </div>
      <div class="flex-1">
        <%= f.date_field :date_to, value: params[:date_to], class: "w-full h-10 px-3 text-sm rounded-md border border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 focus:ring-1", placeholder: "종료일" %>
      </div>
      <div class="flex items-center gap-2 flex-shrink-0">
        <%= f.submit "검색", class: "h-10 w-20 inline-flex items-center justify-center rounded-md bg-indigo-600 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 cursor-pointer transition-colors" %>
        <%= link_to "초기화", admin_payments_path, class: "h-10 w-20 inline-flex items-center justify-center rounded-md bg-gray-100 text-sm font-semibold text-gray-700 shadow-sm hover:bg-gray-200 transition-colors" %>
      </div>
    <% end %>
  </div>

  <!-- Payments List -->
  <div class="mt-6 bg-white shadow rounded-lg overflow-hidden">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">결제정보</th>
          <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">사용자</th>
          <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">결제대상</th>
          <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">금액</th>
          <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">방법</th>
          <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">상태</th>
          <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">결제일</th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-gray-200">
        <% @payments.each do |payment| %>
          <tr class="hover:bg-indigo-50 cursor-pointer transition-colors" onclick="window.location='<%= admin_payment_path(payment) %>'">
            <td class="px-6 py-4">
              <div class="text-sm font-medium text-gray-900"><%= payment.payment_code %></div>
              <div class="text-xs text-gray-500"><%= payment.order_id %></div>
            </td>
            <td class="px-6 py-4 whitespace-nowrap">
              <div class="text-sm text-gray-900"><%= payment.user&.display_name || "알 수 없음" %></div>
              <div class="text-xs text-gray-500"><%= payment.user&.email %></div>
            </td>
            <td class="px-6 py-4 whitespace-nowrap">
              <div class="text-sm text-gray-900"><%= payment.payable_type %></div>
              <div class="text-xs text-gray-500"><%= payment.payable_description rescue "-" %></div>
            </td>
            <td class="px-6 py-4 whitespace-nowrap">
              <div class="text-sm font-medium text-gray-900"><%= number_to_currency(payment.final_amount, unit: '', precision: 0) %>원</div>
              <% if payment.discount_amount.to_i > 0 %>
                <div class="text-xs text-red-500">-<%= number_to_currency(payment.discount_amount, unit: '', precision: 0) %>원 할인</div>
              <% end %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap">
              <span class="inline-flex rounded-full px-2 text-xs font-semibold leading-5
                <%= case payment.payment_method
                    when 'card' then 'bg-blue-100 text-blue-800'
                    when 'virtual_account' then 'bg-purple-100 text-purple-800'
                    when 'transfer' then 'bg-green-100 text-green-800'
                    else 'bg-gray-100 text-gray-800'
                    end %>">
                <%= payment.payment_method_label %>
              </span>
            </td>
            <td class="px-6 py-4 whitespace-nowrap">
              <span class="inline-flex rounded-full px-2 text-xs font-semibold leading-5
                <%= case payment.status
                    when 'pending', 'ready', 'in_progress' then 'bg-yellow-100 text-yellow-800'
                    when 'done' then 'bg-green-100 text-green-800'
                    when 'cancelled', 'aborted' then 'bg-red-100 text-red-800'
                    when 'refunded', 'partial_cancelled' then 'bg-orange-100 text-orange-800'
                    else 'bg-gray-100 text-gray-800'
                    end %>">
                <%= payment.status_label %>
              </span>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
              <%= payment.paid_at ? l(payment.paid_at, format: :short) : l(payment.created_at, format: :short) %>
            </td>
          </tr>
        <% end %>

        <% if @payments.empty? %>
          <tr>
            <td colspan="7" class="px-6 py-12 text-center text-gray-500">
              결제 내역이 없습니다.
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>

    <!-- Pagination -->
    <% if @pagy && @pagy.pages > 1 %>
      <div class="bg-white px-4 py-3 border-t border-gray-200 sm:px-6">
        <%== pagy_nav(@pagy) %>
      </div>
    <% end %>
  </div>
</div>
