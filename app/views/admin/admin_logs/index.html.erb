<% content_for :title, '관리자 로그' %>

<div class="px-4 sm:px-6 lg:px-8">
  <div class="sm:flex sm:items-center">
    <div class="sm:flex-auto">
      <h1 class="text-2xl font-semibold text-gray-900">관리자 로그</h1>
      <p class="mt-2 text-sm text-gray-700">모든 관리자 활동을 기록합니다.</p>
    </div>
  </div>

  <!-- Stats -->
  <div class="mt-6 grid grid-cols-2 gap-4 sm:grid-cols-4">
    <div class="bg-white rounded-lg shadow p-4">
      <p class="text-sm text-gray-500">오늘</p>
      <p class="text-2xl font-semibold text-gray-900"><%= @stats[:total_today] %></p>
    </div>
    <div class="bg-blue-50 rounded-lg shadow p-4">
      <p class="text-sm text-blue-600">이번 주</p>
      <p class="text-2xl font-semibold text-blue-700"><%= @stats[:total_week] %></p>
    </div>
    <div class="bg-red-50 rounded-lg shadow p-4">
      <p class="text-sm text-red-600">오늘 오류</p>
      <p class="text-2xl font-semibold text-red-700"><%= @stats[:errors_today] %></p>
    </div>
  </div>

  <!-- Filters -->
  <div class="mt-6 bg-white rounded-lg shadow p-4">
    <%= form_with url: admin_admin_logs_path, method: :get, class: "flex flex-wrap gap-4" do |f| %>
      <div class="flex-1 min-w-[200px]">
        <%= f.text_field :q, value: params[:q], placeholder: "설명 검색...", class: "w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500" %>
      </div>
      <div>
        <%= f.select :severity, options_for_select([["모든 심각도", ""], ["정보", "info"], ["경고", "warning"], ["오류", "error"], ["심각", "critical"]], params[:severity]), {}, class: "rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500" %>
      </div>
      <div>
        <%= f.date_field :date_from, value: params[:date_from], class: "rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500" %>
      </div>
      <div>
        <%= f.date_field :date_to, value: params[:date_to], class: "rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500" %>
      </div>
      <div>
        <%= f.submit "검색", class: "inline-flex items-center rounded-md bg-indigo-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 cursor-pointer" %>
        <%= link_to "초기화", admin_admin_logs_path, class: "inline-flex items-center rounded-md bg-gray-100 px-4 py-2 text-sm font-semibold text-gray-700 shadow-sm hover:bg-gray-200" %>
      </div>
    <% end %>
  </div>

  <!-- Logs List -->
  <div class="mt-6 bg-white shadow rounded-lg overflow-hidden">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">관리자</th>
          <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">액션</th>
          <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">설명</th>
          <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">심각도</th>
          <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">일시</th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-gray-200">
        <% @logs.each do |log| %>
          <tr class="hover:bg-gray-50">
            <td class="px-6 py-4 whitespace-nowrap">
              <div class="text-sm text-gray-900"><%= log.admin&.display_name || "시스템" %></div>
              <div class="text-xs text-gray-500"><%= log.ip_address %></div>
            </td>
            <td class="px-6 py-4 whitespace-nowrap">
              <span class="inline-flex rounded-full px-2 text-xs font-semibold leading-5 bg-blue-100 text-blue-800">
                <%= log.action %>
              </span>
            </td>
            <td class="px-6 py-4">
              <div class="text-sm text-gray-900"><%= truncate(log.description, length: 60) %></div>
              <% if log.resource_type.present? %>
                <div class="text-xs text-gray-500"><%= log.resource_type %>#<%= log.resource_id %></div>
              <% end %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap">
              <span class="inline-flex rounded-full px-2 text-xs font-semibold leading-5
                <%= case log.severity
                    when 'info' then 'bg-blue-100 text-blue-800'
                    when 'warning' then 'bg-yellow-100 text-yellow-800'
                    when 'error' then 'bg-red-100 text-red-800'
                    when 'critical' then 'bg-red-200 text-red-900'
                    else 'bg-gray-100 text-gray-800'
                    end %>">
                <%= log.severity %>
              </span>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
              <%= l(log.created_at, format: :short) %>
            </td>
          </tr>
        <% end %>

        <% if @logs.empty? %>
          <tr>
            <td colspan="5" class="px-6 py-12 text-center text-gray-500">
              로그가 없습니다.
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>

    <% if @pagy && @pagy.pages > 1 %>
      <div class="bg-white px-4 py-3 border-t border-gray-200 sm:px-6">
        <%== pagy_nav(@pagy) %>
      </div>
    <% end %>
  </div>
</div>
