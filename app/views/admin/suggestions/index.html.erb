<% content_for :title, '건의사항 관리' %>

<div class="px-4 sm:px-6 lg:px-8">
  <!-- Header -->
  <div class="sm:flex sm:items-center">
    <div class="sm:flex-auto">
      <h1 class="text-2xl font-semibold text-gray-900">건의사항 관리</h1>
      <p class="mt-2 text-sm text-gray-700">사용자 건의사항을 관리하고 답변합니다.</p>
    </div>
  </div>

  <!-- Stats -->
  <div class="mt-6 grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-6">
    <div class="bg-white rounded-lg shadow p-4">
      <p class="text-sm text-gray-500">전체</p>
      <p class="text-2xl font-semibold text-gray-900"><%= @stats[:total] %></p>
    </div>
    <div class="bg-yellow-50 rounded-lg shadow p-4">
      <p class="text-sm text-yellow-600">대기중</p>
      <p class="text-2xl font-semibold text-yellow-700"><%= @stats[:pending] %></p>
    </div>
    <div class="bg-blue-50 rounded-lg shadow p-4">
      <p class="text-sm text-blue-600">검토중</p>
      <p class="text-2xl font-semibold text-blue-700"><%= @stats[:in_review] %></p>
    </div>
    <div class="bg-indigo-50 rounded-lg shadow p-4">
      <p class="text-sm text-indigo-600">처리중</p>
      <p class="text-2xl font-semibold text-indigo-700"><%= @stats[:in_progress] %></p>
    </div>
    <div class="bg-green-50 rounded-lg shadow p-4">
      <p class="text-sm text-green-600">해결됨</p>
      <p class="text-2xl font-semibold text-green-700"><%= @stats[:resolved] %></p>
    </div>
    <div class="bg-red-50 rounded-lg shadow p-4">
      <p class="text-sm text-red-600">긴급</p>
      <p class="text-2xl font-semibold text-red-700"><%= @stats[:high_priority] %></p>
    </div>
  </div>

  <!-- Filters -->
  <div class="mt-6 bg-white rounded-lg shadow p-4">
    <%= form_with url: admin_suggestions_path, method: :get, class: "flex items-center gap-3" do |f| %>
      <div class="flex-[2]">
        <%= f.text_field :q, value: params[:q], placeholder: "검색...", class: "w-full h-10 px-3 text-sm rounded-md border border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 focus:ring-1" %>
      </div>
      <div class="flex-1">
        <%= f.select :status, options_for_select([["모든 상태", ""], ["대기중", "pending"], ["검토중", "in_review"], ["처리중", "in_progress"], ["해결됨", "resolved"], ["반려됨", "rejected"], ["종료", "closed"]], params[:status]), {}, class: "w-full h-10 pl-3 pr-8 text-sm rounded-md border border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 focus:ring-1" %>
      </div>
      <div class="flex-1">
        <%= f.select :category, options_for_select([["모든 카테고리", ""], ["일반", "general"], ["버그 신고", "bug_report"], ["기능 요청", "feature_request"], ["개선 제안", "improvement"], ["결제 관련", "payment"], ["대회 관련", "tournament"], ["팀 관련", "team"], ["기타", "other"]], params[:category]), {}, class: "w-full h-10 pl-3 pr-8 text-sm rounded-md border border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 focus:ring-1" %>
      </div>
      <div class="flex-1">
        <%= f.select :priority, options_for_select([["모든 우선순위", ""], ["낮음", "0"], ["보통", "1"], ["높음", "2"], ["긴급", "3"]], params[:priority]), {}, class: "w-full h-10 pl-3 pr-8 text-sm rounded-md border border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 focus:ring-1" %>
      </div>
      <div class="flex items-center gap-2 flex-shrink-0">
        <%= f.submit "검색", class: "h-10 w-20 inline-flex items-center justify-center rounded-md bg-indigo-600 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 cursor-pointer transition-colors" %>
        <%= link_to "초기화", admin_suggestions_path, class: "h-10 w-20 inline-flex items-center justify-center rounded-md bg-gray-100 text-sm font-semibold text-gray-700 shadow-sm hover:bg-gray-200 transition-colors" %>
      </div>
    <% end %>
  </div>

  <!-- Suggestions List -->
  <div class="mt-6 bg-white shadow rounded-lg overflow-hidden">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">제목</th>
          <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">작성자</th>
          <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">카테고리</th>
          <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">상태</th>
          <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">우선순위</th>
          <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">작성일</th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-gray-200">
        <% @suggestions.each do |suggestion| %>
          <tr class="hover:bg-indigo-50 cursor-pointer transition-colors" onclick="window.location='<%= admin_suggestion_path(suggestion) %>'">
            <td class="px-6 py-4">
              <div class="text-sm font-medium text-gray-900"><%= truncate(suggestion.title, length: 40) %></div>
              <div class="text-sm text-gray-500"><%= truncate(suggestion.content, length: 60) %></div>
            </td>
            <td class="px-6 py-4 whitespace-nowrap">
              <div class="text-sm text-gray-900"><%= suggestion.user&.display_name || "알 수 없음" %></div>
              <div class="text-sm text-gray-500"><%= suggestion.user&.email %></div>
            </td>
            <td class="px-6 py-4 whitespace-nowrap">
              <span class="inline-flex rounded-full px-2 text-xs font-semibold leading-5
                <%= case suggestion.category
                    when 'feature_request' then 'bg-blue-100 text-blue-800'
                    when 'bug_report' then 'bg-red-100 text-red-800'
                    when 'improvement' then 'bg-green-100 text-green-800'
                    when 'payment' then 'bg-purple-100 text-purple-800'
                    when 'tournament' then 'bg-indigo-100 text-indigo-800'
                    when 'team' then 'bg-cyan-100 text-cyan-800'
                    else 'bg-gray-100 text-gray-800'
                    end %>">
                <%= suggestion.category_label %>
              </span>
            </td>
            <td class="px-6 py-4 whitespace-nowrap">
              <span class="inline-flex rounded-full px-2 text-xs font-semibold leading-5 <%= suggestion.status_badge_class %>">
                <%= suggestion.status_label %>
              </span>
            </td>
            <td class="px-6 py-4 whitespace-nowrap">
              <span class="inline-flex rounded-full px-2 text-xs font-semibold leading-5 <%= suggestion.priority_badge_class %>">
                <%= suggestion.priority_label %>
              </span>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
              <%= l(suggestion.created_at, format: :short) %>
            </td>
          </tr>
        <% end %>

        <% if @suggestions.empty? %>
          <tr>
            <td colspan="6" class="px-6 py-12 text-center text-gray-500">
              건의사항이 없습니다.
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>

    <!-- Pagination -->
    <% if @pagy && @pagy.pages > 1 %>
      <div class="bg-white px-4 py-3 border-t border-gray-200 sm:px-6">
        <%== pagy_nav(@pagy) %>
      </div>
    <% end %>
  </div>
</div>
