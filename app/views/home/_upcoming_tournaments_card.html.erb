<%# Upcoming Tournaments Dashboard Card %>
<% upcoming_tournaments = Tournament.published.where('start_date > ?', Date.today).order(start_date: :asc).limit(3) %>

<div class="dashboard-card">
  <div class="flex items-center justify-between mb-4">
    <h3 class="text-lg font-semibold text-gray-900">다가오는 대회</h3>
    <%= link_to tournaments_path, class: "text-sm text-primary-600 font-medium" do %>
      전체보기
      <svg class="w-4 h-4 inline" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
      </svg>
    <% end %>
  </div>

  <% if upcoming_tournaments.any? %>
    <div class="space-y-3">
      <% upcoming_tournaments.each do |tournament| %>
        <%= link_to tournament_path(tournament), class: "block p-3 bg-gray-50 rounded-xl hover:bg-gray-100 transition-colors" do %>
          <div class="flex items-center gap-3">
            <% if tournament.logo.attached? %>
              <%= image_tag tournament.logo, class: "w-14 h-14 rounded-lg object-cover" %>
            <% else %>
              <div class="w-14 h-14 bg-gradient-to-br from-purple-500 to-purple-600 rounded-lg flex items-center justify-center">
                <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16.5 18.75h-9m9 0a3 3 0 013 3h-15a3 3 0 013-3m9 0v-3.375c0-.621-.503-1.125-1.125-1.125h-.871M7.5 18.75v-3.375c0-.621.504-1.125 1.125-1.125h.872m5.007 0H9.497m5.007 0a7.454 7.454 0 01-.982-3.172M9.497 14.25a7.454 7.454 0 00.981-3.172"/>
                </svg>
              </div>
            <% end %>
            <div class="flex-1 min-w-0">
              <p class="font-medium text-gray-900 truncate"><%= tournament.name %></p>
              <p class="text-sm text-gray-500 mt-0.5">
                <span class="inline-flex items-center gap-1">
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                  </svg>
                  <%= tournament.start_date.strftime("%m/%d") %> ~ <%= tournament.end_date.strftime("%m/%d") %>
                </span>
              </p>
              <div class="flex items-center gap-2 mt-1">
                <% if tournament.status == "registration_open" %>
                  <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-700">
                    접수중
                  </span>
                <% else %>
                  <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-600">
                    <%= tournament.status == "upcoming" ? "접수예정" : tournament.status %>
                  </span>
                <% end %>
                <span class="text-xs text-gray-400">
                  <%= tournament.tournament_teams.approved.count %>/<%= tournament.max_teams || "무제한" %>팀
                </span>
              </div>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <div class="text-center py-8">
      <div class="w-12 h-12 mx-auto bg-gray-100 rounded-full flex items-center justify-center mb-3">
        <svg class="w-6 h-6 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16.5 18.75h-9m9 0a3 3 0 013 3h-15a3 3 0 013-3m9 0v-3.375c0-.621-.503-1.125-1.125-1.125h-.871M7.5 18.75v-3.375c0-.621.504-1.125 1.125-1.125h.872m5.007 0H9.497"/>
        </svg>
      </div>
      <p class="text-gray-500 text-sm">예정된 대회가 없어요</p>
      <%= link_to "대회 둘러보기", tournaments_path, class: "inline-flex items-center mt-2 text-sm text-primary-600 font-medium" %>
    </div>
  <% end %>
</div>
