<%# Recommended Games Section %>
<section class="px-4 mb-6">
  <div class="flex items-center justify-between mb-4">
    <h2 class="text-lg font-bold text-gray-900">추천 경기</h2>
    <%= link_to games_path, class: "text-blue-600 text-sm font-medium flex items-center gap-1" do %>
      전체보기
      <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5"/>
      </svg>
    <% end %>
  </div>

  <div class="space-y-3">
    <% if @recommended_games.present? && @recommended_games.any? %>
      <% @recommended_games.each do |game| %>
        <%= link_to game_path(game), class: "block bg-white rounded-2xl p-4 shadow-sm border border-gray-100 hover:shadow-md transition-shadow" do %>
          <div class="flex items-start justify-between mb-3">
            <span class="px-3 py-1 rounded-full text-xs font-medium
                         <%= game.game_type_pickup? ? 'bg-green-100 text-green-700' : 'bg-purple-100 text-purple-700' %>">
              <%= game.game_type_name %>
            </span>
            <% if game.skill_level.present? %>
              <span class="text-xs text-gray-400"><%= game.skill_level_name %></span>
            <% end %>
          </div>

          <h3 class="font-bold text-gray-900 mb-3"><%= game.title.presence || game.game_type_name %></h3>

          <div class="space-y-2 text-sm text-gray-500">
            <div class="flex items-center gap-2">
              <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/>
              </svg>
              <span class="truncate"><%= game.location_display %></span>
            </div>
            <div class="flex items-center gap-2">
              <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
              <span><%= game.scheduled_at.strftime("%m/%d (%a) %H:%M") %></span>
            </div>
            <div class="flex items-center gap-2">
              <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z"/>
              </svg>
              <span><%= game.current_participants %>/<%= game.max_participants %>명</span>
              <% if game.full? %>
                <span class="text-xs text-red-500 font-medium">마감</span>
              <% elsif game.remaining_spots <= 3 %>
                <span class="text-xs text-orange-500 font-medium"><%= game.remaining_spots %>자리 남음</span>
              <% end %>
            </div>
          </div>
        <% end %>
      <% end %>
    <% else %>
      <div class="bg-gray-50 rounded-2xl p-6 text-center">
        <div class="w-12 h-12 bg-gray-100 rounded-full flex items-center justify-center mx-auto mb-3">
          <svg class="w-6 h-6 text-gray-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5"/>
          </svg>
        </div>
        <p class="text-gray-500 text-sm">예정된 경기가 없어요</p>
        <p class="text-gray-400 text-xs mt-1">나중에 다시 확인해주세요</p>
      </div>
    <% end %>
  </div>
</section>
