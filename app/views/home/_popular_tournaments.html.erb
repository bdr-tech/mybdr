<%# Popular Tournaments Section %>
<section class="px-4 mb-6">
  <div class="flex items-center justify-between mb-4">
    <h2 class="text-lg font-bold text-gray-900">&#128293; 인기 대회</h2>
    <%= link_to tournaments_path, class: "text-blue-600 text-sm font-medium flex items-center gap-1" do %>
      전체보기
      <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5"/>
      </svg>
    <% end %>
  </div>

  <div class="space-y-3">
    <% if @popular_tournaments.present? && @popular_tournaments.any? %>
      <% @popular_tournaments.each do |tournament| %>
        <%= link_to tournament_path(tournament), class: "block bg-white rounded-2xl p-4 border border-gray-100 hover:shadow-md transition-shadow" do %>
          <div class="flex gap-4">
            <%# Tournament Icon/Logo %>
            <div class="w-20 h-20 bg-gradient-to-br from-orange-400 to-orange-500 rounded-xl flex items-center justify-center flex-shrink-0 shadow-lg shadow-orange-500/20">
              <% if tournament.has_logo? %>
                <img src="<%= tournament.logo_image_url %>" alt="<%= tournament.name %>" class="w-full h-full object-cover rounded-xl">
              <% else %>
                <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 18.75h-9m9 0a3 3 0 013 3h-15a3 3 0 013-3m9 0v-3.375c0-.621-.503-1.125-1.125-1.125h-.871M7.5 18.75v-3.375c0-.621.504-1.125 1.125-1.125h.872m5.007 0H9.497m5.007 0a7.454 7.454 0 01-.982-3.172M9.497 14.25a7.454 7.454 0 00.981-3.172M5.25 4.236c-.982.143-1.954.317-2.916.52A6.003 6.003 0 007.73 9.728M5.25 4.236V4.5c0 2.108.966 3.99 2.48 5.228M5.25 4.236V2.721C7.456 2.41 9.71 2.25 12 2.25c2.291 0 4.545.16 6.75.47v1.516M7.73 9.728a6.726 6.726 0 002.748 1.35m8.272-6.842V4.5c0 2.108-.966 3.99-2.48 5.228m2.48-5.492a46.32 46.32 0 012.916.52 6.003 6.003 0 01-5.395 4.972m0 0a6.726 6.726 0 01-2.749 1.35m0 0a6.772 6.772 0 01-3.044 0"/>
                </svg>
              <% end %>
            </div>

            <div class="flex-1 min-w-0">
              <%# D-Day Badge %>
              <% if tournament.start_date.present? && tournament.start_date.to_date > Date.current %>
                <% days_until = (tournament.start_date.to_date - Date.current).to_i %>
                <span class="text-xs text-orange-500 font-medium">D-<%= days_until %></span>
              <% elsif tournament.status_registration_open? %>
                <span class="text-xs text-green-500 font-medium">모집중</span>
              <% end %>

              <h3 class="font-bold text-gray-900 mt-1 truncate"><%= tournament.name %></h3>
              <p class="text-sm text-gray-500 mt-1">참가팀 <%= tournament.teams_count %>/<%= tournament.max_teams %></p>

              <div class="flex items-center gap-3 mt-2 text-xs text-gray-400">
                <% if tournament.city.present? %>
                  <span class="flex items-center gap-1">
                    <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/>
                      <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/>
                    </svg>
                    <%= tournament.city %>
                  </span>
                <% end %>
                <% if tournament.entry_fee.present? && tournament.entry_fee > 0 %>
                  <span><%= number_to_currency(tournament.entry_fee, unit: "원", precision: 0) %></span>
                <% end %>
              </div>
            </div>
          </div>
        <% end %>
      <% end %>
    <% else %>
      <div class="bg-gray-50 rounded-2xl p-6 text-center">
        <div class="w-12 h-12 bg-gray-100 rounded-full flex items-center justify-center mx-auto mb-3">
          <svg class="w-6 h-6 text-gray-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 18.75h-9m9 0a3 3 0 013 3h-15a3 3 0 013-3m9 0v-3.375c0-.621-.503-1.125-1.125-1.125h-.871M7.5 18.75v-3.375c0-.621.504-1.125 1.125-1.125h.872m5.007 0H9.497m5.007 0a7.454 7.454 0 01-.982-3.172M9.497 14.25a7.454 7.454 0 00.981-3.172"/>
          </svg>
        </div>
        <p class="text-gray-500 text-sm">등록 가능한 대회가 없어요</p>
        <p class="text-gray-400 text-xs mt-1">새로운 대회가 열리면 알려드릴게요</p>
      </div>
    <% end %>
  </div>
</section>
