<%# My Teams Dashboard Card %>
<% team_ids = current_user.team_memberships.pluck(:team_id) %>
<% my_teams = Team.where(id: team_ids).includes(:team_members).order(created_at: :desc).limit(3) %>

<div class="dashboard-card">
  <div class="flex items-center justify-between mb-4">
    <h3 class="text-lg font-semibold text-gray-900">내 팀</h3>
    <%= link_to teams_path, class: "text-sm text-primary-600 font-medium" do %>
      전체보기
      <svg class="w-4 h-4 inline" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
      </svg>
    <% end %>
  </div>

  <% if my_teams.any? %>
    <div class="space-y-3">
      <% my_teams.each do |team| %>
        <%= link_to team_path(team), class: "block p-3 bg-gray-50 rounded-xl hover:bg-gray-100 transition-colors" do %>
          <div class="flex items-center gap-3">
            <% if team.logo.attached? %>
              <%= image_tag team.logo, class: "w-10 h-10 rounded-lg object-cover" %>
            <% else %>
              <div class="w-10 h-10 bg-gradient-to-br from-primary-500 to-primary-600 rounded-lg flex items-center justify-center">
                <span class="text-white font-bold text-sm"><%= team.name.first(2) %></span>
              </div>
            <% end %>
            <div class="flex-1 min-w-0">
              <p class="font-medium text-gray-900 truncate"><%= team.name %></p>
              <p class="text-sm text-gray-500">
                <span class="inline-flex items-center gap-1">
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/>
                  </svg>
                  <%= team.team_members.count %>명
                </span>
                <% if team.captain == current_user %>
                  <span class="ml-2 inline-flex items-center px-1.5 py-0.5 rounded text-xs font-medium bg-amber-100 text-amber-700">
                    주장
                  </span>
                <% end %>
              </p>
            </div>
            <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
          </div>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <div class="text-center py-8">
      <div class="w-12 h-12 mx-auto bg-gray-100 rounded-full flex items-center justify-center mb-3">
        <svg class="w-6 h-6 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z"/>
        </svg>
      </div>
      <p class="text-gray-500 text-sm">가입한 팀이 없어요</p>
      <%= link_to "팀 찾기", teams_path, class: "inline-flex items-center mt-2 text-sm text-primary-600 font-medium" %>
    </div>
  <% end %>
</div>
