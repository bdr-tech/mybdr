<% content_for :full_width do %>true<% end %>

<%# Hero Section %>
<section class="bg-gradient-to-br from-primary-600 via-primary-700 to-primary-800 text-white">
  <div class="container-app py-16 lg:py-24">
    <div class="max-w-3xl">
      <h1 class="text-4xl lg:text-6xl font-bold tracking-tight leading-tight">
        농구를 사랑하는<br>
        모든 사람들을 위한<br>
        <span class="text-cream-200">경기 매칭 플랫폼</span>
      </h1>
      <p class="mt-6 text-lg lg:text-xl text-primary-100 max-w-xl">
        경기 참가부터 팀 관리, 대회 개최까지.<br>
        BDR에서 당신의 농구 라이프를 시작하세요.
      </p>
      <div class="mt-8 flex flex-wrap gap-4">
        <% if logged_in? %>
          <%= link_to games_path, class: "btn btn-lg bg-white text-primary-700 hover:bg-gray-100" do %>
            경기 찾기
            <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
            </svg>
          <% end %>
        <% else %>
          <%= link_to signup_path, class: "btn btn-lg bg-white text-primary-700 hover:bg-gray-100" do %>
            무료로 시작하기
            <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
            </svg>
          <% end %>
          <%= link_to "자세히 알아보기", "#features", class: "btn btn-lg bg-transparent border-2 border-white/30 text-white hover:bg-white/10" %>
        <% end %>
      </div>
    </div>
  </div>
</section>

<%# Stats Section %>
<section class="bg-white py-12 border-b border-gray-100">
  <div class="container-app">
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-8">
      <div class="text-center">
        <div class="text-3xl lg:text-4xl font-bold text-primary-600">10,000+</div>
        <div class="mt-2 text-gray-500">등록 사용자</div>
      </div>
      <div class="text-center">
        <div class="text-3xl lg:text-4xl font-bold text-primary-600">500+</div>
        <div class="mt-2 text-gray-500">등록 팀</div>
      </div>
      <div class="text-center">
        <div class="text-3xl lg:text-4xl font-bold text-primary-600">2,000+</div>
        <div class="mt-2 text-gray-500">진행된 경기</div>
      </div>
      <div class="text-center">
        <div class="text-3xl lg:text-4xl font-bold text-primary-600">50+</div>
        <div class="mt-2 text-gray-500">개최된 대회</div>
      </div>
    </div>
  </div>
</section>

<%# Features Section %>
<section id="features" class="py-16 lg:py-24 bg-gray-50">
  <div class="container-app">
    <div class="text-center mb-12">
      <h2 class="text-3xl lg:text-4xl font-bold text-gray-900">BDR의 주요 기능</h2>
      <p class="mt-4 text-gray-500 max-w-2xl mx-auto">
        경기 참가부터 대회 개최까지, 농구에 필요한 모든 것을 제공합니다
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <%# Feature 1 %>
      <div class="card-interactive">
        <div class="w-12 h-12 bg-primary-100 rounded-xl flex items-center justify-center mb-4">
          <svg class="w-6 h-6 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
          </svg>
        </div>
        <h3 class="text-lg font-semibold text-gray-900">경기 매칭</h3>
        <p class="mt-2 text-gray-500 text-sm">
          픽업게임, 연습경기, 친선경기 등 다양한 경기를 찾고 참가하세요
        </p>
      </div>

      <%# Feature 2 %>
      <div class="card-interactive">
        <div class="w-12 h-12 bg-secondary-100 rounded-xl flex items-center justify-center mb-4">
          <svg class="w-6 h-6 text-secondary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>
          </svg>
        </div>
        <h3 class="text-lg font-semibold text-gray-900">팀 관리</h3>
        <p class="mt-2 text-gray-500 text-sm">
          나만의 팀을 만들고 팀원을 관리하세요. 팀 전적과 통계도 확인할 수 있어요
        </p>
      </div>

      <%# Feature 3 %>
      <div class="card-interactive">
        <div class="w-12 h-12 bg-purple-100 rounded-xl flex items-center justify-center mb-4">
          <svg class="w-6 h-6 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
          </svg>
        </div>
        <h3 class="text-lg font-semibold text-gray-900">대회 참가</h3>
        <p class="mt-2 text-gray-500 text-sm">
          지역 대회 정보를 확인하고 팀으로 참가하세요. NBA 스타일 박스스코어 제공
        </p>
      </div>

      <%# Feature 4 %>
      <div class="card-interactive">
        <div class="w-12 h-12 bg-green-100 rounded-xl flex items-center justify-center mb-4">
          <svg class="w-6 h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
          </svg>
        </div>
        <h3 class="text-lg font-semibold text-gray-900">코트 정보</h3>
        <p class="mt-2 text-gray-500 text-sm">
          전국 농구장 정보를 검색하고 리뷰를 확인하세요. GPS 기반 주변 코트 찾기
        </p>
      </div>

      <%# Feature 5 %>
      <div class="card-interactive">
        <div class="w-12 h-12 bg-blue-100 rounded-xl flex items-center justify-center mb-4">
          <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
          </svg>
        </div>
        <h3 class="text-lg font-semibold text-gray-900">개인 통계</h3>
        <p class="mt-2 text-gray-500 text-sm">
          경기 기록을 분석하고 나의 농구 성향을 확인하세요. 성장 과정을 한눈에
        </p>
      </div>

      <%# Feature 6 %>
      <div class="card-interactive">
        <div class="w-12 h-12 bg-amber-100 rounded-xl flex items-center justify-center mb-4">
          <svg class="w-6 h-6 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
          </svg>
        </div>
        <h3 class="text-lg font-semibold text-gray-900">커뮤니티</h3>
        <p class="mt-2 text-gray-500 text-sm">
          농구 이야기를 나누고, 중고 장비를 거래하고, 레슨을 받아보세요
        </p>
      </div>
    </div>
  </div>
</section>

<%# Membership Section %>
<section class="py-16 lg:py-24 bg-white">
  <div class="container-app">
    <div class="text-center mb-12">
      <h2 class="text-3xl lg:text-4xl font-bold text-gray-900">멤버십 플랜</h2>
      <p class="mt-4 text-gray-500">필요에 맞는 플랜을 선택하세요</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 max-w-6xl mx-auto">
      <%# Free %>
