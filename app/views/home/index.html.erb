</section>

<%# CTA Section %>
<section class="py-16 lg:py-24 bg-gray-900 text-white">
  <div class="container-app text-center">
    <h2 class="text-3xl lg:text-4xl font-bold">지금 바로 시작하세요</h2>
    <p class="mt-4 text-gray-400 max-w-xl mx-auto">
      10,000명 이상의 농구인들이 BDR과 함께하고 있습니다
    </p>
    <div class="mt-8">
      <%= link_to signup_path, class: "btn btn-lg bg-primary-600 text-white hover:bg-primary-700" do %>
        무료로 회원가입
        <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
        </svg>
      <% end %>
    </div>
  </div>
</section>
