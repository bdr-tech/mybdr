            <span class="text-3xl font-bold text-gray-900">3,900</span>
            <span class="text-gray-500">원/월</span>
          </div>
        </div>
        <ul class="mt-6 space-y-3">
          <li class="flex items-start gap-2 text-sm text-gray-600">
