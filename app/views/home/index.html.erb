<% content_for :title, "BDR - 농구 경기 매칭 플랫폼" %>

<% if logged_in? %>
  <%# ===== Logged In User View ===== %>
  <div class="min-h-screen bg-gray-50 pb-20">
    <%# Header with Greeting %>
    <div class="bg-white border-b border-gray-100 px-4 py-4">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-gray-500 text-sm">안녕하세요,</p>
          <h1 class="text-xl font-bold text-gray-900"><%= current_user.nickname || current_user.name %>님</h1>
        </div>
        <%= link_to profile_path, class: "relative" do %>
          <% if current_user.avatar.attached? %>
            <%= image_tag current_user.avatar, class: "w-10 h-10 rounded-full object-cover ring-2 ring-gray-100" %>
          <% else %>
            <div class="w-10 h-10 bg-gradient-to-br from-primary-500 to-primary-600 rounded-full flex items-center justify-center ring-2 ring-gray-100">
              <span class="text-white font-semibold text-sm"><%= (current_user.nickname || current_user.name).first %></span>
            </div>
          <% end %>
          <% if current_user.notifications.unread.any? %>
            <span class="absolute -top-1 -right-1 w-3 h-3 bg-primary-500 rounded-full border-2 border-white"></span>
          <% end %>
        <% end %>
      </div>
    </div>

    <%# Admin Mode Toggle (if applicable) %>
    <% if current_user.show_admin_mode? %>
      <%= render "shared/admin_mode_toggle" %>
    <% end %>

    <%# Quick Actions Grid %>
    <section class="px-4 pt-4">
      <div class="grid grid-cols-3 gap-3">
        <%= render "home/quick_action", icon: "search", label: "경기", path: games_path %>
        <%= render "home/quick_action", icon: "trophy", label: "대회", path: tournaments_path %>
        <%= render "home/quick_action", icon: "community", label: "커뮤니티", path: community_path %>
      </div>

      <%# Admin Mode - Additional Quick Actions %>
      <% if current_user.admin_mode_active? %>
        <div class="grid grid-cols-2 gap-3 mt-3">
          <% if current_user.can_access_pickup_menu? %>
            <%= render "home/quick_action", icon: "calendar-plus", label: "경기 생성", path: new_game_path, variant: "admin" %>
          <% end %>
          <% if current_user.can_create_tournament? %>
            <%= render "home/quick_action", icon: "trophy-plus", label: "대회 생성", path: tournament_admin_root_path, variant: "admin" %>
          <% end %>
        </div>
      <% end %>
    </section>

    <%# Dashboard Cards %>
    <section class="px-4 pt-6 space-y-4">
      <%= render "home/my_games_card" %>
      <%= render "home/my_teams_card" %>
      <%= render "home/upcoming_tournaments_card" %>
    </section>

    <%# Community Preview %>
    <section class="px-4 pt-6 pb-4">
      <div class="dashboard-card">
        <div class="flex items-center justify-between mb-4">
          <h3 class="text-lg font-semibold text-gray-900">게시판</h3>
          <%= link_to community_path, class: "text-sm text-primary-600 font-medium" do %>
            전체보기
            <svg class="w-4 h-4 inline" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
          <% end %>
        </div>

        <% recent_posts = CommunityPost.published.order(created_at: :desc).limit(3) %>
        <% if recent_posts.any? %>
          <div class="space-y-3">
            <% recent_posts.each do |post| %>
              <%= link_to community_post_path(post), class: "block p-3 bg-gray-50 rounded-xl hover:bg-gray-100 transition-colors" do %>
                <div class="flex items-start gap-3">
                  <div class="flex-shrink-0 w-8 h-8 bg-gray-200 rounded-lg flex items-center justify-center text-gray-500">
                    <%= render "shared/category_icon", category: post.category %>
                  </div>
                  <div class="flex-1 min-w-0">
                    <p class="font-medium text-gray-900 truncate text-sm"><%= post.title %></p>
                    <p class="text-xs text-gray-500 mt-0.5">
                      <%= CommunityPost.category_label(post.category) %>
                      <span class="mx-1">·</span>
                      <%= time_ago_in_words(post.created_at) %> 전
                    </p>
                  </div>
                  <div class="flex items-center gap-2 text-xs text-gray-400">
                    <span class="flex items-center gap-0.5">
                      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
                      </svg>
                      <%= post.comments_count || 0 %>
                    </span>
                  </div>
                </div>
              <% end %>
            <% end %>
          </div>
        <% else %>
          <div class="text-center py-6">
            <p class="text-gray-500 text-sm">아직 게시글이 없어요</p>
          </div>
        <% end %>
      </div>
    </section>
  </div>

<% else %>
  <%# ===== Non-Logged In User View (Onboarding Complete) ===== %>
  <div class="min-h-screen bg-gray-50 pb-20">
    <%# Hero Section %>
    <div class="pt-4">
      <%= render "home/hero_section" %>
    </div>

    <%# Recommended Games %>
    <%= render "home/recommended_games" %>

    <%# Popular Tournaments %>
    <%= render "home/popular_tournaments" %>

    <%# Guest CTA %>
    <%= render "home/guest_cta" %>
  </div>
<% end %>

<%# Auth Bottom Sheet %>
<%= render "shared/auth_bottom_sheet" %>
