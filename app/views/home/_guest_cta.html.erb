<%# Guest CTA - Call to Action for non-logged in users %>
<% unless logged_in? %>
  <section class="px-4 mb-6">
    <div class="bg-gradient-to-br from-gray-100 to-gray-50 rounded-2xl p-6 text-center">
      <div class="w-14 h-14 bg-white rounded-2xl flex items-center justify-center mx-auto mb-4 shadow-sm">
        <svg class="w-7 h-7 text-blue-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z"/>
        </svg>
      </div>
      <h3 class="font-bold text-gray-900 mb-2">회원가입하고 시작하세요</h3>
      <p class="text-gray-500 text-sm mb-5">
        경기 참가, 팀 생성, 대회 등록까지<br/>
        BDR의 모든 기능을 이용해보세요
      </p>
      <button onclick="document.dispatchEvent(new CustomEvent('bottom-sheet:open', {detail: {target: 'auth'}}))"
              class="w-full px-6 py-3.5 bg-blue-600 text-white rounded-xl font-semibold
                     hover:bg-blue-700 transition-colors active:scale-[0.98] transform">
        무료로 시작하기
      </button>
    </div>
  </section>
<% end %>
