<%# Notification Item Partial %>
<div class="flex items-start p-4 hover:bg-gray-50 transition <%= notification.unread? ? 'bg-indigo-50/50' : '' %>">
  <!-- Icon -->
  <div class="flex-shrink-0">
    <div class="w-10 h-10 rounded-full flex items-center justify-center <%= notification_icon_bg_class(notification) %>">
      <%= render_notification_icon(notification) %>
    </div>
  </div>

  <!-- Content -->
  <div class="ml-4 flex-1 min-w-0">
    <div class="flex items-center justify-between">
      <p class="text-sm font-medium text-gray-900 <%= notification.unread? ? 'font-semibold' : '' %>">
        <%= notification.title %>
      </p>
      <% if notification.unread? %>
        <span class="w-2 h-2 bg-indigo-600 rounded-full flex-shrink-0 ml-2"></span>
      <% end %>
    </div>
    <p class="mt-1 text-sm text-gray-600 line-clamp-2"><%= notification.content %></p>
    <div class="mt-2 flex items-center justify-between">
      <div class="flex items-center space-x-2">
        <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium <%= notification_badge_class(notification) %>">
          <%= notification.notification_type_label %>
        </span>
        <span class="text-xs text-gray-400">
          <%= time_ago_in_words(notification.created_at) %> 전
        </span>
      </div>
      <div class="flex items-center space-x-2">
        <% if notification.action_url.present? %>
          <%= link_to visit_notification_path(notification), class: "text-xs text-indigo-600 hover:text-indigo-800 font-medium", data: { turbo: false } do %>
            바로가기
            <svg class="inline w-3 h-3 ml-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          <% end %>
        <% end %>
        <% if notification.unread? %>
          <%= button_to mark_as_read_notification_path(notification), method: :post, class: "text-xs text-gray-400 hover:text-gray-600", data: { turbo: false } do %>
            읽음
          <% end %>
        <% end %>
      </div>
    </div>
  </div>
</div>
