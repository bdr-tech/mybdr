<% content_for :title, @notification.title %>

<div class="max-w-2xl mx-auto px-4 py-8">
  <!-- Back Link -->
  <div class="mb-6">
    <%= link_to notifications_path, class: "inline-flex items-center text-sm text-gray-500 hover:text-gray-700" do %>
      <svg class="w-5 h-5 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
      알림 목록
    <% end %>
  </div>

  <!-- Notification Card -->
  <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
    <!-- Header -->
    <div class="px-6 py-4 border-b border-gray-100 <%= notification_icon_bg_class(@notification) %>">
      <div class="flex items-center">
        <div class="w-12 h-12 rounded-full flex items-center justify-center bg-white/80">
          <%= render_notification_icon(@notification, size: "large") %>
        </div>
        <div class="ml-4">
          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium <%= notification_badge_class(@notification) %>">
            <%= @notification.notification_type_label %>
          </span>
          <p class="mt-1 text-xs text-gray-500">
            <%= @notification.created_at.strftime("%Y년 %m월 %d일 %H:%M") %>
          </p>
        </div>
      </div>
    </div>

    <!-- Content -->
    <div class="px-6 py-6">
      <h1 class="text-xl font-bold text-gray-900"><%= @notification.title %></h1>
      <p class="mt-4 text-gray-600 leading-relaxed"><%= @notification.content %></p>

      <% if @notification.metadata.present? %>
        <div class="mt-6 p-4 bg-gray-50 rounded-lg">
          <h3 class="text-sm font-medium text-gray-700 mb-2">상세 정보</h3>
          <dl class="space-y-1">
            <% @notification.metadata.each do |key, value| %>
              <% next if value.blank? %>
              <div class="flex text-sm">
                <dt class="text-gray-500 w-24"><%= notification_metadata_label(key) %></dt>
                <dd class="text-gray-900"><%= value %></dd>
              </div>
            <% end %>
          </dl>
        </div>
      <% end %>
    </div>

    <!-- Actions -->
    <% if @notification.action_url.present? %>
      <div class="px-6 py-4 bg-gray-50 border-t border-gray-100">
        <%= link_to @notification.action_url, class: "inline-flex items-center px-4 py-2 bg-indigo-600 text-white text-sm font-medium rounded-lg hover:bg-indigo-700 transition" do %>
          <%= action_button_label(@notification) %>
          <svg class="ml-2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
          </svg>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
