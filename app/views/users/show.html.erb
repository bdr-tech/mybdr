<% content_for :title do %>프로필 - <%= @user.display_name %> - BDR<% end %>
<% content_for :full_width do %>yes<% end %>

<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8" data-controller="tabs" data-tabs-default-tab-value="info">
  <%# Profile Header Card %>
  <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden mb-6">
    <%# Banner Background %>
    <div class="h-32 bg-gradient-to-r from-indigo-500 via-purple-500 to-pink-500"></div>

    <%# Profile Content %>
    <div class="px-6 pb-6">
      <%# Avatar & Actions Row %>
      <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between -mt-16 mb-4">
        <%# Avatar %>
        <div class="flex items-end gap-4">
          <div class="relative">
            <div class="w-28 h-28 rounded-2xl border-4 border-white shadow-lg bg-white overflow-hidden">
              <% if @user.avatar.attached? %>
                <%= image_tag @user.avatar, alt: @user.display_name, class: "w-full h-full object-cover" %>
              <% elsif @user.profile_image.present? %>
                <img src="<%= @user.profile_image %>" alt="<%= @user.display_name %>" class="w-full h-full object-cover">
              <% else %>
                <div class="w-full h-full bg-gradient-to-br from-indigo-400 to-purple-500 flex items-center justify-center">
                  <span class="text-4xl font-bold text-white"><%= @user.display_name[0].upcase %></span>
                </div>
              <% end %>
            </div>
            <% if @user.subscription_active? %>
              <div class="absolute -bottom-1 -right-1 w-8 h-8 bg-yellow-400 rounded-lg flex items-center justify-center shadow-sm border-2 border-white">
                <svg class="w-4 h-4 text-yellow-900" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"/>
                </svg>
              </div>
            <% end %>
          </div>
          <div class="hidden sm:block pb-2">
            <span class="<%= @user.membership_badge_class %>"><%= @user.membership_label %></span>
          </div>
        </div>

        <%# Edit Button & Admin Links %>
        <% if @user == current_user %>
          <div class="mt-4 sm:mt-0 flex flex-wrap gap-2">
            <%# Tournament Admin Dashboard Link %>
            <% if current_user.can_create_tournament? || current_user.administrated_tournaments.any? %>
              <%= link_to tournament_admin_root_path, class: "inline-flex items-center px-4 py-2 bg-primary-600 border border-primary-600 rounded-xl text-sm font-medium text-white hover:bg-primary-700 transition shadow-sm" do %>
                <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
                </svg>
                대회 관리
              <% end %>
            <% end %>
            <%= link_to profile_edit_path, class: "inline-flex items-center px-4 py-2 bg-white border border-gray-200 rounded-xl text-sm font-medium text-gray-700 hover:bg-gray-50 hover:border-gray-300 transition shadow-sm" do %>
              <svg class="w-4 h-4 mr-2 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
              </svg>
              프로필 수정
            <% end %>
          </div>
        <% end %>
      </div>

      <%# User Info %>
      <div class="mb-6">
        <h1 class="text-2xl font-bold text-gray-900"><%= @user.display_name %></h1>
        <p class="text-gray-500 mt-1"><%= @user.email %></p>
        <div class="mt-3 flex flex-wrap gap-2 sm:hidden">
          <span class="<%= @user.membership_badge_class %>"><%= @user.membership_label %></span>
        </div>
        <div class="mt-2 flex flex-wrap gap-2">
          <% if @user.position.present? %>
            <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-blue-50 text-blue-700">
              <svg class="w-3 h-3 mr-1" fill="currentColor" viewBox="0 0 24 24">
                <circle cx="12" cy="12" r="10"/>
              </svg>
              <%= @user.position_label %>
            </span>
          <% end %>
          <% if @user.city.present? %>
            <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-gray-100 text-gray-600">
              <svg class="w-3 h-3 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
              <%= @user.city %>
            </span>
          <% end %>
        </div>
        <% if @user.bio.present? %>
          <p class="mt-4 text-gray-600 leading-relaxed"><%= @user.bio %></p>
        <% end %>
      </div>

      <%# Stats Grid %>
      <div class="grid grid-cols-4 gap-3">
        <div class="bg-gradient-to-br from-indigo-50 to-indigo-100 rounded-xl p-3 text-center">
          <div class="text-xl font-bold text-indigo-700"><%= @user_stats[:pickup][:approved_games] %></div>
          <div class="text-xs text-indigo-600/80 font-medium">픽업 경기</div>
        </div>
        <div class="bg-gradient-to-br from-purple-50 to-purple-100 rounded-xl p-3 text-center">
          <div class="text-xl font-bold text-purple-700"><%= @user_stats[:tournaments_participated] %></div>
          <div class="text-xs text-purple-600/80 font-medium">대회 참가</div>
        </div>
        <div class="bg-gradient-to-br from-emerald-50 to-emerald-100 rounded-xl p-3 text-center">
          <div class="text-xl font-bold text-emerald-700"><%= @user_stats[:teams_count] %></div>
          <div class="text-xs text-emerald-600/80 font-medium">소속 팀</div>
        </div>
        <div class="bg-gradient-to-br from-amber-50 to-amber-100 rounded-xl p-3 text-center">
          <div class="text-xl font-bold text-amber-700"><%= number_with_precision(@user.evaluation_rating || 0, precision: 1) %></div>
          <div class="text-xs text-amber-600/80 font-medium">평점</div>
        </div>
      </div>
    </div>
  </div>

  <%# Tab Navigation %>
  <div class="bg-white rounded-xl shadow-sm border border-gray-100 mb-6">
    <div class="flex overflow-x-auto">
      <button class="flex-1 px-4 py-4 text-sm font-medium border-b-2 transition whitespace-nowrap text-indigo-600 border-indigo-600 bg-indigo-50/50"
              data-tabs-target="tab"
              data-tabs-name="info"
              data-action="click->tabs#switch">
        기본 정보
      </button>
      <button class="flex-1 px-4 py-4 text-sm font-medium border-b-2 transition whitespace-nowrap text-gray-500 border-transparent hover:text-gray-700 hover:border-gray-200"
              data-tabs-target="tab"
              data-tabs-name="games"
              data-action="click->tabs#switch">
        경기 기록
      </button>
      <button class="flex-1 px-4 py-4 text-sm font-medium border-b-2 transition whitespace-nowrap text-gray-500 border-transparent hover:text-gray-700 hover:border-gray-200"
              data-tabs-target="tab"
              data-tabs-name="tournaments"
              data-action="click->tabs#switch">
        대회 기록
      </button>
      <button class="flex-1 px-4 py-4 text-sm font-medium border-b-2 transition whitespace-nowrap text-gray-500 border-transparent hover:text-gray-700 hover:border-gray-200"
              data-tabs-target="tab"
              data-tabs-name="teams"
              data-action="click->tabs#switch">
        소속 팀
      </button>
      <button class="flex-1 px-4 py-4 text-sm font-medium border-b-2 transition whitespace-nowrap text-gray-500 border-transparent hover:text-gray-700 hover:border-gray-200"
              data-tabs-target="tab"
              data-tabs-name="stats"
              data-action="click->tabs#switch">
        통계
      </button>
    </div>
  </div>

  <%# Tab Panels %>
  <%# 기본 정보 탭 %>
  <div data-tabs-target="panel" data-tabs-panel="info">
    <%= render "users/tab_info", user: @user %>
  </div>

  <%# 경기 기록 탭 %>
  <div data-tabs-target="panel" data-tabs-panel="games" class="hidden">
    <%= render "users/tab_games", user: @user, game_applications: @game_applications %>
  </div>

  <%# 대회 기록 탭 %>
  <div data-tabs-target="panel" data-tabs-panel="tournaments" class="hidden">
    <%= render "users/tab_tournaments", user: @user, tournament_participations: @tournament_participations %>
  </div>

  <%# 소속 팀 탭 %>
  <div data-tabs-target="panel" data-tabs-panel="teams" class="hidden">
    <%= render "users/tab_teams", user: @user, team_memberships: @team_memberships %>
  </div>

  <%# 통계 탭 %>
  <div data-tabs-target="panel" data-tabs-panel="stats" class="hidden">
    <%= render "users/tab_stats", user: @user, user_stats: @user_stats %>
  </div>
</div>
