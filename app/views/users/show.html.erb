<% content_for :title do %>프로필 - <%= @user.display_name %> - BDR<% end %>
<% content_for :full_width do %>yes<% end %>

<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <%# Profile Header Card %>
  <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden mb-6">
    <%# Banner Background %>
    <div class="h-32 bg-gradient-to-r from-indigo-500 via-purple-500 to-pink-500"></div>

    <%# Profile Content %>
    <div class="px-6 pb-6">
      <%# Avatar & Actions Row %>
      <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between -mt-16 mb-4">
        <%# Avatar %>
        <div class="flex items-end gap-4">
          <div class="relative">
            <div class="w-28 h-28 rounded-2xl border-4 border-white shadow-lg bg-white overflow-hidden">
              <% if @user.avatar.attached? %>
                <%= image_tag @user.avatar, alt: @user.display_name, class: "w-full h-full object-cover" %>
              <% elsif @user.profile_image.present? %>
                <img src="<%= @user.profile_image %>" alt="<%= @user.display_name %>" class="w-full h-full object-cover">
              <% else %>
                <div class="w-full h-full bg-gradient-to-br from-indigo-400 to-purple-500 flex items-center justify-center">
                  <span class="text-4xl font-bold text-white"><%= @user.display_name[0].upcase %></span>
                </div>
              <% end %>
            </div>
            <% if @user.subscription_active? %>
              <div class="absolute -bottom-1 -right-1 w-8 h-8 bg-yellow-400 rounded-lg flex items-center justify-center shadow-sm border-2 border-white">
                <svg class="w-4 h-4 text-yellow-900" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"/>
                </svg>
              </div>
            <% end %>
          </div>
          <div class="hidden sm:block pb-2">
            <span class="<%= @user.membership_badge_class %>"><%= @user.membership_label %></span>
          </div>
        </div>

        <%# Edit Button %>
        <% if @user == current_user %>
          <div class="mt-4 sm:mt-0">
            <%= link_to profile_edit_path, class: "inline-flex items-center px-4 py-2 bg-white border border-gray-200 rounded-xl text-sm font-medium text-gray-700 hover:bg-gray-50 hover:border-gray-300 transition shadow-sm" do %>
              <svg class="w-4 h-4 mr-2 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
              </svg>
              프로필 수정
            <% end %>
          </div>
        <% end %>
      </div>

      <%# User Info %>
      <div class="mb-6">
        <h1 class="text-2xl font-bold text-gray-900"><%= @user.display_name %></h1>
        <p class="text-gray-500 mt-1"><%= @user.email %></p>
        <div class="mt-3 flex flex-wrap gap-2 sm:hidden">
          <span class="<%= @user.membership_badge_class %>"><%= @user.membership_label %></span>
        </div>
        <div class="mt-2 flex flex-wrap gap-2">
          <% if @user.position.present? %>
            <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-blue-50 text-blue-700">
              <svg class="w-3 h-3 mr-1" fill="currentColor" viewBox="0 0 24 24">
                <circle cx="12" cy="12" r="10"/>
              </svg>
              <%= @user.position_label %>
            </span>
          <% end %>
          <% if @user.city.present? %>
            <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-gray-100 text-gray-600">
              <svg class="w-3 h-3 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
              <%= @user.city %>
            </span>
          <% end %>
        </div>
        <% if @user.bio.present? %>
          <p class="mt-4 text-gray-600 leading-relaxed"><%= @user.bio %></p>
        <% end %>
      </div>

      <%# Stats Grid %>
      <div class="grid grid-cols-3 gap-4">
        <div class="bg-gradient-to-br from-indigo-50 to-indigo-100 rounded-xl p-4 text-center">
          <div class="w-10 h-10 mx-auto mb-2 rounded-full bg-indigo-500/10 flex items-center justify-center">
            <svg class="w-5 h-5 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
            </svg>
          </div>
          <div class="text-2xl font-bold text-indigo-700"><%= @user.total_games_participated %></div>
          <div class="text-xs text-indigo-600/80 font-medium">참가 경기</div>
        </div>
        <div class="bg-gradient-to-br from-purple-50 to-purple-100 rounded-xl p-4 text-center">
          <div class="w-10 h-10 mx-auto mb-2 rounded-full bg-purple-500/10 flex items-center justify-center">
            <svg class="w-5 h-5 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/>
            </svg>
          </div>
          <div class="text-2xl font-bold text-purple-700"><%= @user.total_games_hosted %></div>
          <div class="text-xs text-purple-600/80 font-medium">주최 경기</div>
        </div>
        <div class="bg-gradient-to-br from-amber-50 to-amber-100 rounded-xl p-4 text-center">
          <div class="w-10 h-10 mx-auto mb-2 rounded-full bg-amber-500/10 flex items-center justify-center">
            <svg class="w-5 h-5 text-amber-600" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"/>
            </svg>
          </div>
          <div class="text-2xl font-bold text-amber-700"><%= number_with_precision(@user.evaluation_rating || 0, precision: 1) %></div>
          <div class="text-xs text-amber-600/80 font-medium">평점</div>
        </div>
      </div>
    </div>
  </div>

  <%# Tab Navigation %>
  <div class="bg-white rounded-xl shadow-sm border border-gray-100 mb-6">
    <div class="flex overflow-x-auto">
      <button class="flex-1 px-6 py-4 text-sm font-medium text-indigo-600 border-b-2 border-indigo-600 bg-indigo-50/50">
        기본 정보
      </button>
      <button class="flex-1 px-6 py-4 text-sm font-medium text-gray-500 hover:text-gray-700 border-b-2 border-transparent hover:border-gray-200 transition">
        경기 기록
      </button>
      <button class="flex-1 px-6 py-4 text-sm font-medium text-gray-500 hover:text-gray-700 border-b-2 border-transparent hover:border-gray-200 transition">
        소속 팀
      </button>
      <button class="flex-1 px-6 py-4 text-sm font-medium text-gray-500 hover:text-gray-700 border-b-2 border-transparent hover:border-gray-200 transition">
        통계
      </button>
    </div>
  </div>

  <%# Basic Info Cards %>
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <%# Personal Info %>
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
      <div class="px-6 py-4 border-b border-gray-100 bg-gray-50/50">
        <h3 class="font-semibold text-gray-900 flex items-center">
          <svg class="w-5 h-5 mr-2 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
          </svg>
          개인 정보
        </h3>
      </div>
      <div class="divide-y divide-gray-100">
        <div class="px-6 py-4 flex justify-between items-center">
          <span class="text-sm text-gray-500">이름</span>
          <span class="text-sm font-medium text-gray-900"><%= @user.name || "-" %></span>
        </div>
        <div class="px-6 py-4 flex justify-between items-center">
          <span class="text-sm text-gray-500">닉네임</span>
          <span class="text-sm font-medium text-gray-900"><%= @user.nickname || "-" %></span>
        </div>
        <div class="px-6 py-4 flex justify-between items-center">
          <span class="text-sm text-gray-500">전화번호</span>
          <span class="text-sm font-medium text-gray-900"><%= @user.formatted_phone || "-" %></span>
        </div>
        <div class="px-6 py-4 flex justify-between items-center">
          <span class="text-sm text-gray-500">지역</span>
          <span class="text-sm font-medium text-gray-900"><%= @user.full_address.presence || "-" %></span>
        </div>
      </div>
    </div>

    <%# Basketball Profile %>
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
      <div class="px-6 py-4 border-b border-gray-100 bg-gray-50/50">
        <h3 class="font-semibold text-gray-900 flex items-center">
          <svg class="w-5 h-5 mr-2 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          농구 프로필
        </h3>
      </div>
      <div class="divide-y divide-gray-100">
        <div class="px-6 py-4 flex justify-between items-center">
          <span class="text-sm text-gray-500">포지션</span>
          <% if @user.position.present? %>
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800">
              <%= @user.position_label %>
            </span>
          <% else %>
            <span class="text-sm font-medium text-gray-900">-</span>
          <% end %>
        </div>
        <div class="px-6 py-4 flex justify-between items-center">
          <span class="text-sm text-gray-500">키</span>
          <span class="text-sm font-medium text-gray-900"><%= @user.height ? "#{@user.height}cm" : "-" %></span>
        </div>
        <div class="px-6 py-4 flex justify-between items-center">
          <span class="text-sm text-gray-500">몸무게</span>
          <span class="text-sm font-medium text-gray-900"><%= @user.weight ? "#{@user.weight}kg" : "-" %></span>
        </div>
        <div class="px-6 py-4 flex justify-between items-center">
          <span class="text-sm text-gray-500">생년월일</span>
          <span class="text-sm font-medium text-gray-900"><%= @user.birth_date ? l(@user.birth_date, format: :long) : "-" %></span>
        </div>
      </div>
    </div>
  </div>

  <%# Membership Info (only for self) %>
  <% if @user == current_user %>
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden mt-6">
      <div class="px-6 py-4 border-b border-gray-100 bg-gradient-to-r from-indigo-50 to-purple-50">
        <h3 class="font-semibold text-gray-900 flex items-center">
          <svg class="w-5 h-5 mr-2 text-indigo-500" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"/>
          </svg>
          멤버십 정보
        </h3>
      </div>
      <div class="p-6">
        <div class="flex items-center justify-between mb-4">
          <span class="text-sm text-gray-500">현재 등급</span>
          <span class="<%= @user.membership_badge_class %>"><%= @user.membership_label %></span>
        </div>

        <% if @user.subscription_active? && @user.subscription_expires_at %>
          <div class="flex items-center justify-between mb-4 pb-4 border-b border-gray-100">
            <span class="text-sm text-gray-500">만료일</span>
            <div class="text-right">
              <span class="text-sm font-medium text-gray-900"><%= l(@user.subscription_expires_at, format: :long) %></span>
              <span class="block text-xs text-indigo-600 font-medium"><%= @user.days_until_subscription_expires %>일 남음</span>
            </div>
          </div>
        <% end %>

        <% unless @user.membership_type_super_admin? %>
          <div class="mt-4 p-4 bg-gradient-to-r from-indigo-500 to-purple-600 rounded-xl text-white">
            <div class="flex items-center justify-between">
              <div>
                <p class="font-medium">프리미엄으로 업그레이드</p>
                <p class="text-sm text-indigo-100">더 많은 기능을 이용해보세요</p>
              </div>
              <%= link_to "#", class: "px-4 py-2 bg-white text-indigo-600 font-medium text-sm rounded-lg hover:bg-indigo-50 transition" do %>
                업그레이드
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <%# Payment Info (only for self) %>
  <% if @user == current_user && (@user.bank_name.present? || @user.toss_id.present?) %>
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden mt-6">
      <div class="px-6 py-4 border-b border-gray-100 bg-gray-50/50">
        <h3 class="font-semibold text-gray-900 flex items-center">
          <svg class="w-5 h-5 mr-2 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/>
          </svg>
          결제 정보
        </h3>
      </div>
      <div class="divide-y divide-gray-100">
        <% if @user.bank_name.present? && @user.account_number.present? %>
          <div class="px-6 py-4 flex items-center justify-between">
            <div>
              <span class="text-xs text-gray-500 block mb-1">계좌번호</span>
              <span class="text-sm font-medium text-gray-900"><%= @user.bank_name %> <%= @user.account_number %></span>
              <% if @user.account_holder.present? %>
                <span class="text-sm text-gray-400 ml-1">(<%= @user.account_holder %>)</span>
              <% end %>
            </div>
            <button type="button"
                    class="inline-flex items-center px-3 py-1.5 bg-gray-100 hover:bg-gray-200 text-gray-700 text-xs font-medium rounded-lg transition"
                    data-controller="clipboard"
                    data-clipboard-text="<%= @user.account_info_for_copy %>"
                    data-action="click->clipboard#copy">
              <svg class="w-3.5 h-3.5 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/>
              </svg>
              복사
            </button>
          </div>
        <% end %>

        <% if @user.toss_id.present? %>
          <div class="px-6 py-4">
            <span class="text-xs text-gray-500 block mb-1">토스 아이디</span>
            <span class="text-sm font-medium text-gray-900"><%= @user.toss_id %></span>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>
</div>
