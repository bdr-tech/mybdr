<% content_for :title do %>회원가입 - BDR<% end %>

<div class="container-narrow py-8">
  <div class="card max-w-md mx-auto">
    <%# Header %>
    <div class="text-center mb-8">
      <div class="w-12 h-12 bg-primary-600 rounded-xl flex items-center justify-center mx-auto mb-4">
        <svg class="w-7 h-7 text-white" fill="currentColor" viewBox="0 0 24 24">
          <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2" fill="none"/>
        </svg>
      </div>
      <h1 class="text-2xl font-bold text-gray-900">회원가입</h1>
      <p class="mt-2 text-gray-500">BDR과 함께 농구 라이프를 시작하세요</p>
    </div>

    <%# Social Login %>
    <div class="space-y-3">
      <%# Google Login %>
      <%= link_to "/auth/google_oauth2", method: :post, class: "flex items-center justify-center gap-3 w-full px-4 py-3 bg-white border border-gray-300 rounded-xl text-gray-700 font-medium hover:bg-gray-50 hover:border-gray-400 transition-all shadow-sm", data: { turbo: false } do %>
        <svg class="w-5 h-5" viewBox="0 0 24 24">
          <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
          <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
          <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
          <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
        </svg>
        Google로 시작하기
      <% end %>

      <%# Kakao Login (개발중) %>
      <button type="button" disabled class="flex items-center justify-center gap-3 w-full px-4 py-3 bg-[#FEE500] border border-[#FEE500] rounded-xl text-[#3C1E1E] font-medium opacity-50 cursor-not-allowed relative">
        <svg class="w-5 h-5" viewBox="0 0 24 24">
          <path fill="#3C1E1E" d="M12 3c5.799 0 10.5 3.664 10.5 8.185 0 4.52-4.701 8.184-10.5 8.184a13.5 13.5 0 0 1-1.727-.11l-4.408 2.883c-.501.265-.678.236-.472-.413l.892-3.678c-2.88-1.46-4.785-3.99-4.785-6.866C1.5 6.665 6.201 3 12 3z"/>
        </svg>
        카카오로 시작하기
        <span class="absolute -top-2 -right-2 bg-amber-500 text-white text-xs px-2 py-0.5 rounded-full">개발중</span>
      </button>
    </div>

    <%# Info %>
    <p class="mt-8 text-center text-xs text-gray-400">
      가입 시
      <a href="#" class="text-primary-600 hover:underline">이용약관</a> 및
      <a href="#" class="text-primary-600 hover:underline">개인정보처리방침</a>에 동의하게 됩니다.
    </p>

    <%# Login Link %>
    <p class="mt-4 text-center text-sm text-gray-500">
      이미 계정이 있으신가요?
      <%= link_to "로그인", login_path, class: "font-semibold text-primary-600 hover:text-primary-700" %>
    </p>
  </div>
</div>
