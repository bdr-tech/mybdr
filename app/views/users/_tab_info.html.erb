<%# 기본 정보 탭 %>
<div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
  <%# Personal Info %>
  <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
    <div class="px-6 py-4 border-b border-gray-100 bg-gray-50/50">
      <h3 class="font-semibold text-gray-900 flex items-center">
        <svg class="w-5 h-5 mr-2 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
        </svg>
        개인 정보
      </h3>
    </div>
    <div class="divide-y divide-gray-100">
      <div class="px-6 py-4 flex justify-between items-center">
        <span class="text-sm text-gray-500">이름</span>
        <span class="text-sm font-medium text-gray-900"><%= user.name || "-" %></span>
      </div>
      <div class="px-6 py-4 flex justify-between items-center">
        <span class="text-sm text-gray-500">닉네임</span>
        <span class="text-sm font-medium text-gray-900"><%= user.nickname || "-" %></span>
      </div>
      <div class="px-6 py-4 flex justify-between items-center">
        <span class="text-sm text-gray-500">전화번호</span>
        <span class="text-sm font-medium text-gray-900"><%= user.formatted_phone || "-" %></span>
      </div>
      <div class="px-6 py-4 flex justify-between items-center">
        <span class="text-sm text-gray-500">지역</span>
        <span class="text-sm font-medium text-gray-900"><%= user.full_address.presence || "-" %></span>
      </div>
    </div>
  </div>

  <%# Basketball Profile %>
  <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
    <div class="px-6 py-4 border-b border-gray-100 bg-gray-50/50">
      <h3 class="font-semibold text-gray-900 flex items-center">
        <svg class="w-5 h-5 mr-2 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/>
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        농구 프로필
      </h3>
    </div>
    <div class="divide-y divide-gray-100">
      <div class="px-6 py-4 flex justify-between items-center">
        <span class="text-sm text-gray-500">포지션</span>
        <% if user.position.present? %>
          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800">
            <%= user.position_label %>
          </span>
        <% else %>
          <span class="text-sm font-medium text-gray-900">-</span>
        <% end %>
      </div>
      <div class="px-6 py-4 flex justify-between items-center">
        <span class="text-sm text-gray-500">키</span>
        <span class="text-sm font-medium text-gray-900"><%= user.height ? "#{user.height}cm" : "-" %></span>
      </div>
      <div class="px-6 py-4 flex justify-between items-center">
        <span class="text-sm text-gray-500">몸무게</span>
        <span class="text-sm font-medium text-gray-900"><%= user.weight ? "#{user.weight}kg" : "-" %></span>
      </div>
      <div class="px-6 py-4 flex justify-between items-center">
        <span class="text-sm text-gray-500">생년월일</span>
        <span class="text-sm font-medium text-gray-900"><%= user.birth_date ? l(user.birth_date, format: :long) : "-" %></span>
      </div>
    </div>
  </div>
</div>

<%# Membership Info (only for self) %>
<% if user == current_user %>
  <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden mt-6">
    <div class="px-6 py-4 border-b border-gray-100 bg-gradient-to-r from-indigo-50 to-purple-50">
      <h3 class="font-semibold text-gray-900 flex items-center">
        <svg class="w-5 h-5 mr-2 text-indigo-500" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"/>
        </svg>
        멤버십 정보
      </h3>
    </div>
    <div class="p-6">
      <div class="flex items-center justify-between mb-4">
        <span class="text-sm text-gray-500">현재 등급</span>
        <span class="<%= user.membership_badge_class %>"><%= user.membership_label %></span>
      </div>

      <% if user.subscription_active? && user.subscription_expires_at %>
        <div class="flex items-center justify-between mb-4 pb-4 border-b border-gray-100">
          <span class="text-sm text-gray-500">만료일</span>
          <div class="text-right">
            <span class="text-sm font-medium text-gray-900"><%= l(user.subscription_expires_at, format: :long) %></span>
            <span class="block text-xs text-indigo-600 font-medium"><%= user.days_until_subscription_expires %>일 남음</span>
          </div>
        </div>
      <% end %>

      <% unless user.membership_type_super_admin? %>
        <div class="mt-4 p-4 bg-gradient-to-r from-indigo-500 to-purple-600 rounded-xl text-white">
          <div class="flex items-center justify-between">
            <div>
              <p class="font-medium">프리미엄으로 업그레이드</p>
              <p class="text-sm text-indigo-100">더 많은 기능을 이용해보세요</p>
            </div>
            <%= link_to "#", class: "px-4 py-2 bg-white text-indigo-600 font-medium text-sm rounded-lg hover:bg-indigo-50 transition" do %>
              업그레이드
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
<% end %>

<%# Payment Info (only for self) %>
<% if user == current_user && (user.bank_name.present? || user.toss_id.present?) %>
  <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden mt-6">
    <div class="px-6 py-4 border-b border-gray-100 bg-gray-50/50">
      <h3 class="font-semibold text-gray-900 flex items-center">
        <svg class="w-5 h-5 mr-2 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/>
        </svg>
        결제 정보
      </h3>
    </div>
    <div class="divide-y divide-gray-100">
      <% if user.bank_name.present? && user.account_number.present? %>
        <div class="px-6 py-4 flex items-center justify-between">
          <div>
            <span class="text-xs text-gray-500 block mb-1">계좌번호</span>
            <span class="text-sm font-medium text-gray-900"><%= user.bank_name %> <%= user.account_number %></span>
            <% if user.account_holder.present? %>
              <span class="text-sm text-gray-400 ml-1">(<%= user.account_holder %>)</span>
            <% end %>
          </div>
          <button type="button"
                  class="inline-flex items-center px-3 py-1.5 bg-gray-100 hover:bg-gray-200 text-gray-700 text-xs font-medium rounded-lg transition"
                  data-controller="clipboard"
                  data-clipboard-text="<%= user.account_info_for_copy %>"
                  data-action="click->clipboard#copy">
            <svg class="w-3.5 h-3.5 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/>
            </svg>
            복사
          </button>
        </div>
      <% end %>

      <% if user.toss_id.present? %>
        <div class="px-6 py-4">
          <span class="text-xs text-gray-500 block mb-1">토스 아이디</span>
          <span class="text-sm font-medium text-gray-900"><%= user.toss_id %></span>
        </div>
      <% end %>
    </div>
  </div>
<% end %>


