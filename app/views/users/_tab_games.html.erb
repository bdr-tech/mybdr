<%# 경기 기록 탭 - 픽업 게임 %>
<div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
  <div class="px-6 py-4 border-b border-gray-100 bg-gray-50/50">
    <h3 class="font-semibold text-gray-900 flex items-center">
      <svg class="w-5 h-5 mr-2 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
      </svg>
      픽업 경기 참가 기록
    </h3>
  </div>

  <% if game_applications.any? %>
    <div class="divide-y divide-gray-100">
      <% game_applications.each do |application| %>
        <% game = application.game %>
        <% next unless game %>
        <div class="px-6 py-4 hover:bg-gray-50 transition">
          <div class="flex items-start justify-between">
            <div class="flex-1 min-w-0">
              <%= link_to game_path(game), class: "block group" do %>
                <h4 class="text-sm font-medium text-gray-900 group-hover:text-indigo-600 transition truncate">
                  <%= game.title.presence || "경기" %>
                </h4>
                <div class="mt-1 flex flex-wrap items-center gap-x-3 gap-y-1 text-xs text-gray-500">
                  <span class="flex items-center">
                    <svg class="w-3.5 h-3.5 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                    </svg>
                    <%= game.scheduled_date ? l(game.scheduled_date, format: :short) : "-" %>
                  </span>
                  <% if game.court %>
                    <span class="flex items-center">
                      <svg class="w-3.5 h-3.5 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                      </svg>
                      <%= game.court.name %>
                    </span>
                  <% end %>
                  <% if game.game_type.present? %>
                    <span class="flex items-center">
                      <svg class="w-3.5 h-3.5 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
                      </svg>
                      <%= game.game_type %>
                    </span>
                  <% end %>
                </div>
              <% end %>
            </div>
            <div class="ml-4 flex-shrink-0">
              <% case application.status %>
              <% when "approved" %>
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                  승인됨
                </span>
              <% when "pending" %>
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800">
                  대기중
                </span>
              <% when "rejected" %>
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800">
                  거절됨
                </span>
              <% when "cancelled" %>
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800">
                  취소됨
                </span>
              <% else %>
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-600">
                  <%= application.status %>
                </span>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="p-12 text-center">
      <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
      </svg>
      <h3 class="mt-4 text-sm font-medium text-gray-900">참가한 경기가 없습니다</h3>
      <p class="mt-1 text-sm text-gray-500">픽업 경기에 참가해보세요!</p>
      <%= link_to "경기 찾기", games_path, class: "mt-4 inline-flex items-center px-4 py-2 bg-indigo-600 text-white text-sm font-medium rounded-lg hover:bg-indigo-700 transition" %>
    </div>
  <% end %>
</div>

<%# 주최한 경기 %>
<% if user == current_user && user.organized_games.any? %>
  <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden mt-6">
    <div class="px-6 py-4 border-b border-gray-100 bg-gray-50/50">
      <h3 class="font-semibold text-gray-900 flex items-center">
        <svg class="w-5 h-5 mr-2 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/>
        </svg>
        주최한 경기
        <span class="ml-2 text-xs text-gray-500">(<%= user.organized_games.count %>개)</span>
      </h3>
    </div>
    <div class="divide-y divide-gray-100">
      <% user.organized_games.order(created_at: :desc).limit(10).each do |game| %>
        <div class="px-6 py-4 hover:bg-gray-50 transition">
          <div class="flex items-start justify-between">
            <div class="flex-1 min-w-0">
              <%= link_to game_path(game), class: "block group" do %>
                <h4 class="text-sm font-medium text-gray-900 group-hover:text-indigo-600 transition truncate">
                  <%= game.title.presence || "경기" %>
                </h4>
                <div class="mt-1 flex items-center gap-x-3 text-xs text-gray-500">
                  <span><%= game.scheduled_date ? l(game.scheduled_date, format: :short) : "-" %></span>
                  <span><%= game.applications_count || 0 %>명 신청</span>
                </div>
              <% end %>
            </div>
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-purple-100 text-purple-800">
              주최
            </span>
          </div>
        </div>
      <% end %>
    </div>
  </div>
<% end %>


