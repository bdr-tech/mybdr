<%# 통계 탭 %>
<div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
  <%# 대회 통계 %>
  <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
    <div class="px-6 py-4 border-b border-gray-100 bg-gradient-to-r from-indigo-50 to-purple-50">
      <h3 class="font-semibold text-gray-900 flex items-center">
        <svg class="w-5 h-5 mr-2 text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/>
        </svg>
        대회 통계
      </h3>
    </div>
    <div class="p-6">
      <%# 참가 대회 수 %>
      <div class="text-center mb-6">
        <div class="text-4xl font-bold text-indigo-600"><%= user_stats[:tournaments_participated] %></div>
        <div class="text-sm text-gray-500 mt-1">참가 대회</div>
      </div>
      
      <%# 경기 수 & 평균 %>
      <div class="grid grid-cols-2 gap-4 mb-6">
        <div class="bg-gray-50 rounded-lg p-4 text-center">
          <div class="text-2xl font-bold text-gray-900"><%= user_stats[:tournament][:total_games] %></div>
          <div class="text-xs text-gray-500">총 경기</div>
        </div>
        <div class="bg-gray-50 rounded-lg p-4 text-center">
          <div class="text-2xl font-bold text-gray-900"><%= user_stats[:tournament][:total_points] %></div>
          <div class="text-xs text-gray-500">총 득점</div>
        </div>
      </div>
      
      <%# 평균 통계 %>
      <div class="space-y-3">
        <div class="flex items-center justify-between">
          <span class="text-sm text-gray-600">평균 득점</span>
          <div class="flex items-center gap-2">
            <div class="w-24 h-2 bg-gray-200 rounded-full overflow-hidden">
              <div class="h-full bg-indigo-500 rounded-full" style="width: <%= [user_stats[:tournament][:avg_points].to_f * 3, 100].min %>%"></div>
            </div>
            <span class="text-sm font-semibold text-gray-900 w-12 text-right"><%= user_stats[:tournament][:avg_points] %></span>
          </div>
        </div>
        <div class="flex items-center justify-between">
          <span class="text-sm text-gray-600">평균 리바운드</span>
          <div class="flex items-center gap-2">
            <div class="w-24 h-2 bg-gray-200 rounded-full overflow-hidden">
              <div class="h-full bg-purple-500 rounded-full" style="width: <%= [user_stats[:tournament][:avg_rebounds].to_f * 5, 100].min %>%"></div>
            </div>
            <span class="text-sm font-semibold text-gray-900 w-12 text-right"><%= user_stats[:tournament][:avg_rebounds] %></span>
          </div>
        </div>
        <div class="flex items-center justify-between">
          <span class="text-sm text-gray-600">평균 어시스트</span>
          <div class="flex items-center gap-2">
            <div class="w-24 h-2 bg-gray-200 rounded-full overflow-hidden">
              <div class="h-full bg-emerald-500 rounded-full" style="width: <%= [user_stats[:tournament][:avg_assists].to_f * 5, 100].min %>%"></div>
            </div>
            <span class="text-sm font-semibold text-gray-900 w-12 text-right"><%= user_stats[:tournament][:avg_assists] %></span>
          </div>
        </div>
      </div>
    </div>
  </div>
  
  <%# 픽업 경기 통계 %>
  <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
    <div class="px-6 py-4 border-b border-gray-100 bg-gradient-to-r from-emerald-50 to-teal-50">
      <h3 class="font-semibold text-gray-900 flex items-center">
        <svg class="w-5 h-5 mr-2 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
        </svg>
        픽업 경기 통계
      </h3>
    </div>
    <div class="p-6">
      <div class="grid grid-cols-3 gap-4">
        <div class="text-center">
          <div class="text-3xl font-bold text-emerald-600"><%= user_stats[:pickup][:total_applications] %></div>
          <div class="text-xs text-gray-500 mt-1">총 신청</div>
        </div>
        <div class="text-center">
          <div class="text-3xl font-bold text-blue-600"><%= user_stats[:pickup][:approved_games] %></div>
          <div class="text-xs text-gray-500 mt-1">참가 확정</div>
        </div>
        <div class="text-center">
          <div class="text-3xl font-bold text-purple-600"><%= user_stats[:pickup][:hosted_games] %></div>
          <div class="text-xs text-gray-500 mt-1">주최 경기</div>
        </div>
      </div>
      
      <% if user_stats[:pickup][:total_applications] > 0 %>
        <div class="mt-6 pt-6 border-t border-gray-100">
          <div class="flex items-center justify-between text-sm">
            <span class="text-gray-600">참가 승인율</span>
            <span class="font-semibold text-gray-900">
              <%= ((user_stats[:pickup][:approved_games].to_f / user_stats[:pickup][:total_applications]) * 100).round(1) %>%
            </span>
          </div>
          <div class="mt-2 w-full h-2 bg-gray-200 rounded-full overflow-hidden">
            <div class="h-full bg-emerald-500 rounded-full" 
                 style="width: <%= (user_stats[:pickup][:approved_games].to_f / user_stats[:pickup][:total_applications]) * 100 %>%"></div>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>

<%# 커리어 하이라이트 %>
<div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden mt-6">
  <div class="px-6 py-4 border-b border-gray-100 bg-gradient-to-r from-amber-50 to-orange-50">
    <h3 class="font-semibold text-gray-900 flex items-center">
      <svg class="w-5 h-5 mr-2 text-amber-500" fill="currentColor" viewBox="0 0 24 24">
        <path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"/>
      </svg>
      커리어 누적 기록
    </h3>
  </div>
  <div class="p-6">
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-4">
      <div class="bg-gradient-to-br from-indigo-50 to-indigo-100 rounded-xl p-4 text-center">
        <div class="text-2xl font-bold text-indigo-700"><%= user_stats[:tournament][:total_points] %></div>
        <div class="text-xs text-indigo-600/80 font-medium mt-1">총 득점</div>
      </div>
      <div class="bg-gradient-to-br from-purple-50 to-purple-100 rounded-xl p-4 text-center">
        <div class="text-2xl font-bold text-purple-700"><%= user_stats[:tournament][:total_rebounds] %></div>
        <div class="text-xs text-purple-600/80 font-medium mt-1">총 리바운드</div>
      </div>
      <div class="bg-gradient-to-br from-emerald-50 to-emerald-100 rounded-xl p-4 text-center">
        <div class="text-2xl font-bold text-emerald-700"><%= user_stats[:tournament][:total_assists] %></div>
        <div class="text-xs text-emerald-600/80 font-medium mt-1">총 어시스트</div>
      </div>
      <div class="bg-gradient-to-br from-rose-50 to-rose-100 rounded-xl p-4 text-center">
        <div class="text-2xl font-bold text-rose-700"><%= user_stats[:tournament][:total_steals] %></div>
        <div class="text-xs text-rose-600/80 font-medium mt-1">총 스틸</div>
      </div>
      <div class="bg-gradient-to-br from-blue-50 to-blue-100 rounded-xl p-4 text-center">
        <div class="text-2xl font-bold text-blue-700"><%= user_stats[:tournament][:total_blocks] %></div>
        <div class="text-xs text-blue-600/80 font-medium mt-1">총 블록</div>
      </div>
    </div>
  </div>
</div>

<%# 활동 요약 %>
<div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden mt-6">
  <div class="px-6 py-4 border-b border-gray-100 bg-gray-50/50">
    <h3 class="font-semibold text-gray-900 flex items-center">
      <svg class="w-5 h-5 mr-2 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
      </svg>
      활동 요약
    </h3>
  </div>
  <div class="divide-y divide-gray-100">
    <div class="px-6 py-4 flex items-center justify-between">
      <span class="text-sm text-gray-600">총 경기 참가</span>
      <span class="text-sm font-semibold text-gray-900">
        <%= user_stats[:tournament][:total_games] + user_stats[:pickup][:approved_games] %>경기
      </span>
    </div>
    <div class="px-6 py-4 flex items-center justify-between">
      <span class="text-sm text-gray-600">소속 팀 수</span>
      <span class="text-sm font-semibold text-gray-900"><%= user_stats[:teams_count] %>팀</span>
    </div>
    <div class="px-6 py-4 flex items-center justify-between">
      <span class="text-sm text-gray-600">대회 참가</span>
      <span class="text-sm font-semibold text-gray-900"><%= user_stats[:tournaments_participated] %>회</span>
    </div>
    <div class="px-6 py-4 flex items-center justify-between">
      <span class="text-sm text-gray-600">가입일</span>
      <span class="text-sm font-semibold text-gray-900"><%= l(user.created_at, format: :long) %></span>
    </div>
    <div class="px-6 py-4 flex items-center justify-between">
      <span class="text-sm text-gray-600">회원 등급</span>
      <span class="<%= user.membership_badge_class %>"><%= user.membership_label %></span>
    </div>
  </div>
</div>

<%# Pro 멤버십 상세 통계 안내 (무료회원인 경우) %>
<% if user == current_user && !current_user.subscription_active? %>
  <div class="mt-6 bg-gradient-to-r from-indigo-500 to-purple-600 rounded-xl p-6 text-white">
    <div class="flex items-start justify-between">
      <div>
        <h4 class="font-semibold text-lg flex items-center">
          <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"/>
          </svg>
          Pro 멤버십 통계 기능
        </h4>
        <ul class="mt-3 text-indigo-100 text-sm space-y-1">
          <li>• 경기별 상세 박스스코어</li>
          <li>• 시즌별 평균 통계 비교</li>
          <li>• 커리어 하이 기록</li>
          <li>• 슈팅 차트 및 고급 통계</li>
        </ul>
      </div>
      <%= link_to "#", class: "flex-shrink-0 ml-4 px-5 py-2.5 bg-white text-indigo-600 font-medium text-sm rounded-lg hover:bg-indigo-50 transition" do %>
        업그레이드
      <% end %>
    </div>
  </div>
<% end %>


