<% content_for :title, "농구장 찾기" %>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <!-- 헤더 -->
  <div class="mb-8">
    <h1 class="text-2xl font-bold text-gray-900">농구장 찾기</h1>
    <p class="text-gray-600 mt-1">근처의 농구장을 찾아보세요</p>
  </div>

  <!-- 필터 -->
  <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-4 mb-6">
    <%= form_with url: courts_path, method: :get, local: true, class: "flex flex-wrap gap-4" do |f| %>
      <div class="flex-1 min-w-[200px]">
        <%= f.text_field :q, value: params[:q], class: "form-input w-full", placeholder: "경기장 이름 또는 주소로 검색..." %>
      </div>
      <div class="flex-1 min-w-[150px]">
        <%= f.select :city,
            options_for_select([["모든 지역", ""]] + Court.distinct.pluck(:city).compact.map { |c| [c, c] }, params[:city]),
            {}, class: "form-select w-full" %>
      </div>
      <div class="flex items-center gap-4">
        <label class="flex items-center gap-2 text-sm text-gray-700">
          <%= f.check_box :indoor, { checked: params[:indoor] == "1" }, "1", "0" %>
          실내
        </label>
        <label class="flex items-center gap-2 text-sm text-gray-700">
          <%= f.check_box :outdoor, { checked: params[:outdoor] == "1" }, "1", "0" %>
          실외
        </label>
        <label class="flex items-center gap-2 text-sm text-gray-700">
          <%= f.check_box :parking, { checked: params[:parking] == "1" }, "1", "0" %>
          주차
        </label>
      </div>
      <%= f.submit "검색", class: "btn btn-secondary" %>
    <% end %>
  </div>

  <!-- 경기장 목록 -->
  <% if @courts.any? %>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <% @courts.each do |court| %>
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden hover:shadow-md transition-shadow">
          <!-- 이미지 -->
          <div class="h-40 bg-gray-200 relative">
            <div class="w-full h-full flex items-center justify-center">
              <svg class="w-16 h-16 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
              </svg>
            </div>
            <div class="absolute top-2 right-2">
              <span class="px-2 py-1 text-xs font-medium rounded-full <%= court.indoor? ? 'bg-blue-100 text-blue-700' : 'bg-green-100 text-green-700' %>">
                <%= court.indoor? ? '실내' : '실외' %>
              </span>
            </div>
          </div>

          <!-- 정보 -->
          <div class="p-4">
            <h3 class="font-bold text-lg text-gray-900">
              <%= link_to court.name, court, class: "hover:text-primary-600" %>
            </h3>
            <p class="text-sm text-gray-500 mt-1"><%= court.full_address %></p>

            <!-- 시설 -->
            <div class="flex flex-wrap gap-2 mt-3">
              <% if court.parking_available? %>
                <span class="px-2 py-1 bg-gray-100 text-gray-600 text-xs rounded">주차</span>
              <% end %>
            </div>

            <!-- 추가 정보 -->
            <div class="flex items-center justify-between mt-4 text-sm text-gray-500">
              <% if court.rental_fee.present? && court.rental_fee > 0 %>
                <span class="font-medium text-gray-900"><%= number_to_currency(court.rental_fee, unit: "₩", precision: 0) %>/시간</span>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    </div>

    <!-- 페이지네이션 -->
    <div class="mt-8">
      <%== pagy_nav(@pagy) if @pagy %>
    </div>
  <% else %>
    <div class="text-center py-16">
      <svg class="mx-auto h-16 w-16 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
      </svg>
      <h3 class="mt-4 text-lg font-medium text-gray-900">등록된 농구장이 없습니다</h3>
      <p class="mt-2 text-gray-600">검색 조건을 변경해 보세요</p>
    </div>
  <% end %>
</div>
