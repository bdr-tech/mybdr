<!DOCTYPE html>
<html lang="<%= I18n.locale %>">
  <head>
    <title><%= @tournament_site&.meta_title || @tournament_site&.tournament&.name || "BDR Tournament" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="theme-color" content="<%= @tournament_site&.primary_color || '#E53E3E' %>">
    <meta name="description" content="<%= @tournament_site&.meta_description || @tournament_site&.tournament&.description %>">

    <%# Open Graph %>
    <meta property="og:title" content="<%= @tournament_site&.meta_title || @tournament_site&.tournament&.name %>">
    <meta property="og:description" content="<%= @tournament_site&.meta_description || @tournament_site&.tournament&.description %>">
    <% if @tournament_site&.og_image_url.present? %>
      <meta property="og:image" content="<%= @tournament_site.og_image_url %>">
    <% end %>
    <meta property="og:type" content="website">
    <meta property="og:url" content="<%= request.original_url %>">

    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <% if @tournament_site&.favicon_url.present? %>
      <link rel="icon" href="<%= @tournament_site.favicon_url %>" type="image/png">
    <% else %>
      <link rel="icon" href="/icon.png" type="image/png">
    <% end %>

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>

    <%# Custom theme colors %>
    <style>
      :root {
        --primary-color: <%= @tournament_site&.primary_color || '#E53E3E' %>;
        --secondary-color: <%= @tournament_site&.secondary_color || '#ED8936' %>;
      }
      .bg-primary { background-color: var(--primary-color); }
      .text-primary { color: var(--primary-color); }
      .border-primary { border-color: var(--primary-color); }
      .bg-secondary { background-color: var(--secondary-color); }
      .text-secondary { color: var(--secondary-color); }
    </style>
  </head>

  <body class="min-h-screen bg-white antialiased">
    <%# Tournament Site Navigation %>
    <nav class="fixed top-0 left-0 right-0 z-50 bg-white shadow-sm">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-16">
          <%# Logo / Title %>
          <div class="flex items-center gap-3">
            <% if @tournament_site&.logo_url.present? %>
              <%= link_to site_home_path do %>
                <%= image_tag @tournament_site.logo_url, class: "h-10 w-auto", alt: @tournament_site.tournament.name %>
              <% end %>
            <% else %>
              <%= link_to site_home_path, class: "font-bold text-lg text-gray-900" do %>
                <%= @tournament_site&.site_name || @tournament_site&.tournament&.name %>
              <% end %>
            <% end %>
          </div>

          <%# Navigation Links %>
          <% if @tournament_site %>
            <div class="hidden md:flex items-center gap-6">
              <% @tournament_site.nav_pages.each do |page| %>
                <% nav_url = site_path(page.url_path) %>
                <%= link_to page.title, nav_url,
                            class: "text-gray-600 hover:text-gray-900 font-medium transition-colors #{request.path == nav_url ? 'text-primary' : ''}" %>
              <% end %>
            </div>

            <%# Mobile menu button %>
            <button type="button" class="md:hidden p-2 text-gray-600"
                    data-controller="mobile-menu"
                    data-action="click->mobile-menu#toggle">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
              </svg>
            </button>
          <% end %>
        </div>
      </div>

      <%# Mobile Navigation %>
      <div class="hidden md:hidden" data-mobile-menu-target="menu">
        <div class="px-4 pb-4 space-y-2 bg-white border-t">
          <% @tournament_site&.nav_pages&.each do |page| %>
            <%= link_to page.title, site_path(page.url_path),
                        class: "block py-2 text-gray-600 hover:text-gray-900 font-medium" %>
          <% end %>
        </div>
      </div>
    </nav>

    <%# Main Content %>
    <main class="pt-16">
      <%= yield %>
    </main>

    <%# Footer %>
    <footer class="bg-gray-900 text-white py-12 mt-16">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <%# Tournament Info %>
          <div>
            <h3 class="font-bold text-lg mb-4"><%= @tournament_site&.tournament&.name %></h3>
            <p class="text-gray-400 text-sm">
              <%= @tournament_site&.tournament&.description&.truncate(150) %>
            </p>
          </div>

          <%# Quick Links %>
          <div>
            <h4 class="font-semibold mb-4">바로가기</h4>
            <ul class="space-y-2 text-gray-400 text-sm">
              <% @tournament_site&.nav_pages&.limit(5)&.each do |page| %>
                <li>
                  <%= link_to page.title, site_path(page.url_path), class: "hover:text-white transition-colors" %>
                </li>
              <% end %>
            </ul>
          </div>

          <%# Contact / Social %>
          <div>
            <h4 class="font-semibold mb-4">문의</h4>
            <p class="text-gray-400 text-sm">
              대회 관련 문의사항은<br>
              공지사항을 확인해주세요.
            </p>
          </div>
        </div>

        <div class="border-t border-gray-800 mt-8 pt-8 flex flex-col md:flex-row justify-between items-center gap-4">
          <p class="text-gray-500 text-sm">
            &copy; <%= Date.current.year %> <%= @tournament_site&.tournament&.name %>. All rights reserved.
          </p>
          <p class="text-gray-600 text-xs">
            Powered by <%= link_to "BDR Platform", "https://mybdr.kr", class: "hover:text-white", target: "_blank" %>
          </p>
        </div>
      </div>
    </footer>
  </body>
</html>
