<% content_for :title, @post.title %>

<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <!-- 게시글 -->
  <article class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
    <!-- 헤더 -->
    <div class="p-6 border-b border-gray-100">
      <div class="flex items-center gap-2 mb-3">
        <span class="px-2 py-1 text-xs font-medium rounded-full bg-gray-100 text-gray-600">
          <%= @post.category_label %>
        </span>
      </div>
      <h1 class="text-2xl font-bold text-gray-900"><%= @post.title %></h1>
      <div class="flex items-center justify-between mt-4">
        <div class="flex items-center gap-3">
          <div class="avatar-sm">
            <% if @post.user.profile_image.present? %>
              <img src="<%= @post.user.profile_image %>" alt="" class="w-full h-full object-cover rounded-full">
            <% else %>
              <%= @post.user.display_name[0] %>
            <% end %>
          </div>
          <div>
            <p class="font-medium text-gray-900"><%= @post.user.display_name %></p>
            <p class="text-sm text-gray-500"><%= @post.created_at.strftime("%Y년 %m월 %d일 %H:%M") %></p>
          </div>
        </div>
        <div class="flex items-center gap-2 text-sm text-gray-500">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
          </svg>
          <%= @post.view_count %>
        </div>
      </div>
    </div>

    <!-- 카테고리별 추가 정보 -->
    <% if @post.team_recruit? && @post.team.present? %>
      <!-- 팀원 모집 - 팀 정보 -->
      <div class="mx-6 mt-6 p-4 bg-blue-50 rounded-lg border border-blue-200">
        <h3 class="font-medium text-blue-800 flex items-center gap-2 mb-3">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>
          </svg>
          모집 팀 정보
        </h3>
        <div class="flex items-center gap-4">
          <% if @post.team.logo_url.present? %>
            <img src="<%= @post.team.logo_url %>" alt="<%= @post.team.name %>" class="w-16 h-16 rounded-lg object-cover">
          <% else %>
            <div class="w-16 h-16 bg-blue-200 rounded-lg flex items-center justify-center text-blue-800 text-xl font-bold">
              <%= @post.team.name[0] %>
            </div>
          <% end %>
          <div>
            <h4 class="font-bold text-gray-900"><%= @post.team.name %></h4>
            <p class="text-sm text-gray-600"><%= @post.team.description.presence || "팀 설명이 없습니다." %></p>
            <%= link_to "팀 상세보기 →", team_path(@post.team), class: "text-sm text-blue-600 hover:text-blue-800 mt-1 inline-block" %>
          </div>
        </div>
      </div>
    <% end %>

    <% if @post.court_info? && @post.has_location? %>
      <!-- 농구장 정보 - 위치 정보 -->
      <div class="mx-6 mt-6 p-4 bg-green-50 rounded-lg border border-green-200">
        <h3 class="font-medium text-green-800 flex items-center gap-2 mb-3">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
          </svg>
          위치 정보
        </h3>
        <div class="space-y-2">
          <% if @post.location_name.present? %>
            <p class="font-medium text-gray-900"><%= @post.location_name %></p>
          <% end %>
          <% if @post.location_address.present? %>
            <p class="text-sm text-gray-600"><%= @post.location_address %></p>
          <% end %>
          <div id="court-map" class="h-64 bg-gray-100 rounded-lg mt-3" data-lat="<%= @post.latitude %>" data-lng="<%= @post.longitude %>"></div>
        </div>
      </div>
      <script>
        document.addEventListener('DOMContentLoaded', function() {
          const mapElement = document.getElementById('court-map');
          if (mapElement && window.kakao && kakao.maps) {
            const lat = parseFloat(mapElement.dataset.lat);
            const lng = parseFloat(mapElement.dataset.lng);
            const position = new kakao.maps.LatLng(lat, lng);
            const map = new kakao.maps.Map(mapElement, {
              center: position,
              level: 3
            });
            new kakao.maps.Marker({
              position: position,
              map: map
            });
          }
        });
      </script>
    <% end %>

    <% if @post.trade? %>
      <!-- 장터 - 거래 정보 -->
      <div class="mx-6 mt-6 p-4 bg-orange-50 rounded-lg border border-orange-200">
        <h3 class="font-medium text-orange-800 flex items-center gap-2 mb-3">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          거래 정보
        </h3>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          <div>
            <p class="text-xs text-gray-500 mb-1">가격</p>
            <p class="font-bold text-lg text-gray-900">
              <%= number_to_currency(@post.price, unit: "", precision: 0) %>원
              <% if @post.negotiable %>
                <span class="text-xs font-normal text-orange-600">(협의 가능)</span>
              <% end %>
            </p>
          </div>
          <div>
            <p class="text-xs text-gray-500 mb-1">거래 상태</p>
            <span class="inline-flex items-center px-2.5 py-1 rounded-full text-sm font-medium
              <%= case @post.trade_status
                  when 'available' then 'bg-green-100 text-green-800'
                  when 'reserved' then 'bg-yellow-100 text-yellow-800'
                  when 'sold' then 'bg-gray-100 text-gray-800'
                  end %>">
              <%= @post.trade_status_label %>
            </span>
          </div>
          <% if @post.share_contact %>
            <div>
              <p class="text-xs text-gray-500 mb-1">판매자</p>
              <p class="font-medium text-gray-900"><%= @post.masked_name %></p>
            </div>
            <div>
              <p class="text-xs text-gray-500 mb-1">연락처</p>
              <p class="font-medium text-gray-900"><%= @post.masked_phone || "등록된 번호 없음" %></p>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>

    <!-- 본문 -->
    <div class="p-6">
      <%= render_with_embeds(@post.content) %>
    </div>

    <!-- 액션 -->
    <% if @post.author?(current_user) || current_user&.admin? %>
      <div class="p-6 border-t border-gray-100 bg-gray-50">
        <div class="flex items-center gap-2">
          <%= link_to edit_community_post_path(@post), class: "btn btn-secondary btn-sm" do %>
            <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
            </svg>
            수정
          <% end %>
          <%= button_to community_post_path(@post), method: :delete, class: "btn btn-danger btn-sm", data: { confirm: "정말 삭제하시겠습니까?" } do %>
            <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
            </svg>
            삭제
          <% end %>
        </div>
      </div>
    <% end %>
  </article>

  <!-- 댓글 섹션 -->
  <%= render partial: "community_comments/comments_section", locals: { post: @post } %>

  <!-- 뒤로 가기 -->
  <div class="mt-6">
    <%= link_to "← 목록으로", community_path, class: "text-gray-600 hover:text-gray-900" %>
  </div>
</div>
