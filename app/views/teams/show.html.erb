<% content_for :title, @team.name %>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <!-- 팀 헤더 -->
  <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden mb-6">
    <!-- 배너 -->
    <div class="h-32 sm:h-48 bg-gradient-to-r from-primary-500 to-primary-600 relative">
      <% if @team.banner.attached? %>
        <%= image_tag @team.banner, alt: "", class: "w-full h-full object-cover" %>
      <% elsif @team.banner_url.present? %>
        <img src="<%= @team.banner_url %>" alt="" class="w-full h-full object-cover">
      <% end %>
    </div>

    <div class="relative px-4 sm:px-6 pb-6">
      <!-- 로고 -->
      <div class="absolute -top-12 left-4 sm:left-6">
        <div class="w-24 h-24 bg-white rounded-xl shadow-lg flex items-center justify-center text-3xl font-bold text-primary-600 border-4 border-white overflow-hidden">
          <% if @team.logo.attached? %>
            <%= image_tag @team.logo, alt: @team.name, class: "w-full h-full object-cover" %>
          <% elsif @team.logo_url.present? %>
            <img src="<%= @team.logo_url %>" alt="<%= @team.name %>" class="w-full h-full object-cover">
          <% else %>
            <%= @team.name[0] %>
          <% end %>
        </div>
      </div>

      <!-- 액션 버튼 -->
      <div class="flex justify-end pt-4">
        <% if @team.admin?(current_user) %>
          <%= link_to edit_team_path(@team), class: "btn btn-secondary mr-2" do %>
            <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
            </svg>
            수정
          <% end %>
        <% elsif logged_in? && @team.can_join?(current_user) %>
          <%= button_to "팀 가입 신청", join_team_path(@team), method: :post, class: "btn btn-primary" %>
        <% elsif logged_in? && @team.member?(current_user) && !@team.captain?(current_user) %>
          <%= button_to "팀 탈퇴", leave_team_path(@team), method: :delete, class: "btn btn-danger",
              data: { confirm: "정말 팀에서 탈퇴하시겠습니까?" } %>
        <% end %>
      </div>

      <!-- 팀 정보 -->
      <div class="mt-8">
        <div class="flex items-center gap-3">
          <h1 class="text-2xl font-bold text-gray-900"><%= @team.name %></h1>
          <% if @team.accepting_members? %>
            <span class="px-2 py-1 bg-green-100 text-green-700 text-xs rounded-full">가입 가능</span>
          <% end %>
        </div>

        <div class="flex flex-wrap items-center gap-4 mt-2 text-sm text-gray-600">
          <span class="flex items-center gap-1">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
            <%= @team.city || "지역 미설정" %>
          </span>
          <span class="flex items-center gap-1">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197m13.5-9a2.5 2.5 0 11-5 0 2.5 2.5 0 015 0z"/>
            </svg>
            <%= @team.members_count %>명
          </span>
          <span class="flex items-center gap-1">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/>
            </svg>
            <%= @team.record_display %> (승률 <%= @team.win_rate %>%)
          </span>
        </div>

        <% if @team.description.present? %>
          <p class="mt-4 text-gray-700"><%= @team.description %></p>
        <% end %>
      </div>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <!-- 메인 콘텐츠 (왼쪽 2/3) -->
    <div class="lg:col-span-2 space-y-6">
      <!-- 팀원 목록 -->
      <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
        <h2 class="text-lg font-bold text-gray-900 mb-4">팀원 (<%= @members.count %>명)</h2>
        <div class="space-y-3">
          <% @members.each do |member| %>
            <div class="flex items-center justify-between p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
              <div class="flex items-center gap-3">
                <div class="avatar-sm">
                  <% if member.user.profile_image.present? %>
                    <img src="<%= member.user.profile_image %>" alt="" class="w-full h-full object-cover rounded-full">
                  <% else %>
                    <%= member.user.display_name[0] %>
                  <% end %>
                </div>
                <div>
                  <p class="font-medium text-gray-900"><%= member.user.display_name %></p>
                  <p class="text-xs text-gray-500">
                    <% if member.role_captain? %>
                      <span class="text-primary-600 font-medium">주장</span>
                    <% elsif member.role_vice_captain? %>
                      <span class="text-blue-600">부주장</span>
                    <% else %>
                      팀원
                    <% end %>
                    <% if member.position.present? %>
                      · <span class="text-gray-600"><%= member.position_name %></span>
                    <% end %>
                    · 가입 <%= time_ago_in_words(member.joined_at) %> 전
                  </p>
                </div>
              </div>
              <% if member.jersey_number.present? %>
                <span class="text-lg font-bold text-gray-400">#<%= member.jersey_number %></span>
              <% end %>
            </div>
          <% end %>
        </div>
      </div>

      <!-- 사진첩 -->
      <% if @team.photos.attached? %>
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
          <div class="flex items-center justify-between mb-4">
            <h2 class="text-lg font-bold text-gray-900 flex items-center gap-2">
              <svg class="w-5 h-5 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
              </svg>
              사진첩 (<%= @team.photos.count %>)
            </h2>
            <% if @team.admin?(current_user) %>
              <%= link_to edit_team_path(@team, anchor: "photos"), class: "text-sm text-primary-600 hover:text-primary-700" do %>
                사진 관리
              <% end %>
            <% end %>
          </div>
          <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-2">
            <% @team.photos.each_with_index do |photo, index| %>
              <div class="aspect-square rounded-lg overflow-hidden bg-gray-100 cursor-pointer hover:opacity-90 transition-opacity"
                   data-controller="lightbox"
                   data-action="click->lightbox#open"
                   data-lightbox-url-value="<%= rails_blob_path(photo, only_path: true) %>">
                <%= image_tag photo.variant(resize_to_fill: [300, 300]),
                    alt: "팀 사진 #{index + 1}",
                    class: "w-full h-full object-cover" %>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>

      <!-- 경기 일정 & 결과 -->
      <% if @upcoming_matches.any? || @recent_matches.any? %>
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
          <h2 class="text-lg font-bold text-gray-900 mb-4">경기 일정 & 결과</h2>

          <%# 예정된 경기 %>
          <% if @upcoming_matches.any? %>
            <div class="mb-6">
              <h3 class="text-sm font-semibold text-blue-600 mb-3 flex items-center gap-2">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                </svg>
                예정된 경기
              </h3>
              <div class="space-y-2">
                <% @upcoming_matches.each do |match| %>
                  <% opponent = @team.opponent_in_match(match) %>
                  <div class="flex items-center justify-between p-3 bg-blue-50 rounded-lg">
                    <div class="flex items-center gap-3">
                      <div class="w-10 h-10 bg-blue-100 rounded-lg flex items-center justify-center">
                        <% if opponent&.logo_url.present? %>
                          <img src="<%= opponent.logo_url %>" alt="" class="w-8 h-8 object-cover rounded">
                        <% else %>
                          <span class="text-sm font-bold text-blue-600"><%= opponent&.name&.first || '?' %></span>
                        <% end %>
                      </div>
                      <div>
                        <p class="font-medium text-gray-900">vs <%= opponent&.name || 'TBD' %></p>
                        <p class="text-xs text-gray-500">
                          <%= match.tournament&.name %> · <%= match.round_display %>
                        </p>
                      </div>
                    </div>
                    <div class="text-right">
                      <% if match.scheduled_at %>
                        <p class="text-sm font-medium text-gray-700"><%= match.scheduled_at.strftime("%m/%d") %></p>
                        <p class="text-xs text-gray-500"><%= match.scheduled_at.strftime("%H:%M") %></p>
                      <% else %>
                        <p class="text-sm text-gray-500">일정 미정</p>
                      <% end %>
                    </div>
                  </div>
                <% end %>
              </div>
            </div>
          <% end %>

          <%# 최근 경기 결과 %>
          <% if @recent_matches.any? %>
            <div>
              <h3 class="text-sm font-semibold text-gray-600 mb-3 flex items-center gap-2">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/>
                </svg>
                최근 경기 결과
              </h3>
              <div class="space-y-2">
                <% @recent_matches.each do |match| %>
                  <% opponent = @team.opponent_in_match(match) %>
                  <% won = @team.won_match?(match) %>
                  <% team_score = @team.team_score_in_match(match) %>
                  <% opponent_score = @team.opponent_score_in_match(match) %>
                  <div class="flex items-center justify-between p-3 <%= won ? 'bg-green-50' : 'bg-red-50' %> rounded-lg">
                    <div class="flex items-center gap-3">
                      <div class="w-10 h-10 <%= won ? 'bg-green-100' : 'bg-red-100' %> rounded-lg flex items-center justify-center">
                        <% if opponent&.logo_url.present? %>
                          <img src="<%= opponent.logo_url %>" alt="" class="w-8 h-8 object-cover rounded">
                        <% else %>
                          <span class="text-sm font-bold <%= won ? 'text-green-600' : 'text-red-600' %>"><%= opponent&.name&.first || '?' %></span>
                        <% end %>
                      </div>
                      <div>
                        <p class="font-medium text-gray-900">vs <%= opponent&.name || 'TBD' %></p>
                        <p class="text-xs text-gray-500">
                          <%= match.tournament&.name %> · <%= match.ended_at&.strftime("%m/%d") %>
                        </p>
                      </div>
                    </div>
                    <div class="text-right">
                      <span class="inline-block px-2 py-0.5 text-xs font-bold rounded <%= won ? 'bg-green-500 text-white' : 'bg-red-500 text-white' %>">
                        <%= won ? '승' : '패' %>
                      </span>
                      <p class="text-lg font-bold <%= won ? 'text-green-700' : 'text-red-700' %>">
                        <%= team_score %> : <%= opponent_score %>
                      </p>
                    </div>
                  </div>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      <% end %>

      <!-- 참가 대회 -->
      <% if @tournament_teams.present? %>
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
          <h2 class="text-lg font-bold text-gray-900 mb-4">참가 대회</h2>
          <div class="space-y-3">
            <% @tournament_teams.each do |tt| %>
              <% tournament = tt.tournament %>
              <%= link_to tournament_path(tournament), class: "flex items-center justify-between p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors" do %>
                <div class="flex items-center gap-3">
                  <div class="w-10 h-10 bg-primary-100 rounded-lg flex items-center justify-center">
                    <svg class="w-5 h-5 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"/>
                    </svg>
                  </div>
                  <div>
                    <p class="font-medium text-gray-900"><%= tournament.name %></p>
                    <p class="text-xs text-gray-500">
                      <% if tournament.series.present? %>
                        <%= tournament.series.name %> ·
                      <% end %>
                      <%= tournament.start_date&.strftime("%Y.%m.%d") %>
                    </p>
                  </div>
                </div>
                <div class="text-right">
                  <% if tt.respond_to?(:wins) && tt.respond_to?(:losses) %>
                    <p class="text-sm font-medium text-gray-700"><%= tt.wins || 0 %>승 <%= tt.losses || 0 %>패</p>
                  <% end %>
                  <% status_class = case tt.status
                    when "approved" then "bg-green-100 text-green-700"
                    when "pending" then "bg-yellow-100 text-yellow-700"
                    when "eliminated" then "bg-red-100 text-red-700"
                    when "champion" then "bg-amber-100 text-amber-700"
                    else "bg-gray-100 text-gray-700"
                  end %>
                  <span class="inline-block px-2 py-0.5 text-xs rounded-full <%= status_class %>">
                    <%= case tt.status
                      when "approved" then "참가중"
                      when "pending" then "승인대기"
                      when "eliminated" then "탈락"
                      when "champion" then "우승"
                      when "runner_up" then "준우승"
                      else tt.status
                    end %>
                  </span>
                </div>
              <% end %>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>

    <!-- 사이드바 (오른쪽 1/3) -->
    <div class="space-y-6">
      <!-- 팀 정보 -->
      <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
        <h3 class="text-lg font-bold text-gray-900 mb-4">팀 정보</h3>
        <dl class="space-y-3">
          <div class="flex justify-between">
            <dt class="text-gray-500">팀장</dt>
            <dd class="font-medium text-gray-900"><%= @team.captain.display_name %></dd>
          </div>
          <% if @team.home_court.present? %>
            <div class="flex justify-between">
              <dt class="text-gray-500">홈 코트</dt>
              <dd class="font-medium text-gray-900"><%= @team.home_court %></dd>
            </div>
          <% end %>
          <div class="flex justify-between">
            <dt class="text-gray-500">창단일</dt>
            <dd class="font-medium text-gray-900"><%= @team.created_at.strftime("%Y년 %m월 %d일") %></dd>
          </div>
        </dl>
      </div>

      <!-- 포지션 분포 -->
      <% if @position_distribution.any? %>
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
          <h3 class="text-lg font-bold text-gray-900 mb-4">포지션 분포</h3>
          <div class="space-y-3">
            <%
              positions = {
                "point_guard" => { name: "PG", color: "bg-blue-500" },
                "shooting_guard" => { name: "SG", color: "bg-green-500" },
                "small_forward" => { name: "SF", color: "bg-yellow-500" },
                "power_forward" => { name: "PF", color: "bg-orange-500" },
                "center" => { name: "C", color: "bg-red-500" }
              }
              total_with_position = @position_distribution.values.sum
            %>
            <% positions.each do |key, info| %>
              <% count = @position_distribution[key] || 0 %>
              <% percentage = total_with_position > 0 ? (count.to_f / total_with_position * 100).round : 0 %>
              <div class="flex items-center gap-3">
                <span class="w-8 text-sm font-medium text-gray-700"><%= info[:name] %></span>
                <div class="flex-1 bg-gray-200 rounded-full h-2.5">
                  <div class="<%= info[:color] %> h-2.5 rounded-full" style="width: <%= percentage %>%"></div>
                </div>
                <span class="text-sm text-gray-600 w-12 text-right"><%= count %>명</span>
              </div>
            <% end %>
            <% nil_count = @position_distribution[nil] || 0 %>
            <% if nil_count > 0 %>
              <div class="flex items-center gap-3">
                <span class="w-8 text-sm font-medium text-gray-500">미정</span>
                <div class="flex-1 bg-gray-200 rounded-full h-2.5">
                  <div class="bg-gray-400 h-2.5 rounded-full" style="width: <%= (nil_count.to_f / total_with_position * 100).round %>%"></div>
                </div>
                <span class="text-sm text-gray-600 w-12 text-right"><%= nil_count %>명</span>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>

      <!-- 가입 신청 목록 (관리자 전용) -->
      <% if @team.admin?(current_user) && @pending_requests&.any? %>
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
          <h3 class="text-lg font-bold text-gray-900 mb-4">
            가입 신청 (<%= @pending_requests.count %>)
          </h3>
          <div class="space-y-3">
            <% @pending_requests.each do |request| %>
              <div class="p-3 bg-yellow-50 rounded-lg">
                <div class="flex items-center justify-between mb-2">
                  <div class="flex items-center gap-2">
                    <div class="avatar-sm bg-yellow-100">
                      <%= request.user.display_name[0] %>
                    </div>
                    <div>
                      <span class="font-medium text-gray-900"><%= request.user.display_name %></span>
                      <p class="text-xs text-gray-500"><%= time_ago_in_words(request.created_at) %> 전</p>
                    </div>
                  </div>
                </div>
                <% if request.message.present? %>
                  <p class="text-sm text-gray-600 mb-2 bg-white p-2 rounded"><%= request.message %></p>
                <% end %>
                <div class="flex gap-2">
                  <%= button_to "수락", approve_team_team_join_request_path(@team, request),
                      method: :post,
                      class: "flex-1 btn btn-sm btn-primary" %>
                  <%= button_to "거절", reject_team_team_join_request_path(@team, request),
                      method: :post,
                      class: "flex-1 btn btn-sm btn-ghost",
                      data: { confirm: "정말 거절하시겠습니까?" } %>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>

      <!-- 팀원 변경 이력 (관리자 전용) -->
      <% if @team.admin?(current_user) && @member_histories&.any? %>
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
          <h3 class="text-lg font-bold text-gray-900 mb-4">최근 변경 이력</h3>
          <div class="space-y-2">
            <% @member_histories.each do |history| %>
              <div class="flex items-start gap-2 text-sm">
                <%
                  icon_class = case history.action
                    when "joined" then "text-green-500"
                    when "left", "kicked" then "text-red-500"
                    when "captain_transferred" then "text-blue-500"
                    when "role_changed" then "text-purple-500"
                    else "text-gray-500"
                  end
                  icon = case history.action
                    when "joined" then "M12 4v16m8-8H4"
                    when "left" then "M6 18L18 6M6 6l12 12"
                    when "kicked" then "M13 7a4 4 0 11-8 0 4 4 0 018 0zM9 14a6 6 0 00-6 6v1h12v-1a6 6 0 00-6-6zM21 12h-6"
                    when "captain_transferred" then "M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"
                    when "role_changed" then "M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"
                    else "M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
                  end
                %>
                <svg class="w-4 h-4 mt-0.5 <%= icon_class %>" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="<%= icon %>"/>
                </svg>
                <div class="flex-1">
                  <p class="text-gray-700">
                    <span class="font-medium"><%= history.user.display_name %></span>
                    <span class="text-gray-500"><%= history.action_label %></span>
                  </p>
                  <p class="text-xs text-gray-400"><%= time_ago_in_words(history.created_at) %> 전</p>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>
