<% content_for :title, "팀 만들기" %>

<div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
    <h1 class="text-2xl font-bold text-gray-900 mb-6">팀 만들기</h1>

    <%= form_with model: @team, local: true, html: { multipart: true }, class: "space-y-6" do |f| %>
      <% if @team.errors.any? %>
        <div class="bg-red-50 text-red-600 p-4 rounded-lg">
          <ul class="list-disc list-inside">
            <% @team.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div>
        <%= f.label :name, "팀 이름", class: "form-label" %>
        <%= f.text_field :name, class: "form-input w-full", placeholder: "팀 이름을 입력하세요", required: true %>
      </div>

      <div>
        <%= f.label :description, "팀 소개", class: "form-label" %>
        <%= f.text_area :description, class: "form-input w-full", rows: 4, placeholder: "팀을 소개해주세요" %>
      </div>

      <div>
        <%= f.label :city, "활동 지역", class: "form-label" %>
        <%= f.text_field :city, class: "form-input w-full", placeholder: "예: 서울" %>
      </div>

      <div>
        <%= f.label :home_court, "홈 코트", class: "form-label" %>
        <%= f.text_field :home_court, class: "form-input w-full", placeholder: "주로 활동하는 경기장" %>
      </div>

      <%# 팀 로고 업로드 %>
      <div>
        <%= f.label :logo, "팀 로고", class: "form-label" %>
        <p class="text-sm text-gray-500 mb-2">팀 생성 후 수정 페이지에서 업로드할 수 있습니다.</p>
      </div>

      <div class="flex flex-col gap-3">
        <label class="flex items-center gap-2">
          <%= f.check_box :is_public, class: "form-checkbox" %>
          <span class="text-gray-700">공개 팀 (검색에 노출)</span>
        </label>

        <label class="flex items-center gap-2">
          <%= f.check_box :accepting_members, class: "form-checkbox" %>
          <span class="text-gray-700">팀원 모집 중</span>
        </label>

        <label class="flex items-center gap-2">
          <%= f.check_box :auto_accept_members, class: "form-checkbox" %>
          <span class="text-gray-700">가입 신청 자동 승인</span>
        </label>
      </div>

      <div class="flex gap-3 pt-4">
        <%= f.submit "팀 만들기", class: "btn btn-primary" %>
        <%= link_to "취소", teams_path, class: "btn btn-ghost" %>
      </div>
    <% end %>
  </div>
</div>
