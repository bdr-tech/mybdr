<% content_for :title, "팀 목록" %>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <!-- 헤더 -->
  <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-8 gap-4">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">팀 목록</h1>
      <p class="text-gray-600 mt-1">함께 할 팀을 찾아보세요</p>
    </div>
    <% if logged_in? %>
      <%= link_to new_team_path, class: "btn btn-primary" do %>
        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
        </svg>
        팀 만들기
      <% end %>
    <% end %>
  </div>

  <!-- 필터 -->
  <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-4 mb-6">
    <%= form_with url: teams_path, method: :get, local: true, class: "flex flex-wrap gap-4" do |f| %>
      <div class="flex-1 min-w-[200px]">
        <%= f.text_field :q, value: params[:q], class: "form-input w-full", placeholder: "팀 이름으로 검색..." %>
      </div>
      <div class="flex-1 min-w-[150px]">
        <%= f.select :city,
            options_for_select([["모든 지역", ""]] + Team::KOREAN_CITIES.map { |c| [c, c] }, params[:city]),
            {}, class: "form-select w-full" %>
      </div>
      <div class="flex items-center gap-2">
        <label class="flex items-center gap-2 text-sm text-gray-700">
          <%= f.check_box :accepting, { checked: params[:accepting] == "1" }, "1", "0" %>
          가입 가능만
        </label>
      </div>
      <%= f.submit "검색", class: "btn btn-secondary" %>
    <% end %>
  </div>

  <!-- 팀 목록 -->
  <% if @teams.any? %>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <% @teams.each do |team| %>
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden hover:shadow-md transition-shadow">
          <!-- 팀 로고/배너 -->
          <div class="h-24 bg-gradient-to-r from-primary-500 to-primary-600 relative">
            <% if team.banner.attached? %>
              <%= image_tag team.banner, alt: "", class: "w-full h-full object-cover" %>
            <% elsif team.banner_url.present? %>
              <img src="<%= team.banner_url %>" alt="" class="w-full h-full object-cover">
            <% end %>
            <div class="absolute -bottom-8 left-4">
              <div class="w-16 h-16 bg-white rounded-lg shadow-md flex items-center justify-center text-2xl font-bold text-primary-600 border-2 border-white overflow-hidden">
                <% if team.logo.attached? %>
                  <%= image_tag team.logo, alt: team.name, class: "w-full h-full object-cover" %>
                <% elsif team.logo_url.present? %>
                  <img src="<%= team.logo_url %>" alt="<%= team.name %>" class="w-full h-full object-cover">
                <% else %>
                  <%= team.name[0] %>
                <% end %>
              </div>
            </div>
          </div>

          <!-- 팀 정보 -->
          <div class="pt-10 px-4 pb-4">
            <div class="flex items-start justify-between">
              <div>
                <h3 class="font-bold text-lg text-gray-900">
                  <%= link_to team.name, team, class: "hover:text-primary-600" %>
                </h3>
                <p class="text-sm text-gray-500"><%= team.city %></p>
              </div>
              <% if team.accepting_members? %>
                <span class="px-2 py-1 bg-green-100 text-green-700 text-xs rounded-full">가입 가능</span>
              <% end %>
            </div>

            <% if team.description.present? %>
              <p class="mt-3 text-sm text-gray-600 line-clamp-2"><%= team.description %></p>
            <% end %>

            <div class="mt-4 flex items-center justify-between text-sm text-gray-500">
              <div class="flex items-center gap-4">
                <span class="flex items-center gap-1">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197m13.5-9a2.5 2.5 0 11-5 0 2.5 2.5 0 015 0z"/>
                  </svg>
                  <%= team.members_count %>명
                </span>
                <span class="flex items-center gap-1">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/>
                  </svg>
                  <%= team.record_display %>
                </span>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    </div>

    <!-- 페이지네이션 -->
    <div class="mt-8">
      <%== pagy_nav(@pagy) if @pagy %>
    </div>
  <% else %>
    <div class="text-center py-16">
      <svg class="mx-auto h-16 w-16 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>
      </svg>
      <h3 class="mt-4 text-lg font-medium text-gray-900">등록된 팀이 없습니다</h3>
      <p class="mt-2 text-gray-600">첫 번째 팀을 만들어보세요!</p>
      <% if logged_in? %>
        <%= link_to "팀 만들기", new_team_path, class: "btn btn-primary mt-4" %>
      <% end %>
    </div>
  <% end %>
</div>
