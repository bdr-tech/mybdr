<% content_for :title, "팀 수정 - #{@team.name}" %>

<div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
    <h1 class="text-2xl font-bold text-gray-900 mb-6">팀 정보 수정</h1>

    <%= form_with model: @team, local: true, html: { multipart: true }, class: "space-y-6" do |f| %>
      <% if @team.errors.any? %>
        <div class="bg-red-50 text-red-600 p-4 rounded-lg">
          <ul class="list-disc list-inside">
            <% @team.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div>
        <%= f.label :name, "팀 이름", class: "form-label" %>
        <%= f.text_field :name, class: "form-input w-full", required: true %>
      </div>

      <div>
        <%= f.label :description, "팀 소개", class: "form-label" %>
        <%= f.text_area :description, class: "form-input w-full", rows: 4 %>
      </div>

      <div>
        <%= f.label :city, "활동 지역", class: "form-label" %>
        <%= f.text_field :city, class: "form-input w-full" %>
      </div>

      <div>
        <%= f.label :home_court, "홈 코트", class: "form-label" %>
        <%= f.text_field :home_court, class: "form-input w-full" %>
      </div>

      <%# 팀 로고 업로드 %>
      <div>
        <label class="form-label">팀 로고</label>
        <div class="mt-2">
          <div class="image-upload-box" data-input-id="logo_input" data-preview-id="logo_preview">
            <%= f.file_field :logo,
                id: "logo_input",
                accept: "image/png,image/jpeg,image/gif,image/webp",
                class: "hidden",
                onchange: "previewImage(this, 'logo_preview')" %>

            <div id="logo_preview" class="w-32 h-32 mx-auto rounded-xl border-2 border-dashed border-gray-300 flex items-center justify-center cursor-pointer hover:border-primary-400 hover:bg-primary-50 transition-all overflow-hidden relative group"
                 onclick="document.getElementById('logo_input').click()"
                 ondragover="handleDragOver(event, this)"
                 ondragleave="handleDragLeave(event, this)"
                 ondrop="handleDrop(event, this, 'logo_input')">
              <% if @team.has_logo? %>
                <% if @team.logo.attached? %>
                  <%= image_tag @team.logo, class: "w-full h-full object-cover", id: "logo_preview_img" %>
                <% elsif @team.logo_url.present? %>
                  <%= image_tag @team.logo_url, class: "w-full h-full object-cover", id: "logo_preview_img" %>
                <% end %>
                <div class="absolute inset-0 bg-black/50 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center">
                  <span class="text-white text-sm font-medium">변경</span>
                </div>
              <% else %>
                <div class="text-center p-4" id="logo_placeholder">
                  <svg class="mx-auto w-10 h-10 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                  </svg>
                  <p class="mt-2 text-xs text-gray-500">클릭 또는 드래그</p>
                </div>
              <% end %>
            </div>
          </div>
          <p class="mt-2 text-xs text-gray-500 text-center">PNG, JPG, GIF, WebP (최대 5MB, 권장: 200x200px)</p>
        </div>
      </div>

      <%# 팀 배너 업로드 %>
      <div>
        <label class="form-label">팀 배너</label>
        <div class="mt-2">
          <div class="image-upload-box" data-input-id="banner_input" data-preview-id="banner_preview">
            <%= f.file_field :banner,
                id: "banner_input",
                accept: "image/png,image/jpeg,image/gif,image/webp",
                class: "hidden",
                onchange: "previewImage(this, 'banner_preview')" %>

            <div id="banner_preview" class="w-full h-40 rounded-xl border-2 border-dashed border-gray-300 flex items-center justify-center cursor-pointer hover:border-primary-400 hover:bg-primary-50 transition-all overflow-hidden relative group"
                 onclick="document.getElementById('banner_input').click()"
                 ondragover="handleDragOver(event, this)"
                 ondragleave="handleDragLeave(event, this)"
                 ondrop="handleDrop(event, this, 'banner_input')">
              <% if @team.has_banner? %>
                <% if @team.banner.attached? %>
                  <%= image_tag @team.banner, class: "w-full h-full object-cover", id: "banner_preview_img" %>
                <% elsif @team.banner_url.present? %>
                  <%= image_tag @team.banner_url, class: "w-full h-full object-cover", id: "banner_preview_img" %>
                <% end %>
                <div class="absolute inset-0 bg-black/50 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center">
                  <span class="text-white text-sm font-medium">변경</span>
                </div>
              <% else %>
                <div class="text-center p-4" id="banner_placeholder">
                  <svg class="mx-auto w-12 h-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                  </svg>
                  <p class="mt-2 text-sm text-gray-500">클릭하거나 이미지를 드래그하세요</p>
                  <p class="text-xs text-gray-400">1200 x 300px 권장</p>
                </div>
              <% end %>
            </div>
          </div>
          <p class="mt-2 text-xs text-gray-500 text-center">PNG, JPG, GIF, WebP (최대 5MB)</p>
        </div>
      </div>

      <div class="flex flex-col gap-3">
        <label class="flex items-center gap-2">
          <%= f.check_box :is_public, class: "form-checkbox" %>
          <span class="text-gray-700">공개 팀 (검색에 노출)</span>
        </label>

        <label class="flex items-center gap-2">
          <%= f.check_box :accepting_members, class: "form-checkbox" %>
          <span class="text-gray-700">팀원 모집 중</span>
        </label>

        <label class="flex items-center gap-2">
          <%= f.check_box :auto_accept_members, class: "form-checkbox" %>
          <span class="text-gray-700">가입 신청 자동 승인</span>
        </label>
      </div>

      <div class="flex gap-3 pt-4">
        <%= f.submit "저장", class: "btn btn-primary" %>
        <%= link_to "취소", @team, class: "btn btn-ghost" %>
      </div>
    <% end %>
  </div>
</div>

<script>
  // 드래그 오버 핸들러
  function handleDragOver(e, element) {
    e.preventDefault();
    e.stopPropagation();
    element.classList.add('border-primary-500', 'bg-primary-50');
    element.classList.remove('border-gray-300');
  }

  // 드래그 리브 핸들러
  function handleDragLeave(e, element) {
    e.preventDefault();
    e.stopPropagation();
    element.classList.remove('border-primary-500', 'bg-primary-50');
    element.classList.add('border-gray-300');
  }

  // 드롭 핸들러
  function handleDrop(e, element, inputId) {
    e.preventDefault();
    e.stopPropagation();
    element.classList.remove('border-primary-500', 'bg-primary-50');
    element.classList.add('border-gray-300');

    const files = e.dataTransfer.files;
    if (files.length > 0) {
      const file = files[0];

      // 이미지 파일인지 확인
      if (!file.type.startsWith('image/')) {
        alert('이미지 파일만 업로드 가능합니다.');
        return;
      }

      // 파일 크기 확인 (5MB)
      if (file.size > 5 * 1024 * 1024) {
        alert('파일 크기는 5MB 이하여야 합니다.');
        return;
      }

      const input = document.getElementById(inputId);
      const dataTransfer = new DataTransfer();
      dataTransfer.items.add(file);
      input.files = dataTransfer.files;

      previewImage(input, element.id);
    }
  }

  // 이미지 미리보기
  function previewImage(input, previewId) {
    const preview = document.getElementById(previewId);
    const file = input.files[0];

    if (file) {
      // 파일 크기 확인 (5MB)
      if (file.size > 5 * 1024 * 1024) {
        alert('파일 크기는 5MB 이하여야 합니다.');
        input.value = '';
        return;
      }

      const reader = new FileReader();
      reader.onload = function(e) {
        // 기존 placeholder 제거하고 이미지로 교체
        preview.innerHTML = `
          <img src="${e.target.result}" class="w-full h-full object-cover" />
          <div class="absolute inset-0 bg-black/50 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center">
            <span class="text-white text-sm font-medium">변경</span>
          </div>
        `;
      };
      reader.readAsDataURL(file);
    }
  }
</script>
