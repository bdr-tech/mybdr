<div class="max-w-7xl mx-auto px-4 py-8">
  <div class="flex justify-between items-center mb-8">
    <div>
      <h1 class="text-3xl font-bold text-white">대회 시리즈</h1>
      <p class="text-zinc-400 mt-2">역대 대회 시리즈를 탐색하세요</p>
    </div>
    <% if logged_in? && current_user.can_create_tournament? %>
      <%= link_to new_tournament_series_path, class: "btn-primary" do %>
        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
        </svg>
        새 시리즈 만들기
      <% end %>
    <% end %>
  </div>

  <% if @series.any? %>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <% @series.each do |series| %>
        <%= link_to tournament_series_path(series), class: "block bg-zinc-800 rounded-xl overflow-hidden hover:bg-zinc-700 transition-colors" do %>
          <% if series.logo_url.present? %>
            <div class="aspect-video bg-zinc-900">
              <img src="<%= series.logo_url %>" alt="<%= series.name %>" class="w-full h-full object-cover">
            </div>
          <% else %>
            <div class="aspect-video bg-gradient-to-br from-orange-500 to-red-600 flex items-center justify-center">
              <span class="text-4xl font-bold text-white"><%= series.name.first(2) %></span>
            </div>
          <% end %>

          <div class="p-4">
            <h3 class="text-lg font-bold text-white mb-2"><%= series.name %></h3>

            <div class="flex items-center gap-4 text-sm text-zinc-400">
              <span>총 <%= series.tournaments_count %>회</span>
              <span>주최: <%= series.organizer.display_name %></span>
            </div>

            <% if series.description.present? %>
              <p class="text-zinc-500 text-sm mt-2 line-clamp-2"><%= series.description %></p>
            <% end %>
          </div>
        <% end %>
      <% end %>
    </div>

    <div class="mt-8">
      <%== pagy_nav(@pagy) if @pagy.pages > 1 %>
    </div>
  <% else %>
    <div class="text-center py-16 bg-zinc-800 rounded-xl">
      <svg class="w-16 h-16 text-zinc-600 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path>
      </svg>
      <h3 class="text-xl font-semibold text-white mb-2">등록된 시리즈가 없습니다</h3>
      <p class="text-zinc-400">첫 번째 대회 시리즈를 시작해보세요!</p>
    </div>
  <% end %>
</div>
