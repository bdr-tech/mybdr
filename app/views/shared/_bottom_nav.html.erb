<%# Mobile Bottom Navigation - Toss Style with Lucide Icons %>
<div data-controller="bottom-nav" class="lg:hidden">
  <nav class="bottom-nav-new">
    <div class="grid grid-cols-5 h-14">
      <%# 홈 (Home) - Lucide Home %>
      <%= link_to root_path, class: "#{current_page?(root_path) ? 'bottom-nav-item-active-new' : 'bottom-nav-item-new'}", data: { turbo_frame: "_top" } do %>
        <svg class="bottom-nav-icon" fill="none" stroke="currentColor" stroke-width="<%= current_page?(root_path) ? '2.5' : '2' %>" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
          <polyline stroke-linecap="round" stroke-linejoin="round" points="9 22 9 12 15 12 15 22"/>
        </svg>
        <span class="bottom-nav-label">홈</span>
      <% end %>

      <%# 경기 (Games) - Lucide Calendar %>
      <%= link_to games_path, class: "#{controller_name == 'games' ? 'bottom-nav-item-active-new' : 'bottom-nav-item-new'}", data: { turbo_frame: "_top" } do %>
        <svg class="bottom-nav-icon" fill="none" stroke="currentColor" stroke-width="<%= controller_name == 'games' ? '2.5' : '2' %>" viewBox="0 0 24 24">
          <rect stroke-linecap="round" stroke-linejoin="round" x="3" y="4" width="18" height="18" rx="2" ry="2"/>
          <line stroke-linecap="round" stroke-linejoin="round" x1="16" y1="2" x2="16" y2="6"/>
          <line stroke-linecap="round" stroke-linejoin="round" x1="8" y1="2" x2="8" y2="6"/>
          <line stroke-linecap="round" stroke-linejoin="round" x1="3" y1="10" x2="21" y2="10"/>
        </svg>
        <span class="bottom-nav-label">경기</span>
      <% end %>

      <%# 대회 (Tournaments) - Lucide Trophy %>
      <%= link_to tournaments_path, class: "#{controller_name == 'tournaments' ? 'bottom-nav-item-active-new' : 'bottom-nav-item-new'}", data: { turbo_frame: "_top" } do %>
        <svg class="bottom-nav-icon" fill="none" stroke="currentColor" stroke-width="<%= controller_name == 'tournaments' ? '2.5' : '2' %>" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"/>
          <path stroke-linecap="round" stroke-linejoin="round" d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"/>
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 22h16"/>
          <path stroke-linecap="round" stroke-linejoin="round" d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22"/>
          <path stroke-linecap="round" stroke-linejoin="round" d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22"/>
          <path stroke-linecap="round" stroke-linejoin="round" d="M18 2H6v7a6 6 0 0 0 12 0V2Z"/>
        </svg>
        <span class="bottom-nav-label">대회</span>
      <% end %>

      <%# 게시판 (Community) - Lucide MessageSquare %>
      <%= link_to community_path, class: "#{controller_name == 'community' ? 'bottom-nav-item-active-new' : 'bottom-nav-item-new'}", data: { turbo_frame: "_top" } do %>
        <svg class="bottom-nav-icon" fill="none" stroke="currentColor" stroke-width="<%= controller_name == 'community' ? '2.5' : '2' %>" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
        </svg>
        <span class="bottom-nav-label">게시판</span>
      <% end %>

      <%# 전체 (Menu) - Lucide Menu %>
      <button type="button"
              class="bottom-nav-item-new"
              data-action="click->bottom-nav#openMenu"
              data-bottom-nav-target="menuButton">
        <svg class="bottom-nav-icon" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <line stroke-linecap="round" stroke-linejoin="round" x1="4" y1="6" x2="20" y2="6"/>
          <line stroke-linecap="round" stroke-linejoin="round" x1="4" y1="12" x2="20" y2="12"/>
          <line stroke-linecap="round" stroke-linejoin="round" x1="4" y1="18" x2="20" y2="18"/>
        </svg>
        <span class="bottom-nav-label">전체</span>
      </button>
    </div>
  </nav>

  <%# Full Menu Slide Panel %>
  <%= render "shared/full_menu" %>
</div>
