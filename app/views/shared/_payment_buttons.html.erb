<%# locals: (user:, amount:, message: nil) %>
<% if user.has_payment_info? %>
  <div class="space-y-4">
    <!-- 계좌 정보 표시 -->
    <div class="bg-gray-50 rounded-xl p-4">
      <p class="text-sm text-gray-500 mb-1">입금 계좌</p>
      <p class="font-medium text-gray-900">
        <%= user.bank_name %> <%= user.account_number %>
      </p>
      <p class="text-sm text-gray-600"><%= user.account_holder %></p>
    </div>

    <!-- 버튼 그룹 -->
    <div class="flex gap-3">
      <!-- 계좌 복사 버튼 -->
      <button
        type="button"
        class="flex-1 flex items-center justify-center gap-2 px-4 py-3 bg-gray-100 hover:bg-gray-200 rounded-xl font-medium transition-colors"
        data-controller="clipboard"
        data-clipboard-text-value="<%= user.full_account_info %>"
        data-action="click->clipboard#copy"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/>
        </svg>
        <span>계좌 복사</span>
      </button>

      <!-- 토스 송금 버튼 -->
      <% toss_url = user.toss_transfer_url(amount: amount, message: message) %>
      <% if toss_url.present? %>
        <a
          href="<%= toss_url %>"
          class="flex-1 flex items-center justify-center gap-2 px-4 py-3 bg-blue-500 hover:bg-blue-600 text-white rounded-xl font-medium transition-colors"
        >
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1.41 16.09V20h-2.67v-1.93c-1.71-.36-3.16-1.46-3.27-3.4h1.96c.1 1.05.82 1.87 2.65 1.87 1.96 0 2.4-.98 2.4-1.59 0-.83-.44-1.61-2.67-2.14-2.48-.6-4.18-1.62-4.18-3.67 0-1.72 1.39-2.84 3.11-3.21V4h2.67v1.95c1.86.45 2.79 1.86 2.85 3.39H14.3c-.05-1.11-.64-1.87-2.22-1.87-1.5 0-2.4.68-2.4 1.64 0 .84.65 1.39 2.67 1.91s4.18 1.39 4.18 3.91c-.01 1.83-1.38 2.83-3.12 3.16z"/>
          </svg>
          <span>토스로 송금</span>
        </a>
      <% end %>
    </div>

    <!-- 안내 메시지 -->
    <div class="text-sm text-gray-500 space-y-1">
      <p class="flex items-center gap-1">
        <svg class="w-4 h-4 text-green-500" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
        </svg>
        송금 시 "<%= message.presence || '이름' %>" 형태로 입금자명을 남겨주세요
      </p>
      <p>금액: <span class="font-medium text-gray-900"><%= number_to_currency(amount, unit: "₩", precision: 0) %></span></p>
    </div>
  </div>
<% else %>
  <div class="text-center py-4 text-gray-500">
    <p>호스트의 결제 정보가 등록되지 않았습니다.</p>
    <p class="text-sm">호스트에게 직접 문의해주세요.</p>
  </div>
<% end %>
